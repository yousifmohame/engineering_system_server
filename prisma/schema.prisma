// ============================================================================
// 📁 1. مركز الإرسال والاستقبال (Document Transfer Center)
// ============================================================================

// 🟢 أ. روابط طلب الوثائق (للاستقبال من العملاء)
model FileRequest {
  id           String  @id @default(cuid())
  title        String
  description  String? @db.Text
  instructions String? @db.Text

  // التوجيه والهدف
  targetType       String  @default("general") // specific, general
  entityName       String? // اسم العميل/الجهة
  mobile           String?
  email            String?
  systemLinkStatus String  @default("unlinked") // unlinked, client, transaction, property
  linkedEntityId   String? // معرف المعاملة أو العميل المرتبط

  // قيود المرسل
  reqSenderName   Boolean @default(true)
  reqSenderMobile Boolean @default(true)
  reqSenderEmail  Boolean @default(false)
  reqSenderNote   Boolean @default(false)
  reqRefNumber    Boolean @default(false)

  // قيود الملفات
  allowMultiple Boolean @default(true)
  maxFiles      Int     @default(10)
  maxFileSize   Int     @default(50) // MB
  totalSize     Int     @default(500) // MB
  allowedTypes  String  @default("all")

  // الحماية والصلاحية
  linkType   String    @default("open") // open, pin, single, expire
  pinCode    String?
  expireDate DateTime?
  maxUses    Int       @default(0)

  // العرض
  showDisclaimer Boolean @default(true)
  disclaimerText String? @db.Text

  // حالة الرابط
  shortLink   String @unique
  status      String @default("نشط") // نشط، منتهي، مغلق
  viewCount   Int    @default(0)
  uploadCount Int    @default(0)

  createdBy String   @default("مدير النظام")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receivedFiles ReceivedFile[]
}

// 🔵 ب. الملفات المستلمة عبر الروابط
model ReceivedFile {
  id          String      @id @default(cuid())
  requestId   String
  fileRequest FileRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  fileName     String
  originalName String
  fileSize     Int
  fileType     String
  filePath     String

  senderName      String?
  senderMobile    String?
  senderEmail     String?
  senderNote      String? @db.Text
  referenceNumber String?

  isProcessed Boolean @default(false)
  isSafe      Boolean @default(true)
  aiAnalysis  Json?

  uploadedAt DateTime @default(now())
}

// 🟠 ج. حزم الإرسال (للإرسال للعملاء)
model DocumentPackage {
  id      String  @id @default(cuid())
  title   String
  message String? @db.Text

  targetType String  @default("specific")
  entityName String?
  mobile     String?
  email      String?

  permissions String    @default("both") // view, download, both
  linkType    String    @default("open") // open, pin, expire
  pinCode     String?
  expireDate  DateTime?

  showDisclaimer     Boolean @default(true)
  disclaimerText     String? @db.Text
  directDownloadMode Boolean @default(false)

  shortLink String @unique
  status    String @default("بانتظار الفتح") // بانتظار الفتح، تم الاستلام، منتهي
  viewCount Int    @default(0)

  // تخزين الملفات المرسلة (كمصفوفة JSON لتوفير مساحة الجداول، تحتوي على اسم ومسار وحجم الملف)
  filesData Json @default("[]")

  createdBy String   @default("مدير النظام")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ⚙️ د. إعدادات مركز الإرسال والاستقبال (صفحات الهبوط)
model TransferCenterSettings {
  id               Int      @id @default(1)
  uploadSettings   Json     @default("{}") // إعدادات صفحة الرفع
  downloadSettings Json     @default("{}") // إعدادات صفحة التنزيل
  updatedAt        DateTime @updatedAt
}

// 📜 هـ. سجل التدقيق للمركز (Audit Trail)
model TransferAuditLog {
  id        String   @id @default(cuid())
  action    String // إنشاء رابط، رفع ملف، فتح رابط، الخ
  user      String // اسم الموظف أو "عميل خارجي"
  target    String // التفاصيل (اسم الملف، رقم الطلب)
  meta      String? // بيانات إضافية للون الأيقونة
  ipAddress String?
  createdAt DateTime @default(now())
}

// ===============================================
// 📇 دليل جهات الاتصال (للمركز والمراسلات الخارجية)
// ===============================================
model Contact {
  id          String @id @default(cuid())
  contactCode String @unique // كود مرجعي (مثال: CNT-1029)

  displayName String // الاسم المعروض
  nameAr      String? // الاسم بالعربية

  mobile1 String // رقم الجوال الأساسي
  email1  String? // البريد الإلكتروني

  detailedType String  @default("client") // نوع الجهة: client, official, vendor, other
  capacity     String? // المسمى / الصفة (مثال: مالك عقار، مدير مشروع)

  // التصنيفات والحالة
  isFavorite     Boolean @default(false)
  isActualClient Boolean @default(false) // هل هو عميل فعلي في النظام أم مجرد جهة اتصال؟
  status         String  @default("active") // active, inactive

  // تفضيلات وقنوات التواصل المتاحة
  acceptsEmail    Boolean @default(true)
  acceptsWhatsApp Boolean @default(true)
  acceptsSMS      Boolean @default(true)
  acceptsTelegram Boolean @default(false)

  tags String[] // مصفوفة نصوص لتصنيفات حرة (مثال: ["عميل VIP", "مشاريع الرياض"])

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mobile1])
  @@index([email1])
}

// ===============================================
// 📧 قوالب رسائل النظام (واتساب، إيميل، SMS)
// ===============================================
model NotificationTemplate {
  id      String @id @default(cuid())
  code    String @unique // مثال: REQ_FIRST_TIME, REQ_REMINDER, SEND_DOCS
  title   String // اسم القالب (يظهر للموظف)
  content String @db.Text // محتوى الرسالة (يحتوي على المتغيرات {targetName})
  type    String // request (طلب) أو send (إرسال)
  channel String @default("all") // القنوات المدعومة (all, whatsapp, email)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MeetingMinute {
  id              String  @id @default(uuid())
  referenceNumber String  @unique
  title           String
  status          String  @default("مسودة")
  meetingType     String?
  meetingCapacity String?
  isFollowUp      Boolean @default(false)
  meetingDate     String?
  startTime       String?
  endTime         String?
  preparationDate String?
  location        String?
  channel         String?
  requester       String?

  // ==========================================
  // 🔗 1. الربط المرجعي بالجداول الأخرى (Relations)
  // ==========================================
  clientName String? // الاسم النصي كمرجع سريع
  clientId   String? // الآي دي للربط الفعلي بجدول العملاء (Persons)

  transactionId  String? // الآي دي للربط الفعلي بجدول المعاملات
  transactionRef String? // 💡 حقل جديد: كود المعاملة المقروء للعرض (TRX)
  transaction    PrivateTransaction? @relation(fields: [transactionId], references: [id])

  linkedQuoteId    String?
  linkedContractId String?

  // ==========================================
  // 📦 2. حقول التابات (تُحفظ كـ JSON)
  // ==========================================
  attendees                 Json  @default("[]")
  axes                      Json  @default("[]")
  steps                     Json  @default("[]")
  verification              Json?
  advancedSignatureSettings Json?
  printSettings             Json?
  attachments               Json  @default("[]")

  // ==========================================
  // 📝 3. الحقول النصية والملاحظات الداخلية
  // ==========================================
  internalNotes String? @db.Text // حقل الملاحظات الداخلية

  // (حقول إضافية متوافقة مع الأنظمة القديمة أو المحاضر البسيطة)
  objective         String? @db.Text
  decisions         String? @db.Text
  discussedPoints   String? @db.Text
  actionItems       String? @db.Text
  background        String? @db.Text
  plannedPoints     String? @db.Text
  clientRequests    String? @db.Text
  companyResponses  String? @db.Text
  postponedRequests String? @db.Text
  recommendations   String? @db.Text
  finalOutcomes     String? @db.Text
  // 🔐 حقل التحقق المشفر
  verificationToken String? @unique

  // ==========================================
  // ⏱️ 4. التتبع
  // ==========================================
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  createdBy  String?
  updatedBy  String?
  quotations Quotation[] @relation("MeetingMinuteQuotations")
}

// ==========================================
// Enums for Documentation System
// ==========================================
enum SignatureType {
  MANUAL
  STAMP_ONLY
  SIG_AND_STAMP
  SECURE_PLACEHOLDER
  SECURE_AND_MANUAL
  NONE
}

enum SealType {
  OFFICE_STAMP
  INTERNAL_STAMP
  VERIFIED_BADGE
  NONE
}

enum DocPosition {
  TOP_RIGHT
  TOP_LEFT
  BOTTOM_RIGHT
  BOTTOM_LEFT
  CENTER
  ALL_PAGES_HEADER
}

enum ReferenceDocType {
  CONTRACT
  QUOTATION
  INVOICE
  EXTERNAL
}

enum DocumentStatus {
  PENDING_SIGNATURE
  VERIFIED
  REVOKED
}

// ==========================================
// 🛡️ 1. Enums (الثوابت لضمان تكامل البيانات)
// ==========================================

enum SecuredDocStatus {
  PENDING_APPROVAL // بانتظار اعتماد المشرف
  VALID // ساري وموثق
  REJECTED // تم رفضه من المشرف
  REVOKED // تم إبطاله أمنياً
  EXPIRED // منتهي الصلاحية
}

enum DocumentCategory {
  CONTRACT
  INVOICE
  QUOTATION
  RECEIPT
  EXTERNAL
}

enum SignatureStyle {
  DIGITAL_SEAL
  MANUAL_SIGNATURE
  SIG_AND_STAMP
  NONE
}

enum StampPosition {
  TOP_LEFT
  TOP_RIGHT
  BOTTOM_LEFT
  BOTTOM_RIGHT
  CENTER
  CUSTOM
}

enum AuditAction {
  SUBMITTED_FOR_APPROVAL
  APPROVED
  REJECTED
  DOCUMENTED
  VIEWED
  VERIFIED
  DOWNLOADED
  PRINTED
  SHARED
  REVOKED
  DELETED
}

enum StampType {
  NONE
  SECURE_QR
}

// ==========================================
// 🎨 2. قوالب الأختام (Seal Templates)
// ==========================================
model SealTemplate {
  id                String  @id @default(uuid())
  name              String
  stampImage        String // مسار الصورة في السيرفر
  serialPrefix      String  @default("SEC-")
  backgroundText    String?
  backgroundColor   String  @default("#eff6ff")
  backgroundOpacity Float   @default(0.6)
  serialPosition    String  @default("bottom")

  // إعدادات القالب
  showTimestamp    Boolean @default(true)
  securityHash     Boolean @default(true)
  verificationCode Boolean @default(true)
  isDefault        Boolean @default(false)
  isActive         Boolean @default(true)

  // العلاقات
  documentedRecords DocumentedRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("seal_templates")
}

// ==========================================
// 🔗 3. إعدادات ربط المستندات (Doc Type Linkage)
// ==========================================
model DocTypeLinkage {
  id          String @id @default(uuid())
  docTypeId   String @unique // معرف النوع (عقد، فاتورة..)
  docTypeName String

  defaultSignatureType SignatureStyle @default(SIG_AND_STAMP)
  signaturePosition    StampPosition  @default(BOTTOM_RIGHT)
  sealPosition         StampPosition  @default(BOTTOM_LEFT)

  signerRoles                Json    @default("[\"Admin\"]") // مصفوفة الصلاحيات
  showDocumentationStatement Boolean @default(true)
  statementTemplate          String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("doc_type_linkages")
}

// ==========================================
// ⚙️ 4. إعدادات النظام الأمنية (System Settings)
// ==========================================
model DocumentationSetting {
  id Int @id @default(1) // Singleton (صف واحد دائماً)

  autoDocumentContracts Boolean @default(true)
  autoDocumentInvoices  Boolean @default(true)
  autoDocumentQuotes    Boolean @default(false)

  verificationUrl   String  @default("https://verify.domain.com")
  defaultFolderName String  @default("Generated Documents")
  privateKeyHash    String? @db.Text // مفتاح التشفير (يُحفظ مشفراً)
  requireOtp        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("documentation_settings")
}

// ==========================================
// 📄 5. سجل التوثيق المركزي (The Registry - Core Model)
// ==========================================
model DocumentedRecord {
  id          String           @id @default(uuid())
  name        String
  type        DocumentCategory // نوع المستند
  referenceId String? // معرف المستند الأصلي (إن وجد)
  partyB      String? // اسم العميل أو الجهة الثانية

  // 🔗 الربط بالكيانات الأخرى (Entity Linking)
  clientId      String?
  transactionId String?
  propertyId    String?

  // 🔐 البيانات الأمنية والمفاتيح
  serialNumber      String          @unique
  verificationToken String          @unique
  securityHash      String          @unique
  fileUrl           String          @db.Text
  signatureType     SignatureStyle?

  // 🚦 دورة الاعتماد (Approval Workflow)
  status     SecuredDocStatus @default(PENDING_APPROVAL)
  approvedBy String? // ID المشرف الذي اعتمد
  approvedAt DateTime?

  // 🛡️ قيود الأمان والمشاهدة (Security & Access Limits)
  isVerifiable Boolean   @default(true)
  maxViews     Int? // الحد الأقصى للمشاهدات (null = لا محدود)
  currentViews Int       @default(0)
  expiryDate   DateTime? // تاريخ انتهاء الصلاحية

  requireOTP  Boolean @default(false)
  clientPhone String? // 👈 رقم جوال العميل لاستلام الـ OTP

  // 📋 الميتا داتا الديناميكية (Dynamic Metadata)
  customMetadata Json?

  // العلاقات
  sealTemplateId String?
  sealTemplate   SealTemplate? @relation(fields: [sealTemplateId], references: [id], onDelete: SetNull)

  createdBy String // ID الموظف المنشئ

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs DocumentationAuditLog[]

  // 🚀 فهارس لتسريع البحث الخرافي
  @@index([serialNumber])
  @@index([verificationToken])
  @@index([status, type])
  @@index([clientId])
  @@index([transactionId])
  @@map("documented_records")
}

// ==========================================
// 👣 6. سجل العمليات والتدقيق (Audit Trail)
// ==========================================
model DocumentationAuditLog {
  id String @id @default(uuid())

  action    AuditAction // نوع الحدث باستخدام Enum
  details   String?     @db.Text
  ipAddress String? // للتتبع الأمني

  // العلاقات
  recordId String?
  record   DocumentedRecord? @relation(fields: [recordId], references: [id], onDelete: SetNull)

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  // فهارس لتسريع استخراج التقارير
  @@index([recordId])
  @@index([employeeId])
  @@index([action, createdAt])
  @@map("documentation_audit_logs")
}

// ===============================================
// 📁 نظام أرشفة المشاريع والمشاريع المرجعية
// ===============================================

model ArchivedProject {
  id              String  @id @default(cuid())
  archiveCode     String  @unique // الترقيم الموحد (مثال: ARC-2023-001)
  title           String // اسم المشروع
  projectType     String // نوع المشروع (سكني، تجاري، متعدد الاستخدامات)
  transactionType String? // نوع المعاملة

  // --- 1. بيانات المالك ---
  clientId      String?
  client        Client? @relation(fields: [clientId], references: [id])
  ownerType     String? // اعتباري (شركة) / طبيعي (أفراد)
  ownerName     String? // 👈 حقل جديد: لحفظ اسم المالك المستخرج من الذكاء الاصطناعي قبل الربط
  contactMobile String?
  poBox         String?

  // --- 2. الرخص والصكوك القانونية ---
  licenseNumber     String?
  licenseIssueDate  DateTime? @db.Date
  licenseExpiryDate DateTime? @db.Date
  deedNumber        String?
  deedDate          DateTime? @db.Date

  requestNumber String?
  requestYear   String?
  serviceNumber String?
  serviceYear   String?

  licenseHijriYear String?

  // --- 3. الموقع والمحددات المكانية ---
  city         String          @default("الرياض")
  districtId   String?
  district     RiyadhDistrict? @relation(fields: [districtId], references: [id])
  districtName String? // 👈 حقل جديد: لحفظ اسم الحي المستخرج من الذكاء الاصطناعي قبل الربط
  mapUrl       String?         @db.Text

  planNumber String?
  planId     String?
  plan       RiyadhPlan? @relation(fields: [planId], references: [id])

  plots      String[] // أرقام القطع
  mainStreet String?
  sectorName String?

  boundaries Json? @default("[]")

  // --- 4. المواصفات الهندسية والمساحات ---
  totalArea        Float?
  coverageRatio    Float?
  far              Float?
  floorsAbove      Int?
  floorsBelow      Int?
  parkingRequired  Int?
  parkingAvailable Int?

  floorAreas Json? @default("[]")
  setbacks   Json? @default("[]")

  // --- 5. الأطراف المهنية والملاحظات ---
  designerOfficeId   String?
  designerOffice     IntermediaryOffice? @relation("ArchivedDesigner", fields: [designerOfficeId], references: [id])
  designerOfficeName String? // 👈 حقل جديد: لحفظ اسم المكتب المصمم المستخرج من الذكاء الاصطناعي قبل الربط

  supervisorOfficeId   String?
  supervisorOffice     IntermediaryOffice? @relation("ArchivedSupervisor", fields: [supervisorOfficeId], references: [id])
  supervisorOfficeName String? // 👈 حقل جديد: لحفظ اسم المكتب المشرف المستخرج من الذكاء الاصطناعي قبل الربط

  archiveNotes String? @db.Text

  // --- 6. حالة تحليل الذكاء الاصطناعي (Gemini) ---
  aiConfidence Float?
  aiStatus     String @default("pending")

  // --- التتبع والعلاقات الإدارية ---
  archivedById String?
  archivedBy   Employee? @relation("EmployeeArchivedProjects", fields: [archivedById], references: [id])

  approvedById String?
  approvedBy   Employee? @relation("ProjectApprover", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files        ArchivedProjectFile[]
  projectPlots ProjectPlot[]

  @@index([clientId])
  @@index([districtId])
  @@index([archiveCode])
}

model ArchivedProjectFile {
  id                String          @id @default(cuid())
  archivedProjectId String
  archivedProject   ArchivedProject @relation(fields: [archivedProjectId], references: [id], onDelete: Cascade)

  fileName     String
  originalName String
  fileUrl      String
  fileType     String // pdf, dwg, png
  fileSize     Int // الحجم بالبايت

  isAiAnalyzed Boolean  @default(false)
  uploadedAt   DateTime @default(now())
}

model SystemNotification {
  id      String  @id @default(cuid())
  title   String // عنوان الإشعار
  message String  @db.Text // تفاصيل الإشعار
  type    String  @default("info") // أنواع: success, warning, error, info
  isRead  Boolean @default(false) // حالة القراءة

  // ربط الإشعار بالموظف المعني
  userId String
  user   Employee @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================================================
// 🤖 جداول إدارة الذكاء الاصطناعي والطوابير (AI & Queue Management)
// ============================================================================

// 2. جدول مهام الذكاء الاصطناعي (لتتبع كل ملف يدخل السيرفر)
model AiJob {
  id        String  @id @default(uuid())
  bullJobId String? @unique // رقم المهمة الفعلي في مكتبة BullMQ

  // نوع المهمة (مثال: ANALYZE_ARCHIVE أو MATCH_CONTRACT)
  jobType String

  // حالة المهمة: PENDING, PROCESSING, COMPLETED, FAILED
  status String @default("PENDING")

  // نسبة الإنجاز (لتشغيل شريط التحميل في الواجهة الأمامية)
  progress Int @default(0)

  // معرف العنصر المستهدف (مثلاً: ID الخاص بالمشروع المؤرشف)
  targetId   String?
  targetType String? // نوع المستهدف (مثال: ARCHIVED_PROJECT)

  // حفظ الأخطاء إن وجدت لكي يقرأها المبرمج أو تظهر في لوحة التحكم
  errorMessage String? @db.Text

  result String? @db.Text

  // من هو الموظف الذي طلب هذا التحليل؟ (لإرسال إشعار له عند الانتهاء)
  requestedBy String?

  // توقيتات لقياس سرعة الذكاء الاصطناعي
  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 3. جدول الإحصائيات اليومية للذكاء الاصطناعي (اختياري ولكنه ممتاز للـ Dashboard)
model AiDailyStat {
  id            String   @id @default(uuid())
  date          DateTime @unique @default(now()) @db.Date // تاريخ اليوم
  totalJobs     Int      @default(0) // إجمالي الملفات التي دخلت اليوم
  successJobs   Int      @default(0) // ما تم بنجاح
  failedJobs    Int      @default(0) // ما فشل
  totalApiCalls Int      @default(0) // عدد الطلبات المرسلة لجوجل (لمراقبة الاستهلاك)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 💡 جهاز البصمة
model ZkDevice {
  id        String    @id @default(uuid())
  name      String // مثال: "جهاز الإدارة الرئيسي"
  ipAddress String    @unique // مثال: "192.168.1.201"
  port      Int       @default(4370)
  status    String    @default("متصل") // متصل، غير متصل
  lastSync  DateTime? // آخر مرة تم سحب البصمات فيها
  createdAt DateTime  @default(now())
}

// 💡 سجل الحضور والانصراف
model AttendanceLog {
  id         String   @id @default(uuid())
  employeeId String
  deviceUid  String
  punchTime  DateTime
  type       String

  // 🚀 الحقول الجديدة لإدارة تجاوز التأخير
  isExcused    Boolean @default(false)
  excuseReason String?

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, punchTime])
}

// 💡 إعدادات سياسات الدوام (سجل واحد فقط للشركة)
model AttendancePolicy {
  id                     String   @id @default("global_policy")
  morningGracePeriodMins Int      @default(15) // فترة السماحية
  autoAbsentAfterMins    Int      @default(120) // احتساب غياب بعد
  enableAiExcuseApproval Boolean  @default(true) // الذكاء الاصطناعي للأعذار
  enableAiCriticalAlerts Boolean  @default(true) // الذكاء الاصطناعي للتنبيهات
  updatedAt              DateTime @updatedAt
}

// جدول الأختام المرجعية
model DeviceStamp {
  token     String   @id // الـ 8 أرقام ستكون هي المفتاح الأساسي
  deviceId  String
  printId   String
  createdAt DateTime @default(now())

  // (اختياري) يمكنك ربطها بجدول الأجهزة إذا أردت
  // device     Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
}

// 1. القالب الرئيسي (الموحد)
model DocumentTemplate {
  id                     String    @id @default(uuid())
  title                  String
  code                   String    @unique
  internalCode           String?
  dueDate                DateTime?
  pageSize               String    @default("A4")
  orientation            String    @default("portrait")
  showPageNumber         Boolean   @default(false)
  showDate               Boolean   @default(false)
  hideTableHeader        Boolean   @default(false)
  sourceType             String    @default("system")
  category               String    @default("document")
  securityLevel          String    @default("public")
  requiresApproval       Boolean   @default(false)
  preventPrintUnapproved Boolean   @default(false)
  maxFileSize            Int       @default(10)
  allowMultiplePages     Boolean   @default(true)
  allowedSizes           Json?
  allowedOrientations    Json?
  allowedExtensions      Json?
  aiEnabled              Boolean   @default(true)
  readinessLevel         String    @default("مكتمل")
  status                 String    @default("نشطة")
  slaStages              Json?
  blocks                 Json?
  rules                  Json?
  obligations            Json?
  notes                  Json?
  exceptions             Json?
  price                  Float     @default(0)
  duration               Int       @default(0)
  internalNotes          String?   @db.Text
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // علاقة بالخدمات
  serviceRequirements ServiceDocRequirement[]
}

// 2. الخدمات
model Service {
  id             String   @id @default(uuid())
  name           String
  code           String   @unique
  pricingModel   String
  price          Float    @default(0)
  duration       Int      @default(0)
  mainCategory   String?
  subCategory    String?
  description    String?  @db.Text
  inclusions     Json?
  exclusions     Json?
  deliverables   Json?
  tags           Json?
  targetAudience Json?
  isActive       Boolean  @default(true)
  visibility     String   @default("public")
  slaHours       Int      @default(24)
  internalNotes  String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  requiredDocs ServiceDocRequirement[]
  stages       ServiceStage[]
  checklists   ServiceChecklist[]
}

// 3. جداول العلاقات
model ServiceDocRequirement {
  serviceId          String
  documentTemplateId String

  service          Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  documentTemplate DocumentTemplate @relation(fields: [documentTemplateId], references: [id], onDelete: Cascade)

  @@id([serviceId, documentTemplateId])
}

model ServiceStage {
  id        String  @id @default(uuid())
  serviceId String
  name      String
  order     Int     @default(0)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model ServiceChecklist {
  id          String  @id @default(uuid())
  serviceId   String
  task        String
  isMandatory Boolean @default(true)
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

// ===============================================
// 📝 جدول التقارير الفنية (Technical Reports)
// ===============================================
model TechnicalReport {
  id           String @id @default(cuid())
  serialNumber String @unique // رقم التقرير (مثل: REP-TECH-2026-0044)
  status       String @default("DRAFT") // مسودة، مكتمل، ملغي

  // 🔗 الروابط الأساسية
  transactionId String?
  transaction   PrivateTransaction? @relation(fields: [transactionId], references: [id])

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  ownershipId String?
  ownership   OwnershipFile? @relation(fields: [ownershipId], references: [id])

  // 📦 تخزين البيانات المرنة كـ JSON لسهولة التعديل والتمدد مستقبلاً
  reportData     Json // يحوي (purpose, template, ownerName, ownerId, etc...)
  components     Json // أدوار ومكونات المبنى
  setbacks       Json // الارتدادات
  compliance     Json // المطابقة
  settings       Json // إعدادات الطباعة
  technicalNotes String? @db.Text

  createdBy String?  @default("النظام")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionId])
  @@index([clientId])
  @@index([ownershipId])
}

// ==========================================
// 🚀 1. نموذج أرشيف وثائق الملكية (المستودع الرئيسي)
// ==========================================
model PropertyDocumentArchive {
  id           String    @id @default(cuid())
  // بيانات الرفع الأساسية
  uploadDate   DateTime  @default(now())
  uploadedById String?
  // ✅ التعديل هنا: استخدام Employee بدلاً من User
  uploadedBy   Employee? @relation("DocUploader", fields: [uploadedById], references: [id])
  status       String    @default("UPLOADED") // UPLOADED, ANALYZING, ANALYZED, NEEDS_REVIEW, CONFIRMED, REJECTED, ARCHIVED

  // بيانات الملف الأصلي
  originalFileName String
  fileUrl          String
  fileType         String // PDF, IMAGE
  fileSize         Float?

  // 🧠 القسم الأول: بيانات تعريف الوثيقة المستخرجة بالذكاء الاصطناعي 🧠
  docType           String? // صك تسجيل ملكية, وثيقة تملك عقار, صك قديم, صك محدث
  docSource         String? // السجل العقاري, وزارة العدل, البورصة العقارية, مصورة
  documentNumber    String?
  propertyNumber    String? // رقم العقار (للسجل العقاري)
  versionNumber     String? // رقم النسخة
  issueDate         DateTime? // تاريخ الوثيقة
  previousDocNumber String? // رقم الوثيقة السابقة إن وجدت
  previousDocDate   DateTime?
  operationType     String? // نوع العملية (انتقال، رهن، إلخ)

  // روابط التحقق
  verificationUrl String? @db.Text
  hasQrCode       Boolean @default(false)
  hasMap          Boolean @default(false)

  // ⚠️ القيود والرهن (مستوى الوثيقة)
  hasRestrictions  String?   @default("NONE") // NONE, MORTGAGED, RESTRICTED, UNKNOWN
  restrictionType  String?
  restrictedTo     String? // الجهة المرتهنة
  restrictionValue Float? // قيمة الرهن
  restrictionDate  DateTime?
  restrictionText  String?   @db.Text // نص القيد

  // 🧠 تقرير الذكاء الاصطناعي
  aiConfidenceScore  Float? // نسبة مئوية
  aiMissingFields    Json? // حقول لم يستطع قراءتها
  aiNotes            String? @db.Text
  isDuplicateSuspect Boolean @default(false)

  // 🔗 الارتباطات التشغيلية
  ownershipId String? // إذا تم ربطها بملف ملكية قائم
  // ✅ التعديل هنا: استخدام OwnershipFile بدلاً من Ownership
  ownership   OwnershipFile? @relation(fields: [ownershipId], references: [id])
  clientId    String?
  client      Client?        @relation(fields: [clientId], references: [id])

  // العلاقات الداخلية
  properties ArchivePropertyDetail[] // القطع والعقارات داخل الوثيقة
  owners     ArchiveOwnerDetail[] // ملاك الوثيقة
  auditLogs  ArchiveAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentNumber, propertyNumber])
}

// ==========================================
// 🚀 2. تفاصيل العقارات/القطع داخل وثيقة الملكية
// ==========================================
model ArchivePropertyDetail {
  id         String                  @id @default(cuid())
  documentId String
  document   PropertyDocumentArchive @relation(fields: [documentId], references: [id], onDelete: Cascade)

  propertyIndex String? // العقار 1 من 5
  city          String?
  district      String?
  planNumber    String?
  blockNumber   String?
  plotNumber    String?
  propertyType  String? // أرض، مبنى
  usageType     String? // سكني، تجاري
  area          Float?
  areaText      String? // المساحة كما وردت نصاً

  // الحدود الأربعة
  boundariesData Json? // [{direction: "شمالاً", type: "شارع", desc: "شارع 20م", length: 20}]

  notes String? @db.Text
}

// ==========================================
// 🚀 3. تفاصيل الملاك داخل وثيقة الملكية
// ==========================================
model ArchiveOwnerDetail {
  id         String                  @id @default(cuid())
  documentId String
  document   PropertyDocumentArchive @relation(fields: [documentId], references: [id], onDelete: Cascade)

  isMainOwner         Boolean @default(false)
  ownerName           String
  identityType        String? // هوية وطنية، سجل تجاري
  identityNumber      String?
  nationality         String?
  ownershipPercentage Float? // نسبة التملك
  ownerRole           String? // مالك، وريث، وكيل
}

// ==========================================
// 🚀 4. سجل المراجعة (Audit Log)
// ==========================================
model ArchiveAuditLog {
  id         String                  @id @default(cuid())
  documentId String
  document   PropertyDocumentArchive @relation(fields: [documentId], references: [id], onDelete: Cascade)

  userId    String
  // ✅ التعديل هنا: استخدام Employee بدلاً من User
  user      Employee @relation(fields: [userId], references: [id])
  action    String // UPLOAD, AI_ANALYZE, MANUAL_EDIT, CONFIRM, LINK_OWNERSHIP
  details   String?  @db.Text
  createdAt DateTime @default(now())
}
