// ==========================================
// 📌 مفكرة المكتب (Office Notepad / Tasks)
// ==========================================

model OfficeTask {
  id              String    @id @default(uuid())
  serialNumber    String    @unique // التنسيق: T-20260411-001
  title           String? // 👈 أضف هذا الحقل ليكون العنوان المختصر
  description     String    @db.Text
  priority        String    @default("medium") // high, medium, low
  status          String    @default("active") // active, completed, frozen, cancelled
  dueDate         DateTime?
  filePath        String?
  additionalNotes String?   @db.Text
  creatorName     String    @default("النظام") // يمكن ربطها بمعرف المستخدم لاحقاً

  // 🔗 الروابط الاختيارية الجديدة
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  transactionId String?
  transaction   PrivateTransaction? @relation(fields: [transactionId], references: [id])

  ownershipId String?
  ownership   OwnershipFile? @relation(fields: [ownershipId], references: [id])

  // حفظ الموظفين المعينين كـ JSON (مصفوفة من الكائنات {id, name}) لتسهيل العرض
  assignedEmployees Json @default("[]")

  subTasks SubTask[]
  comments TaskComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("office_tasks")
}

model SubTask {
  id           String  @id @default(uuid())
  serialNumber String  @unique // التنسيق: ST-20260411-001
  title        String
  isCompleted  Boolean @default(false)
  authorName   String? @default("موظف") // 👈 أضف هذا السطر

  taskId String
  task   OfficeTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("office_sub_tasks")
}

model TaskComment {
  id         String  @id @default(uuid())
  text       String  @db.Text
  authorName String
  isSystem   Boolean @default(false) // لتمييز التعليقات التلقائية (مثل تغيير الحالة)

  taskId String
  task   OfficeTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("office_task_comments")
}

model Device {
  id                  String    @id @default(cuid())
  deviceCode          String    @unique
  type                String
  name                String
  brand               String
  model               String
  serialNumber        String
  status              String    @default("Active")
  location            String?
  assignedTo          String?
  purchaseDate        DateTime?
  purchasePrice       String?
  depreciationRate    String? // 💡 الحقل الجديد لمعدل الإهلاك
  vendor              String?
  warrantyEnd         DateTime?
  invoiceAttachment   String?
  linkedSystem        String?
  nextMaintenanceDate DateTime?
  // أضف هذا الحقل داخل model Device في schema.prisma
  attachments         Json?     @default("[]") // [{ name, url, date }]

