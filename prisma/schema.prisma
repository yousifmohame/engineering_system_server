// server/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===============================================
// 1. نماذج المستخدمين والصلاحيات (Core Identity & Access)
// ===============================================

// ------ نموذج الموظفين (شاشة 817) ------
model Employee {
  id                String    @id @default(cuid())
  employeeCode      String    @unique @default(cuid())
  name              String
  nameEn            String?
  nationalId        String    @unique
  email             String    @unique
  phone             String    @unique
  position          String
  qiwaPosition      String?
  department        String
  hireDate          DateTime
  baseSalary        Float?
  jobLevel          Int?
  type              String    @default("full-time")
  status            String    @default("active")
  nationality       String?
  gosiNumber        String?
  iqamaNumber       String?
  performanceRating Float?
  frozenUntil       DateTime?
  frozenReason      String?
  password          String
  refreshToken      String?
  permissionsCount  Int? // عدد الصلاحيات المخصصة

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- العلاقات الفرعية للموظف ---
  attachments       Attachment[]            @relation("EmployeeAttachments")
  attendanceRecords EmployeeAttendance[]
  leaveRequests     EmployeeLeaveRequest[]
  skills            EmployeeSkill[]
  certifications    EmployeeCertification[]
  evaluations       EmployeeEvaluation[]
  promotions        EmployeePromotion[]

  // --- علاقات العمل والمهام ---
  roles              JobRole[]    @relation("EmployeeToJobRole")
  specialPermissions Permission[] @relation("EmployeeToSpecialPermission")
  managedProjects    Project[]
  assignedTasks      Task[]       @relation("EmployeeToTask")

  // --- المراسلات ---
  sentMessages  Message[]      @relation("SenderToMessage")
  conversations Conversation[] @relation("EmployeeToConversation")

  // --- النظام المالي والإداري ---
  uploadedAttachments Attachment[]
  paymentsReceived    Payment[]     @relation("EmployeeToPayment")
  activitiesPerformed ActivityLog[] @relation("EmployeeToActivityLog")

  // --- إدارة الوثائق ---
  ownedDocuments         Document[]               @relation("OwnedDocuments")
  docPermissions         DocumentPermission[]     @relation("GrantedPermissions")
  documentActivities     DocumentActivity[]
  documentAccess         DocumentPermission[] // الصلاحيات الممنوحة للموظف
  createdClassifications DocumentClassification[] @relation("CreatedClassifications")

  // --- المعاملات ---
  transactionAssignments TransactionEmployee[]
}

// نموذج لسجل الحضور
model EmployeeAttendance {
  id       String    @id @default(cuid())
  date     DateTime  @db.Date
  status   String // (Present, Absent, On Leave)
  checkIn  DateTime? @db.Time
  checkOut DateTime? @db.Time
  notes    String?

  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String

  @@index([employeeId, date])
}

// نموذج لطلبات الإجازات
model EmployeeLeaveRequest {
  id        String   @id @default(cuid())
  type      String // (سنوية, مرضية, ...)
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  status    String   @default("Pending") // (Pending, Approved, Rejected)
  reason    String?

  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String

  @@index([employeeId])
}

// نموذج لمهارات الموظف
model EmployeeSkill {
  id       String @id @default(cuid())
  category String // (فنية, إدارية, لغات)
  skill    String // (AutoCAD, React, إدارة مشاريع)
  level    String // (مبتدئ, متوسط, خبير)

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  @@index([employeeId])
}

// نموذج لشهادات الموظف
model EmployeeCertification {
  id         String    @id @default(cuid())
  name       String // (PMP, شهادة AWS)
  authority  String // (PMI, Amazon)
  issueDate  DateTime  @db.Date
  expiryDate DateTime? @db.Date

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  @@index([employeeId])
}

// نموذج لتقييمات الموظف
model EmployeeEvaluation {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  evaluator String // (اسم المُقيّم أو الإدارة)
  rating    Float // (التقييم من 5)
  comments  String?

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  @@index([employeeId, date])
}

// نموذج لترقيات الموظف
model EmployeePromotion {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  oldPosition String
  newPosition String
  oldLevel    Int
  newLevel    Int
  notes       String?

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  @@index([employeeId, date])
}

// ------ نموذج الأدوار الوظيفية (شاشة 903) ------
model JobRole {
  id               String   @id @default(cuid())
  code             String   @unique
  nameAr           String
  nameEn           String?
  description      String?
  responsibilities String[]
  level            String?
  department       String?
  status           String   @default("active")
  canAssignTasks   Boolean  @default(true)
  allowMultiple    Boolean  @default(true)
  allowMultiRole   Boolean  @default(true)
  order            Int?

  createdDate  DateTime @default(now())
  lastModified DateTime @updatedAt
  modifiedBy   String?

  parentRole   JobRole?  @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  parentRoleId String?
  childRoles   JobRole[] @relation("RoleHierarchy")

  employees   Employee[]   @relation("EmployeeToJobRole")
  permissions Permission[] @relation("JobRoleToPermission")
}

// ------ نموذج الصلاحيات (شاشة 902) ------
model Permission {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  level       String
  screenId    String?
  screenName  String?
  tabId       String?
  tabName     String?
  actionType  String?
  status      String  @default("active")

  frozenType   String?
  frozenDate   DateTime?
  frozenUntil  DateTime?
  frozenBy     String?
  frozenReason String?

  createdDate  DateTime @default(now())
  lastModified DateTime @updatedAt
  modifiedBy   String?

  roles     JobRole[]         @relation("JobRoleToPermission")
  employees Employee[]        @relation("EmployeeToSpecialPermission")
  groups    PermissionGroup[] @relation("GroupToPermission")
}

// ------ نموذج مجموعات الصلاحيات ------
model PermissionGroup {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  permissions Permission[] @relation("GroupToPermission")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

// ===============================================
// 2. نموذج العملاء (Client Module) - محدث ليدعم WMS
// ===============================================

// ------ نموذج العميل (شاشة 300) ------
model Client {
  id         String @id @default(cuid())
  clientCode String @unique

  // --- بيانات الاتصال الأساسية ---
  mobile   String
  email    String? @unique
  idNumber String  @unique // الهوية الوطنية / السجل / رقم الوقف

  // --- بيانات JSON للمرونة ---
  name           Json // { ar: "...", en: "...", details: {...} }
  contact        Json
  address        Json?
  identification Json // (تحتوي على العمر، مكان الميلاد، التاريخ الهجري والميلادي)
  representative Json? // (بيانات الوكيل/الناظر/المفوض)
  heirs          Json? // 👈 1. الإضافة الجديدة: مصفوفة بيانات الورثة 

  // --- حقول WMS الصريحة (للسرعة والفلترة) ---
  officialNameAr String? @map("official_name_ar")
  riskTier       String  @default("LOW")
  profilePicture String? // 👈 2. الإضافة الجديدة: مسار صورة العميل / شعار الوقف أو الشركة

  // --- التفاصيل ---
  type                 String // (فرد، شركة، جهة حكومية، ورثة، وقف، مكتب هندسي)
  category             String?
  nationality          String?
  occupation           String?
  company              String?
  taxNumber            String?
  rating               Int?    @default(3)
  secretRating         Int?    @default(50)
  grade                String? // (أ, ب, ج)
  gradeScore           Int?
  completionPercentage Float?
  isActive             Boolean @default(true)
  notes                String?
  createdBy            String?

  districtId   String?
  districtNode RiyadhDistrict? @relation(fields: [districtId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- العلاقات ---
  ownerships            OwnershipFile[]
  transactions          Transaction[]
  contracts             Contract[]
  quotations            Quotation[]
  attachments           Attachment[]
  activityLogs          ActivityLog[]
  documents             Document[]
  // داخل model Client
  privateTransactions   PrivateTransaction[] @relation("ClientPrivateTransactions")
  TransactionFolder     TransactionFolder[]
  transactionOwnerships TransactionOwner[]
}

model ClientClassification {
  id          String  @id @default(cuid())
  name        String  @unique
  color       String
  description String?
  isActive    Boolean @default(true)
}

// ===============================================
// 3. نموذج الملكيات (Ownership / Deeds Module)
// ===============================================

model OwnershipFile {
  id   String @id @default(cuid())
  code String @unique // كود مرجعي للنظام OWN-2026-xxx

  // --- تفاصيل الصك (Deed Details) ---
  deedNumber       String?
  deedDate         DateTime? @db.Date
  issuingAuthority String? // الجهة المصدرة (كتابة العدل الأولى بالرياض مثلاً)
  status           String    @default("Active") // Active, Sold, Mortgage

  // --- البيانات المكانية (Spatial Data) ---
  city        String?
  district    String?
  planNumber  String? // رقم المخطط
  blockNumber String? // رقم البلوك (تمت إضافته)
  plotNumber  String? // رقم القطعة
  area        Float? // المساحة بالمتر المربع

  districtId   String?
  districtNode RiyadhDistrict? @relation(fields: [districtId], references: [id])

  // --- إحداثيات (لخرائط جوجل أو GIS) ---
  centerLat Float?
  centerLng Float?

  contracts Contract[]

  notes String?

  documents   Json? @default("[]") // الوثائق
  plots       Json? @default("[]") // القطع
  owners      Json? @default("[]") // الملاك والحصص
  boundaries  Json? @default("[]") // الحدود والأطوال
  aiData      Json? // بيانات الذكاء الاصطناعي المستخرجة
  attachments Json? @default("[]") // المرفقات

  // --- العلاقات ---
  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  transactions Transaction[] // المعاملات المرتبطة بهذا الصك

  aiLogs     AIAnalysisLog[] // سجل عمليات التحليل لهذا الصك
  quotations Quotation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deedNumber])
  @@index([district])
  @@index([clientId])
  @@index([districtId])
}

// ===============================================
// *. نموذج جديد: سجل تحليل الذكاء الاصطناعي
// ===============================================

model AIAnalysisLog {
  id String @id @default(cuid())

  fileName String // اسم الملف المرفوع
  filePath String // مسار الملف
  fileSize Int

  status          String // Success, Failed
  confidenceScore Float? // نسبة الدقة (0-100)

  extractedData Json // البيانات الخام المستخرجة (Raw JSON)

  // هل تم اعتماد هذه البيانات وإنشاء صك بها؟
  isApproved Boolean @default(false)

  // ربط اختياري بالصك الذي تم إنشاؤه
  ownershipId String?
  ownership   OwnershipFile? @relation(fields: [ownershipId], references: [id])

  performedBy String? // معرف الموظف الذي قام بالعملية
  createdAt   DateTime @default(now())
}

// ===============================================
// 4. نموذج المعاملات والمشاريع (Core Business Logic)
// ===============================================

// ------ نموذج المشروع ------
model Project {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  description String?
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  manager   Employee? @relation(fields: [managerId], references: [id])
  managerId String?

  transactions Transaction[]
}

// ------ نموذج المعاملة (قلب النظام) ------
model Transaction {
  id              String @id @default(cuid())
  transactionCode String @unique
  title           String

  // --- النوع والقالب ---
  transactionType   TransactionType? @relation(fields: [transactionTypeId], references: [id])
  transactionTypeId String?

  // --- البيانات الأساسية ---
  status                String  @default("Draft")
  statusColor           String? @default("#6b7280")
  priority              String? @default("متوسط")
  description           String?
  location              String?
  deedNumber            String? // يمكن استبداله بالربط مع OwnershipFile
  projectClassification String?

  // --- بيانات التتبع والتقدم ---
  category   String?
  complexity String?
  duration   Int?
  progress   Float?  @default(0)

  // --- البيانات المالية ---
  totalFees       Float? @default(0)
  paidAmount      Float? @default(0)
  remainingAmount Float? @default(0)
  fees            Json?

  // --- التفاصيل الفنية (JSON) ---
  floors               Json? @default("[]")
  setbacks             Json? @default("[]")
  components           Json? @default("[]")
  componentsOldLicense Json? @default("[]")
  componentsProposed   Json? @default("[]")
  componentsExisting   Json? @default("[]")
  boundaries           Json? @default("[]")
  landArea             Json? @default("{}")

  authorities     String[]
  stages          Json?
  warnings        String[]
  notes           Json?    @default("{}")
  approvals       Json?    @default("{}")
  requestPurposes Json?

  // --- العلاقات ---
  client   Client @relation(fields: [clientId], references: [id])
  clientId String

  // علاقة جديدة مع الحي (التقسيم الإداري)
  districtId   String?
  districtNode RiyadhDistrict? @relation(fields: [districtId], references: [id])

  // علاقة جديدة مع الملكية (شاشة 310)
  ownership   OwnershipFile? @relation(fields: [ownershipId], references: [id])
  ownershipId String?

  project   Project? @relation(fields: [projectId], references: [id])
  projectId Int?

  contract   Contract? @relation(fields: [contractId], references: [id])
  contractId String?

  // --- المرفقات والمهام والموظفين ---
  attachments          Attachment[]
  payments             Payment[]
  tasks                Task[]
  documents            Document[]
  appointments         Appointment[]
  transactionEmployees TransactionEmployee[]
  followUpTasks        FollowUpTask[]

  // --- تواريخ ---
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedDate DateTime?
}

// ------ نوع المعاملة (Configuration) ------
model TransactionType {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String  @unique
  description String?
  isActive    Boolean @default(true)

  // تفاصيل الإعدادات
  category      String?
  categoryAr    String?
  duration      Int?    @default(0)
  estimatedCost Float?  @default(0)
  complexity    String?

  defaultCosts Json?
  // القيم الافتراضية
  tasks        Json?
  documents    String[]
  authorities  String[]
  fees         Json?
  stages       Json?
  warnings     String[]
  notes        String[]

  transactions Transaction[]
  quotations   Quotation[]
}

// ------ سجل الموظفين العاملين على المعاملة ------
model TransactionEmployee {
  id String @id @default(cuid())

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String

  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String

  role String // الدور في المعاملة (مهندس مصمم، مراجع، etc)

  createdAt DateTime @default(now())

  @@unique([transactionId, employeeId])
  @@index([transactionId])
  @@index([employeeId])
}

// ===============================================
// 5. النماذج الديناميكية (Dynamic Forms)
// ===============================================

model RequestPurpose {
  id          String  @id @default(cuid())
  type        String // 'brief' أو 'detailed'
  name        String
  nameEn      String
  description String?
  icon        String?
  color       String?
  isActive    Boolean @default(true)

  dynamicForm DynamicFormDefinition?

  @@unique([type, name])
}

model DynamicFormDefinition {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  purpose   RequestPurpose @relation(fields: [purposeId], references: [id], onDelete: Cascade)
  purposeId String         @unique

  fields DynamicFormField[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DynamicFormField {
  id        String @id @default(cuid())
  label     String
  fieldKey  String
  fieldType String
  order     Int    @default(0)

  optionsJson    Json?
  validationJson Json?
  placeholder    String?

  form   DynamicFormDefinition @relation(fields: [formId], references: [id], onDelete: Cascade)
  formId String

  @@unique([formId, fieldKey])
  @@index([formId])
}

// ===============================================
// 6. المهام والمواعيد (Task & Appointment Management)
// ===============================================

model Task {
  id          String    @id @default(cuid())
  taskNumber  String?   @unique
  title       String
  description String?
  status      String    @default("Pending")
  dueDate     DateTime?

  priority         String?   @default("medium")
  progress         Int?      @default(0)
  category         String?
  assignedById     String?
  receivedDate     DateTime?
  completedDate    DateTime?
  attachmentsCount Int?      @default(0)
  commentsCount    Int?      @default(0)
  fees             Json?

  createdAt DateTime @default(now())

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String

  assignedTo   Employee? @relation("EmployeeToTask", fields: [assignedToId], references: [id])
  assignedToId String?

  @@index([assignedToId])
  @@index([transactionId])
}

model Appointment {
  id       String   @id @default(cuid())
  title    String
  date     DateTime
  type     String
  status   String   @default("scheduled")
  notes    String?
  location String?

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionId])
}

// ===============================================
// نموذج قوالب العقود (Contract Templates)
// ===============================================
model ContractTemplate {
  id          String  @id @default(cuid())
  title       String // اسم القالب (مثال: عقد فرد — خدمات هندسية)
  description String? // وصف القالب
  clientType  String // نوع العميل المستهدف (فرد، شركة، جهة حكومية)
  serviceType String // نوع الخدمة (رخصة بناء، إشراف، إلخ)

  hasRep    Boolean @default(false) // هل يدعم وجود ممثل/وكيل؟
  isProxy   Boolean @default(false) // هل يدعم نيابة عن مكتب آخر؟
  isDefault Boolean @default(false) // هل هذا القالب هو الافتراضي؟

  sections  Int @default(1) // عدد أقسام العقد
  usesCount Int @default(0) // عدد مرات استخدام هذا القالب

  clauses Json? @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts Contract[]
}

// ===============================================
// 7. المالية والعقود (Finance & Contracts)
// ===============================================

model Contract {
  id           String   @id @default(cuid())
  contractCode String   @unique
  title        String
  startDate    DateTime
  endDate      DateTime
  totalValue   Float
  status       String   @default("Active")

  client   Client @relation(fields: [clientId], references: [id])
  clientId String

  // 👈 الإضافات الجديدة لحفظ تفاصيل العقد
  ownershipId String?
  ownership   OwnershipFile? @relation(fields: [ownershipId], references: [id])

  templateId String?
  template   ContractTemplate? @relation(fields: [templateId], references: [id])

  clauses Json? @default("[]") // حفظ نسخة من بنود العقد وقت إنشائه

  transactions Transaction[]
  quotation    Quotation?    @relation(fields: [quotationId], references: [id])
  quotationId  String?       @unique
  attachments  Attachment[]
}

// --- Enums الخاصة بعروض الأسعار ---
enum TemplateType {
  SUMMARY
  DETAILED
}

enum QuotationStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  ACCEPTED
  PARTIALLY_PAID
  REJECTED
  TRASHED
  EXPIRED
  CANCELLED // 👈 تم إضافة (ملغى)
  REFUND_IN_PROGRESS // 👈 تم إضافة (استرجاع جارٍ)
  REFUNDED // 👈 تم إضافة (مسترد بالكامل)
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum ClientTitle {
  MR
  MRS
  SIR_COMPANY
  SIR_ENTITY
  SIR_WAQF
  PRINCE
  PRINCESS
  ROYAL_PRINCE
  ROYAL_PRINCESS
  CUSTOM
}

enum HandlingMethod {
  DIRECT
  AUTHORIZED
  AGENT
}

// --- النماذج (Models) الخاصة بعروض الأسعار ---
model Quotation {
  id     String @id @default(cuid())
  number String @unique // QT-26-02-0012

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  // تم تغيير Property إلى OwnershipFile لتطابق قاعدة بياناتك الفعالة
  ownershipId String?
  ownership   OwnershipFile? @relation(fields: [ownershipId], references: [id])

  // البيانات الأساسية
  issueDate    DateTime @default(now())
  validityDays Int      @default(30)
  expiryDate   DateTime
  isRenewable  Boolean  @default(false)

  // نموذج العرض
  templateType     TemplateType @default(SUMMARY)
  templateId       String?
  showClientCode   Boolean      @default(true)
  showPropertyCode Boolean      @default(true)

  // بيانات الخدمة
  transactionTypeId String?
  transactionType   TransactionType? @relation(fields: [transactionTypeId], references: [id])
  serviceNumber     String?
  serviceYear       String?
  licenseNumber     String?
  licenseYear       String?

  // حقول الاعتمادات والأختام
  isStamped Boolean   @default(false)
  stampedAt DateTime?
  stampedBy String? // ID المستخدم الذي قام بالختم

  isSigned      Boolean   @default(false)
  signedAt      DateTime?
  signedBy      String?
  signatureHash String? // رمز التشفير للتوقيع الإلكتروني (إن وُجد)

  // البنود والتسعير
  items            QuotationItem[]
  subtotal         Float           @default(0) // استخدام Float ليتوافق مع باقي النظام
  taxRate          Float           @default(0.15)
  officeTaxBearing Int             @default(0)
  taxAmount        Float           @default(0)
  total            Float           @default(0)
  collectedAmount  Float           @default(0)
  currency         String          @default("SAR")

  // الدفعات
  payments        QuotationPayment[] // تم تغيير الاسم لمنع التضارب مع الدفعات العادية
  acceptedMethods Json?

  // المرفقات والنواقص
  attachments     Attachment[]
  missingDocs     String?      @db.Text
  showMissingDocs Boolean      @default(false)

  // الشروط
  terms          String?        @db.Text
  notes          String?        @db.Text
  clientTitle    ClientTitle    @default(MR)
  handlingMethod HandlingMethod @default(DIRECT)

  // الحالة والربط
  status   QuotationStatus @default(DRAFT)
  contract Contract?

  qrCodeData String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  order       Int
  title       String
  description String?
  category    String?

  quantity     Float        @default(1)
  unit         String       @default("خدمة")
  unitPrice    Float
  discount     Float        @default(0)
  discountType DiscountType @default(PERCENTAGE)

  subtotal Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuotationPayment {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  installmentNumber Int
  percentage        Float
  amount            Float
  dueCondition      String

  createdAt DateTime @default(now())
}

model QuotationTemplate {
  id          String       @id @default(cuid())
  code        String       @unique // TPL-001
  title       String
  description String?      @db.Text
  type        TemplateType @default(SUMMARY)

  // هل هو النموذج الافتراضي
  isDefault Boolean @default(false)
  status    String  @default("active") // "active", "disabled"

  // JSON لتخزين خيارات الأقسام (cover, header, items...)
  sectionsConfig Json @default("{}")
  // JSON لتخزين خيارات العرض الإضافية (showClientCode...)
  displayOptions Json @default("{}")

  defaultTerms String? @db.Text

  // عداد الاستخدام
  usesCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// بند مفرد في المكتبة
model QuotationLibraryItem {
  id          String  @id @default(cuid())
  code        String  @unique // ITM-001
  title       String
  description String? @db.Text
  category    String // "خدمات هندسية", "خدمات قانونية"
  subCategory String? // "رخص وأمانة"
  unit        String  @default("خدمة")
  price       Float   @default(0)

  isEditable  Boolean @default(true)
  isActive    Boolean @default(true)
  warningText String? @db.Text // ملاحظات قانونية/استثناءات
  usesCount   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// مجموعة بنود في المكتبة
model QuotationBundle {
  id          String  @id @default(cuid())
  code        String  @unique // BDL-001
  title       String
  description String? @db.Text
  icon        String? @default("📦") // رمز تعبيري (Emoji)
  color       String? @default("blue") // اللون في الواجهة

  itemsIds String[] // مصفوفة تحتوي على أكواد البنود [ITM-001, ITM-002]

  isActive  Boolean @default(true)
  usesCount Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id        String   @id @default(cuid())
  amount    Float
  date      DateTime @default(now())
  method    String // (Cash, Check, Transfer)
  reference String?
  notes     String?

  category      String? @default("أتعاب مكتب")
  isFollowUpFee Boolean @default(false)
  receiptImage  String?

  receivedBy   Employee @relation("EmployeeToPayment", fields: [receivedById], references: [id])
  receivedById String

  allocations Json? @default("[]")

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionId])
  @@index([receivedById])
}

// ===============================================
// 8. إدارة الوثائق والأرشفة (DMS)
// ===============================================

model Document {
  id         String  @id @default(cuid())
  fileNumber String  @unique
  name       String
  type       String // 'file' أو 'folder'
  extension  String?
  size       Int?
  filePath   String? @unique

  createdAt  DateTime @default(now())
  modifiedAt DateTime @updatedAt

  owner   Employee @relation("OwnedDocuments", fields: [ownerId], references: [id])
  ownerId String

  classification   DocumentClassification? @relation(fields: [classificationId], references: [id])
  classificationId String?

  tags      String[]
  version   String   @default("1.0")
  isShared  Boolean  @default(false)
  downloads Int      @default(0)
  views     Int      @default(0)

  // هيكلية المجلدات
  path     String
  parent   Document?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?
  children Document[] @relation("FolderHierarchy")

  // الربط بالكيانات الأخرى
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String?

  client   Client? @relation(fields: [clientId], references: [id])
  clientId String?

  permissions DocumentPermission[]
  activities  DocumentActivity[]

  @@index([ownerId])
  @@index([parentId])
  @@index([transactionId])
  @@index([clientId])
  @@index([classificationId])
}

// ===============================================
// *. إعدادات أنواع المستندات (Document Types Config)
// ===============================================

model DocumentType {
  id     String  @id @default(cuid())
  code   String  @unique // DOC-001
  name   String
  nameEn String?

  classification    String // "مالي", "فني", "إداري", "قانوني"
  allowedExtensions String[] // ["PDF", "JPG", "DWG"]
  maxSizeMB         Int      @default(5)

  requiresSignature Boolean @default(false)
  confidentiality   String  @default("General") // "General", "Confidential", "TopSecret"
  allowMultiple     Boolean @default(false) // هل يسمح برفع أكثر من ملف لهذا النوع في المعاملة الواحدة؟

  status String @default("Active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentPermission {
  id               String @id @default(cuid())
  permissionNumber String @unique @default(cuid())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String

  user   Employee @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  accessLevel String // 'view', 'edit', 'delete', 'admin'
  expiryDate  DateTime?

  grantedBy   Employee @relation("GrantedPermissions", fields: [grantedById], references: [id])
  grantedById String
  grantedAt   DateTime @default(now())

  @@unique([documentId, userId])
  @@index([userId])
}

model DocumentActivity {
  id             String @id @default(cuid())
  activityNumber String @unique @default(cuid())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String

  fileName String
  action   String // 'upload', 'download', 'edit', 'delete', ...

  user   Employee @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  timestamp DateTime @default(now())
  ipAddress String?
  details   String?

  @@index([documentId])
  @@index([userId])
}

model DocumentClassification {
  id          String  @id @default(cuid())
  name        String  @unique
  color       String  @default("#6b7280")
  description String?

  createdBy   Employee @relation("CreatedClassifications", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())

  documents Document[]

  @@index([createdById])
}

model Attachment {
  id        String   @id @default(cuid())
  fileName  String
  filePath  String   @unique
  fileType  String
  fileSize  Int
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  uploadedBy   Employee @relation(fields: [uploadedById], references: [id])
  uploadedById String

  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String?

  contract   Contract? @relation(fields: [contractId], references: [id])
  contractId String?

  client   Client? @relation(fields: [clientId], references: [id])
  clientId String?

  sectorId String?
  sector   RiyadhSector? @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  districtId String?
  district   RiyadhDistrict? @relation(fields: [districtId], references: [id], onDelete: Cascade)

  employee    Employee?  @relation("EmployeeAttachments", fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId  String?
  quotation   Quotation? @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId String?
}

// ===============================================
// 9. وحدات إضافية (التعقيب، شوارع الرياض، الإعدادات)
// ===============================================

// وحدة التعقيب (Follow-Up)
model FollowUpAgent {
  id                 String  @id @default(cuid())
  type               String // 'individual' or 'entity'
  name               String
  nationalId         String?
  commercialRegister String?

  phone   String
  email   String?
  address String?

  specialization     String[]
  governmentEntities String[]

  joinDate DateTime @default(now())
  status   String   @default("active")
  rating   Float    @default(5.0)
  notes    String?

  tasks FollowUpTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FollowUpTask {
  id String @id @default(cuid())

  agent   FollowUpAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId String

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String

  governmentEntity String
  description      String

  startDate      DateTime  @default(now())
  targetDate     DateTime?
  completionDate DateTime?

  status        String @default("pending")
  successStatus String @default("pending")
  attempts      Int    @default(0)

  notes     String?
  feedbacks String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([transactionId])
}

// وحدة شوارع وتقسيم الرياض
model RiyadhSector {
  id             String           @id @default(cuid())
  code           String           @unique // 👈 جديد: مثل SEC-C
  name           String           @unique
  districts      RiyadhDistrict[] // 👈 جديد: القطاع يحتوي على أحياء
  streets        RiyadhStreet[]
  createdAt      DateTime         @default(now())
  officialLink   String?
  mapImage       String?
  satelliteImage String?
  notes          Json?            @default("[]") // لتخزين الملاحظات
  regulations    Json?            @default("[]") // لتخزين الاشتراطات
  auditLogs      Json?            @default("[]") // لتخزين سجل التعديلات
  attachments    Attachment[] // ربط المرفقات
}

model RiyadhPlan {
  id           String  @id @default(cuid())
  planNumber   String  @unique // رقم المخطط الرسمي (مثال: 2345)
  oldNumber    String? // الترقيم القديم
  internalCode String  @unique // رمز داخلي (مثال: PLAN-C-001)
  status       String // معتمد، قيد المراجعة، ملغى، معدل
  isWithout    Boolean @default(false) // هل هو "بدون" مخطط؟
  properties   Int     @default(0) // عدد الملكيات (للتخزين المؤقت قبل الربط الحقيقي)
  plots        Int     @default(0) // عدد القطع
  attachments  Int     @default(0) // عدد المرفقات

  // علاقة متعدد إلى متعدد مع الأحياء
  districts RiyadhDistrict[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RiyadhDistrict {
  id   String @id @default(cuid())
  code String @unique // 👈 جديد: مثل NBH-C-001
  name String @unique

  sector   RiyadhSector @relation(fields: [sectorId], references: [id]) // 👈 جديد: الحي ينتمي لقطاع
  sectorId String

  streets             RiyadhStreet[]
  plans               RiyadhPlan[]
  ownerships          OwnershipFile[]
  clients             Client[] // أضف هذا السطر
  transactions        Transaction[] // أضف هذا السطر
  createdAt           DateTime             @default(now())
  officialLink        String?
  mapImage            String?
  satelliteImage      String?
  notes               Json?                @default("[]") // لتخزين الملاحظات
  regulations         Json?                @default("[]") // لتخزين الاشتراطات
  auditLogs           Json?                @default("[]") // لتخزين سجل التعديلات
  attachments         Attachment[] // ربط المرفقات
  privateTransactions PrivateTransaction[] @relation("DistrictPrivateTransactions")
}

model RiyadhStreet {
  id         String @id @default(cuid())
  streetCode String @unique
  name       String

  sector   RiyadhSector @relation(fields: [sectorId], references: [id])
  sectorId String

  district   RiyadhDistrict @relation(fields: [districtId], references: [id])
  districtId String

  type   String
  width  Float
  length Float
  lanes  Int
  status String

  lighting  Boolean @default(true)
  sidewalks Boolean @default(true)

  centerLat Float
  centerLng Float

  hasSpecialRegulation Boolean @default(false)
  regulationDetails    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectorId])
  @@index([districtId])
}

// سجل الأنشطة العام
model ActivityLog {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  action      String
  description String
  category    String

  performedBy   Employee @relation("EmployeeToActivityLog", fields: [performedById], references: [id])
  performedById String

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  @@index([clientId])
  @@index([performedById])
}

// نظام المحادثات
model Conversation {
  id        String   @id @default(cuid())
  name      String?
  createdAt DateTime @default(now())

  participants Employee[] @relation("EmployeeToConversation")
  messages     Message[]
}

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String

  sender   Employee @relation("SenderToMessage", fields: [senderId], references: [id])
  senderId String
}

// ===============================================
// 10. النظام الداخلي الموازي (Private / Shadow System)
// ===============================================

model PrivateTransaction {
  id              String @id @default(cuid())
  transactionCode String @unique // مثال: PTX-2026-001
  title           String

  // --- البيانات الأساسية ---
  status      String  @default("جديدة")
  description String?
  category    String? // نوع المعاملة (إصدار، تعديل...)
  complexity  String? // نوع الرفع (برافع، بدون...)
  source      String? // المكتب المنفذ الخارجي الحر
  createdBy   String? @default("مدير النظام")

  // 💡 [احترافي] فصل بيانات الملاك لدعم تعدد الملاك بشكل صريح
  clientId   String
  client     Client  @relation("ClientPrivateTransactions", fields: [clientId], references: [id])
  clientType String? // نوع العميل (فرد، شركة، ورثة...)
  ownerNames String? @db.Text // أسماء الملاك المتعددين (أحمد و محمد)
  ownerIds   String? // هويات الملاك المتعددين

  // 💡 [احترافي] فصل بيانات الموقع والمساحة لسهولة الفلترة والبحث
  districtId   String?
  districtNode RiyadhDistrict? @relation("DistrictPrivateTransactions", fields: [districtId], references: [id])
  districtName String? // اسم الحي (نص حر في حال لم يكن مسجلاً)
  sector       String?
  planNumber   String? // رقم المخطط
  plots        String[] // أرقام القطع كـ Array
  landArea     Float? // مساحة الأرض (Float لتقبل الكسور)
  oldDeed      String? // رقم الصك القديم

  // 💡 [احترافي] فصل أرقام المنصات
  serviceNo String?
  requestNo String?
  licenseNo String?

  // --- البيانات المالية والضريبية ---
  totalFees       Float?  @default(0)
  paidAmount      Float?  @default(0)
  remainingAmount Float?  @default(0)
  firstPayment    Float?  @default(0) // الدفعة الأولى المحصلة
  feeType         String? @default("نهائي") // مبدئي / نهائي

  // 💡 [احترافي] فصل بيانات الضريبة لتسهيل التقارير المحاسبية الختامية
  taxType   String? @default("بدون احتساب ضريبة")
  netAmount Float?  @default(0) // المبلغ الصافي
  taxAmount Float?  @default(0) // قيمة الضريبة المضافة

  // 💡 [احترافي] بيانات المصدر وتوزيع الأرباح
  sourceType    String? @default("مباشر")
  sourceName    String?
  sourcePercent Float?  @default(0)

  // --- التفاصيل الإضافية ---
  authorities String[]
  attachments String[]
  notes       Json?    @default("{}") // مخصص فقط لسجل الأحداث (Logs) والملاحظات العشوائية

  // --- العلاقات العكسية للتسويات ---
  payments      PrivatePayment[]
  settlements   PrivateSettlement[]
  disbursements Disbursement[]
  treasuryLogs  TreasuryTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- العلاقات مع سجل الأشخاص (الأدوار) ---
  brokerId String?
  broker   Person? @relation("TxBroker", fields: [brokerId], references: [id])

  agentId String?
  agent   Person? @relation("TxAgent", fields: [agentId], references: [id])

  officeId String?
  office   IntermediaryOffice? @relation(fields: [officeId], references: [id])

  stakeholderId String?
  stakeholder   Person? @relation("TxStakeholder", fields: [stakeholderId], references: [id])

  receiverId String?
  receiver   Person? @relation("TxReceiver", fields: [receiverId], references: [id])

  engOfficeBrokerId String?
  engOfficeBroker   Person? @relation("TxEngBroker", fields: [engOfficeBrokerId], references: [id])

  tasks       TransactionTask[]
  brokersList TransactionBroker[]

  coopOfficeId String?
  CoopOffice   CoopOffice? @relation(fields: [coopOfficeId], references: [id])

  folders TransactionFolder[]
  files   TransactionFile[]

  // 💡 [احترافي] بيانات التتبع لمدير الملفات
  modifiedBy String? @default("غير محدد") // اسم الموظف الذي قام بآخر تعديل
  isUrgent   Boolean @default(false) // علامة الاستعجال

  // 💡 [احترافي] المعاملات المرتبطة (Linked Transactions) - علاقة ذاتية
  linkedParentId String?
  linkedParent   PrivateTransaction?  @relation("LinkedTransactions", fields: [linkedParentId], references: [id])
  linkedChildren PrivateTransaction[] @relation("LinkedTransactions")

  ownersList TransactionOwner[]

  @@index([clientId])
  @@index([districtId])
}

// 💡 👈 الجدول الوسيط الجديد لربط المعاملة بأكثر من عميل (مالك)
model TransactionOwner {
  id String @id @default(cuid())

  transactionId String
  transaction   PrivateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  clientId String // إجباري: كل مالك يجب أن يكون عميلاً في النظام
  client   Client @relation(fields: [clientId], references: [id])

  idNumber        String?
  sharePercentage Float?  @default(100) // نسبة التملك (اختياري)
  isPrimary       Boolean @default(false) // هل هو العميل الرئيسي للمعاملة؟

  createdAt DateTime @default(now())

  @@unique([transactionId, clientId]) // منع تكرار نفس العميل في نفس المعاملة
  @@index([clientId])
}

// ===============================================
// مدفوعات النظام الداخلي
// ===============================================
model PrivatePayment {
  id        String   @id @default(cuid())
  amount    Float
  date      DateTime @db.Date
  method    String
  periodRef String?

  // 👈 الربط مع سجل الأشخاص (من دفع؟)
  collectedFromType String // من أشخاص النظام، شخص آخر
  collectedFromId   String?
  collectedFrom     Person? @relation("PaymentCollector", fields: [collectedFromId], references: [id])
  collectedFromName String? // يستخدم فقط إذا كان شخصاً خارجياً غير مسجل

  // 👈 الربط مع سجل الأشخاص (الموظف المستلم)
  receiverId String?
  receiver   Person? @relation("PaymentReceiver", fields: [receiverId], references: [id])

  // 👈 الربط مع البنك
  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])

  // 💡 2. هل تم توريد المبلغ النقدي للخزنة؟
  isDepositedToSafe Boolean @default(false)

  notes        String? @db.Text
  receiptImage String?
  collectedBy  String? // اسم أو بيانات الموظف الذي قام بالتحصيل

  // الربط مع المعاملة
  transactionId String?
  transaction   PrivateTransaction? @relation(fields: [transactionId], references: [id])

  createdAt DateTime @default(now())

  @@index([collectedFromId])
  @@index([receiverId])
  @@index([bankAccountId])
}

// ===============================================
// تسويات النظام الداخلي
// ===============================================
model PrivateSettlement {
  id         String @id @default(cuid())
  targetType String

  // 👈 الربط مع المستفيد (شريك، وسيط، معقب)
  targetId   String?
  target     Person? @relation("SettlementTarget", fields: [targetId], references: [id])
  targetName String? // شخص خارجي

  amount Float
  status String @default("PENDING")

  deliveryMethod String?
  deliveryDate   DateTime? @db.Date

  // 👈 الربط مع من قام بتسليم المبلغ
  deliveredById String?
  deliveredBy   Person? @relation("SettlementDeliverer", fields: [deliveredById], references: [id])

  // 👈 الربط مع المعاملة (إذا كانت التسوية تخص معاملة محددة)
  transactionId String?
  transaction   PrivateTransaction? @relation(fields: [transactionId], references: [id])

  source         String?
  periodRef      String?
  notes          String? @db.Text
  attachmentPath String?

  isOpeningBalance Boolean @default(false)
  openingTotal     Float?  @default(0)
  openingDelivered Float?  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetId])
  @@index([deliveredById])
  @@index([transactionId])
}

// ===============================================
// المكاتب المتعاونة
// ===============================================
model CoopOffice {
  id            String  @id @default(cuid())
  name          String
  contactName   String?
  phone         String?
  agreementType String  @default("حسب عدد المعاملات")
  monthlyAmount Float?  @default(0)

  // 👈 الربط مع سجل الأشخاص (المسؤول من طرفكم)
  responsibleId String?
  responsible   Person? @relation("OfficeResponsible", fields: [responsibleId], references: [id])

  isLinkedToSystem Boolean @default(false)
  notes            String? @db.Text

  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  fees               CoopOfficeFee[]
  PrivateTransaction PrivateTransaction[]
}

model CoopOfficeFee {
  id              String @id @default(cuid())
  transactionCode String @unique
  internalName    String

  officeId String
  office   CoopOffice @relation(fields: [officeId], references: [id])

  isSurveyOnly Boolean @default(false)
  isPrepToo    Boolean @default(false)

  officeFees Float
  paidAmount Float     @default(0)
  dueDate    DateTime?

  status String  @default("غير مدفوع")
  notes  String? @db.Text

  // 💡 الحقول الجديدة التي تمت إضافتها من التحديث الأخير
  transactionId    String? // للربط بالمعاملة الأم
  requestType      String? // نوع الطلب (إصدار، تجديد...)
  providedServices String? @db.Text // الخدمات المقدمة (نص حر)
  uploadStatus     String? // حالة الرفع على النظام
  licenseNumber    String? // رقم الرخصة
  licenseYear      String? // سنة الرخصة
  serviceNumber    String? // رقم الخدمة
  serviceYear      String? // سنة الخدمة
  entityName       String? // اسم الجهة

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===============================================
// مصروفات المكتب
// ===============================================
model OfficeExpense {
  id     String @id @default(cuid())
  item   String
  amount Float

  // 👈 الربط مع الأشخاص
  payerId   String?
  payer     Person? @relation("ExpensePayer", fields: [payerId], references: [id])
  payerName String? // في حال كان كيان خارجي (الشركة مثلاً)

  payeeId   String?
  payee     Person? @relation("ExpensePayee", fields: [payeeId], references: [id])
  payeeName String? // جهة خارجية (شركة الكهرباء)

  method        String
  source        String
  expenseDate   DateTime
  notes         String?  @db.Text
  attachmentUrl String?

  isClearable      Boolean @default(false)
  linkToSettlement Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===============================================
// حركات الخزنة
// ===============================================
model TreasuryTransaction {
  id        String   @id @default(cuid())
  type      String
  amount    Float
  date      DateTime
  statement String?

  // 👈 الربط مع المعاملات (إذا كانت الحركة مرتبطة بمعاملة)
  transactionId String?
  transaction   PrivateTransaction? @relation(fields: [transactionId], references: [id])

  // 👈 الربط مع الأشخاص (المستفيد / المودع)
  personId      String?
  person        Person? @relation("TreasuryPerson", fields: [personId], references: [id])
  referenceText String? // نص مرجعي إضافي

  notes         String? @db.Text
  attachmentUrl String?
  metadata      Json?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TreasurySettings {
  id      Int     @id @default(1)
  enabled Boolean @default(true)
  type    String  @default("نسبة مئوية")
  value   Float   @default(27.3)
  method  String  @default("على كل معاملة")

  updatedAt DateTime @updatedAt
}

// ===============================================
// الحسابات البنكية
// ===============================================
model BankAccount {
  id            String  @id @default(cuid())
  bankName      String
  accountName   String?
  accountNumber String  @unique
  iban          String?

  // 👈 الربط مع الأشخاص
  openedById String?
  openedBy   Person? @relation("AccountOpener", fields: [openedById], references: [id])

  controlledById String?
  controlledBy   Person? @relation("AccountController", fields: [controlledById], references: [id])

  openDate          DateTime?
  authorizedPersons String?

  initialBalance      Float     @default(0)
  initialBalanceDate  DateTime?
  initialBalanceNotes String?

  systemBalance   Float @default(0)
  externalBalance Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions    BankTransaction[]
  privatePayments PrivatePayment[]
}

model BankTransaction {
  id        String      @id @default(cuid())
  accountId String
  account   BankAccount @relation(fields: [accountId], references: [id])

  type   String
  amount Float

  // 👈 الربط مع الشريك عند الشحن
  partnerId String?
  partner   Person? @relation("BankTxPartner", fields: [partnerId], references: [id])

  date  DateTime
  notes String?

  createdAt DateTime @default(now())
}

// ===============================================
// أوامر الصرف (Disbursements)
// ===============================================
model Disbursement {
  id            String @id @default(cuid())
  requestNumber String @unique
  type          String

  // 👈 الربط مع المستفيد
  beneficiaryId   String?
  beneficiary     Person? @relation("DisbursementBeneficiary", fields: [beneficiaryId], references: [id])
  beneficiaryName String? // في حال المستفيد خارجي غير مسجل

  amount            Float
  date              DateTime
  reason            String
  notes             String?  @db.Text
  requestAttachment String?

  // 👈 الربط بالمعاملة
  isRelatedToTx Boolean             @default(false)
  transactionId String?
  transaction   PrivateTransaction? @relation(fields: [transactionId], references: [id])

  department String?
  importance String?

  repaymentType      String?
  expectedReturnDate DateTime?
  repaymentMethod    String?

  status          String @default("معلق")
  repaymentStatus String @default("غير مطلوب")
  remainingAmount Float?

  executionMethod     String?
  executionReference  String?
  executionNotes      String?   @db.Text
  executionAttachment String?
  executedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===============================================
// سجل الأشخاص (المركز الأساسي)
// ===============================================
model Person {
  id            String  @id @default(cuid())
  personCode    String  @unique
  name          String
  role          String
  phone         String?
  agreementType String?
  notes         String? @db.Text
  attachments   Json?

  email             String?
  preferredCurrency String? @default("SAR")
  isActive          Boolean @default(true)
  // 🚀 --- الحقول الجديدة للموظف عن بعد والربط المستقبلي ---
  firstNameAr       String?
  secondNameAr      String?
  thirdNameAr       String?
  fourthNameAr      String?

  firstNameEn  String?
  secondNameEn String?
  thirdNameEn  String?
  fourthNameEn String?

  country  String?
  whatsapp String?
  telegram String?

  transferMethod  String? // طريقة التحويل (ويسترن، بنك، انستا)
  transferDetails Json? // تفاصيل التحويل (رقم الحساب، الايبان الخ)

  isLocalOnly Boolean @default(true) // 💡 true = هذا الشخص تم إنشاؤه في النظام الفرعي ولا يرحل للرئيسي

  idNumber      String? // رقم الهوية أو الإقامة
  monthlySalary Float? // الراتب الشهري
  jobTitle      String? // المسمى الوظيفي

  // 👈 جميع العلاقات العكسية (لتسهيل استخراج كشف حساب/ملف للشخص)
  paymentsCollected PrivatePayment[] @relation("PaymentCollector")
  paymentsReceived  PrivatePayment[] @relation("PaymentReceiver")

  settlementsTarget   PrivateSettlement[] @relation("SettlementTarget")
  settlementsDelivred PrivateSettlement[] @relation("SettlementDeliverer")

  expensesPaid     OfficeExpense[]     @relation("ExpensePayer")
  expensesReceived OfficeExpense[]     @relation("ExpensePayee")
  assignedBrokers  TransactionBroker[] @relation("PersonBrokers")

  treasuryLogs TreasuryTransaction[] @relation("TreasuryPerson")

  disbursements Disbursement[] @relation("DisbursementBeneficiary")

  bankAccountsOpened BankAccount[]     @relation("AccountOpener")
  bankAccountsCtrl   BankAccount[]     @relation("AccountController")
  bankTransactions   BankTransaction[] @relation("BankTxPartner")

  officesResponsible CoopOffice[] @relation("OfficeResponsible")

  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  brokeredTransactions    PrivateTransaction[] @relation("TxBroker")
  agentTransactions       PrivateTransaction[] @relation("TxAgent")
  stakeholderTransactions PrivateTransaction[] @relation("TxStakeholder")
  receivedTransactions    PrivateTransaction[] @relation("TxReceiver")
  engBrokeredTransactions PrivateTransaction[] @relation("TxEngBroker")
  assignedTasks           TransactionTask[]    @relation("WorkerTasks")
}

model TransactionTask {
  id            String  @id @default(cuid())
  transactionId String
  workerId      String
  taskName      String?
  cost          Float?  @default(0)

  // 💡 1. الحقول الجديدة للمهام المتقدمة
  description   String?   @db.Text
  deadline      DateTime?
  isUrgent      Boolean   @default(false)
  isCompleted   Boolean   @default(false)
  submitComment String?   @db.Text
  submitFileUrl String?
  submittedAt   DateTime?
  assignedBy    String?   @default("مدير النظام")

  // 💡 2. الحقول القديمة (استرجعناها هنا حتى لا يتم حذف بياناتك المالية السابقة)
  isFinal         Boolean?  @default(false)
  isPaid          Boolean   @default(false)
  paidAmount      Float     @default(0)
  paymentCurrency String?   @default("SAR")
  paymentDate     DateTime? @db.Date

  createdAt DateTime @default(now())

  // العلاقات (Relations)
  transaction PrivateTransaction @relation(fields: [transactionId], references: [id])
  worker      Person             @relation("WorkerTasks", fields: [workerId], references: [id])
}

// 💡 3. أضف هذا النموذج الجديد (لأسعار الصرف)
model ExchangeRate {
  id          String   @id @default(cuid())
  currency    String   @unique // USD, EGP
  rate        Float // e.g., 0.266 for USD, 13.15 for EGP
  transferFee Float    @default(0) // رسوم التحويل الثابتة
  updatedAt   DateTime @updatedAt
}

// ===============================================
// جدول ربط الوسطاء بالمعاملات (لدعم وسطاء متعددين)
// ===============================================
model TransactionBroker {
  id            String   @id @default(cuid())
  transactionId String
  brokerId      String
  fees          Float    @default(0)
  createdAt     DateTime @default(now())

  transaction PrivateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  broker      Person             @relation("PersonBrokers", fields: [brokerId], references: [id])
}

// ===============================================
// إعدادات النظام الشاملة (System Settings)
// ===============================================
model SystemSettings {
  id Int @id @default(1)

  // إعدادات عامة
  companyName String? @default("مكتب ديتيلز للاستشارات الهندسية")
  taxNumber   String? @default("310000000000003")
  currency    String? @default("SAR")
  timezone    String? @default("Asia/Riyadh (UTC+3)")

  // إعدادات التأخير
  warningDays Int? @default(5)
  overdueDays Int? @default(10)

  // إعدادات التقدير الضريبي
  taxEstimateEnabled Boolean? @default(true)
  taxPercentage      Float?   @default(15)
  taxApplyTo         String?  @default("كل المبالغ البنكية")
  taxExclude         Json?    @default("[\"النقد\", \"الخزنة\", \"التحصيل غير المسلم للشركة\"]")
  taxNotes           String?  @db.Text

  // إعدادات حصة المكتب
  officeShareType       String?  @default("percentage")
  officeShareValue      Float?   @default(10)
  officeShareCategories Json?    @default("[{\"id\":1,\"label\":\"أقل من 50,000\",\"minProfit\":0,\"maxProfit\":50000,\"fixedAmount\":2000},{\"id\":2,\"label\":\"50,000 — 150,000\",\"minProfit\":50000,\"maxProfit\":150000,\"fixedAmount\":5000},{\"id\":3,\"label\":\"150,000 — 500,000\",\"minProfit\":150000,\"maxProfit\":500000,\"fixedAmount\":12000},{\"id\":4,\"label\":\"أكثر من 500,000\",\"minProfit\":500000,\"maxProfit\":999999999,\"fixedAmount\":25000}]")
  officeShareManual     Boolean? @default(false)
  officeShareManualVal  Float?   @default(0)

  // الحسابات الخاصة
  specialAccounts Json? @default("[{\"id\":1,\"systemName\":\"حسابات العبودي\",\"reportName\":\"العبودي\"},{\"id\":2,\"systemName\":\"حسابات إبراهيم الراجحي\",\"reportName\":\"إبراهيم الراجحي\"},{\"id\":3,\"systemName\":\"حسابات أحمد طلعت\",\"reportName\":\"أحمد طلعت\"},{\"id\":4,\"systemName\":\"حسابات محمد فؤاد\",\"reportName\":\"محمد فؤاد\"}]")

  updatedAt DateTime @updatedAt
}

model OutsourceSalary {
  id              String   @id @default(uuid())
  employeeId      String
  employeeName    String
  period          String
  startDate       String
  endDate         String
  daysCount       Int
  dailyRate       Float
  grossAmount     Float
  deductions      Float
  netAmount       Float
  roundedAmount   Float
  status          String // "paid", "partial", "unpaid"
  paidAmount      Float    @default(0)
  remainingAmount Float
  paymentType     String
  createdAt       DateTime @default(now())

  payments OutsourcePayment[]
}

model OutsourcePayment {
  id             String          @id @default(uuid())
  salaryRecordId String
  salary         OutsourceSalary @relation(fields: [salaryRecordId], references: [id])
  amount         Float
  paymentMethod  String
  paymentDate    String
  paymentTime    String
  currency       String
  notes          String?
  receiptUrl     String?
  isPartial      Boolean
  createdAt      DateTime        @default(now())
}

// ===============================================
// 💡 نظام التسجيل السريع (Quick Entries)
// ===============================================

model QuickEntry {
  id            String   @id @default(cuid())
  entryCode     String   @unique
  date          DateTime @db.Date
  time          String
  type          String
  description   String   @db.Text
  amount        Float?
  relatedPerson String?
  priority      String   @default("normal")
  attachments   String[]

  status String @default("pending")

  processedDetails Json?
  processedAt      DateTime?

  // 💡 التعديل هنا: استخدام نصوص بدلاً من علاقات لمنع أي مشاكل
  recordedBy  String  @default("موظف النظام")
  processedBy String?

  comments QuickEntryComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuickEntryComment {
  id   String @id @default(cuid())
  text String @db.Text

  entryId String
  entry   QuickEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  // 💡 التعديل هنا
  author String @default("مستخدم")

  createdAt DateTime @default(now())
}

// ===============================================
// 💡 إدارة المكاتب الوسيطة (Intermediary Offices)
// ===============================================

model IntermediaryOffice {
  id                 String   @id @default(cuid())
  code               String   @unique
  nameAr             String
  nameEn             String?
  commercialRegister String
  engineeringLicense String?
  vatNumber          String?
  vatStatus          String   @default("غير مسجل") // مسجل، غير مسجل
  nationalAddress    String?
  city               String
  region             String?
  email              String?
  phone              String?
  whatsapp           String?
  website            String?
  specializations    String[]
  internalNotes      String?  @db.Text

  status           String  @default("نشط") // نشط، موقوف، مجمد
  suspensionReason String? @db.Text
  relationshipType String  @default("وسيط") // وسيط، شريك، مكتب تابع

  contactPerson String?
  contactMobile String?

  receivableBalance   Float   @default(0)
  lastTransactionCode String? @default("-")
  lastTransactionDate String? @default("-")

  contacts          OfficeContact[]
  officialAssets    OfficeAsset[]
  intermediaryLinks IntermediaryLink[]

  // علاقة مع المعاملات (يجب أن يكون لديك حقل officeId في جدول PrivateTransaction)
  // transactions    PrivateTransaction[] 

  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  PrivateTransaction PrivateTransaction[]
}

model OfficeContact {
  id                 String  @id @default(cuid())
  name               String
  position           String?
  mobile             String
  email              String?
  notes              String? @db.Text
  isAuthorizedSigner Boolean @default(false)

  officeId String
  office   IntermediaryOffice @relation(fields: [officeId], references: [id], onDelete: Cascade)
}

model OfficeAsset {
  id           String  @id @default(cuid())
  type         String // logo, stamp, signature, etc.
  label        String
  fileName     String?
  fileType     String?
  content      String? @db.Text
  version      Int     @default(1)
  isActive     Boolean @default(true)
  approvedBy   String?
  approvedDate String?
  settings     Json?

  uploadedBy   String?
  uploadedAt   String?
  uploadedTime String?
  usageCount   Int     @default(0)

  officeId String
  office   IntermediaryOffice @relation(fields: [officeId], references: [id], onDelete: Cascade)
}

model IntermediaryLink {
  id               String  @id @default(cuid())
  intermediaryName String
  role             String
  commissionType   String  @default("percentage")
  commissionValue  Float   @default(0)
  isDefault        Boolean @default(false)

  officeId String
  office   IntermediaryOffice @relation(fields: [officeId], references: [id], onDelete: Cascade)
}

// ===============================================
// سجل الرخص المركزي (Permits Registry)
// ===============================================
model Permit {
  id           String  @id @default(cuid())
  permitNumber String
  year         Int
  type         String
  form         String
  ownerName    String
  idNumber     String?

  // 💡 [احترافي] تواريخ الرخصة
  issueDate  String? // تاريخ الإصدار
  expiryDate String? // تاريخ الانتهاء الهجري

  district          String?
  sector            String?
  plotNumber        String?
  planNumber        String?
  usage             String?
  landArea          Float?
  engineeringOffice String?
  source            String
  qrStatus          String  @default("غير متوفر")
  aiStatus          String  @default("غير مطبق")
  copies            Int     @default(1)
  notes             String  @default("")
  attachmentUrl     String?
  mainUsage         String?
  subUsage          String?
  detailedReport    String? @db.Text

  linkedTransactionId String?
  linkedOwnershipId   String?
  linkedClientId      String?
  linkedOfficeId      String?
  extraAttachments    String? @db.Text

  componentsData String? @db.Text
  boundariesData String? @db.Text

  archiveDate DateTime @default(now()) @db.Date
  updatedAt   DateTime @updatedAt
}

// ============================================================================
// 💡 11. نظام إدارة الوثائق والأرشفة المؤسسي (Enterprise DMS)
// ============================================================================

model TransactionFolder {
  id    String  @id @default(cuid())
  name  String
  color String? @default("#FDB022")
  icon  String? @default("📁")

  // 💡 [احترافي] إعدادات المجلد
  isSystemFolder Boolean @default(false) // لا يمكن حذفه أو تغيير اسمه
  isLocked       Boolean @default(false) // مقفل بكلمة مرور أو صلاحيات
  isDeleted      Boolean @default(false) // الحذف الآمن (Soft Delete)

  // 💡 [احترافي] التتبع
  createdBy String    @default("النظام")
  updatedBy String?
  deletedBy String?
  deletedAt DateTime?

  // العلاقات الهرمية
  parentId String?
  parent   TransactionFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children TransactionFolder[] @relation("FolderHierarchy")

  files TransactionFile[]

  // 💡 [احترافي] الربط المرن (يمكن ربط المجلد بأكثر من كيان)
  transactionId String?
  transaction   PrivateTransaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionId])
  @@index([parentId])
}

model TransactionFile {
  id           String @id @default(cuid())
  name         String // الاسم المعروض للمستخدم
  originalName String // الاسم الحقيقي وقت الرفع
  mimeType     String
  extension    String
  size         Int
  url          String

  // 💡 [احترافي] النزاهة والإصدارات
  fileHash       String? // بصمة الملف (MD5/SHA256) لمنع التكرار
  version        Int     @default(1) // رقم الإصدار
  isConfidential Boolean @default(false) // ملف سري (يتطلب صلاحية عليا)

  // 💡 [احترافي] الحذف الآمن
  isDeleted Boolean @default(false)

  // 💡 [احترافي] التتبع
  uploadedBy String // الموظف الذي رفع الملف
  updatedBy  String? // الموظف الذي غير اسمه
  deletedBy  String? // الموظف الذي حذفه
  deletedAt  DateTime?

  // 💡 [احترافي] البيانات الوصفية المرنة (Meta-data)
  tags            String[] // [فواتير, 2026, ضرائب]
  aiExtractedData Json? // بيانات استخرجها الذكاء الاصطناعي من الملف

  // العلاقات
  folderId String?
  folder   TransactionFolder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  transactionId String?
  transaction   PrivateTransaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  // 💡 سجل الحركات الخاص بهذا الملف تحديداً
  activityLogs FileActivityLog[]
  // 💡 الإصدارات القديمة من هذا الملف
  versions     FileVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionId])
  @@index([folderId])
}

// ============================================================================
// 💡 نظام الإصدارات (File Versioning) - للإحتفاظ بتاريخ الملفات المعدلة
// ============================================================================
model FileVersion {
  id     String          @id @default(cuid())
  fileId String
  file   TransactionFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  versionNumber Int
  url           String
  size          Int
  uploadedBy    String
  changeNotes   String? // سبب التعديل

  createdAt DateTime @default(now())

  @@index([fileId])
}

// ============================================================================
// 💡 سجل التدقيق للملفات (Audit Trail & Activity Logs) - تتبع كل همسة!
// ============================================================================
model FileActivityLog {
  id String @id @default(cuid())

  fileId String?
  file   TransactionFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)

  folderId String? // في حال كان الحدث على مجلد

  // نوع الحدث: UPLOAD, DOWNLOAD, VIEW, RENAME, DELETE, RESTORE, SHARE
  action String

  // من قام بالحدث؟
  performedBy String // معرف أو اسم الموظف

  // من أين؟
  ipAddress String? // رقم الـ IP للموظف (أمان)
  userAgent String? // المتصفح والجهاز المستخدم

  // ماذا تغير؟ (مثال: { "oldName": "x.pdf", "newName": "y.pdf" })
  details Json?

  createdAt DateTime @default(now())

  @@index([fileId])
  @@index([action])
  @@index([performedBy])
}

// ============================================================================
// 💡 إعدادات تصنيفات المجلدات
// ============================================================================
model FolderCategory {
  id         String   @id @default(cuid())
  name       String // اسم التصنيف (مثل: مرفقات، صكوك)
  code       String? // كود مكون من 3 أرقام (اختياري)
  icon       String // الرمز (Emoji)
  color      String // كود اللون (Hex)
  order      Int      @default(0) // ترتيب العرض
  subFolders String[] // قائمة بأسماء المجلدات الفرعية التلقائية

  // صلاحيات افتراضية لمن يمكنه رؤية هذا التصنيف
  allowedRoles String[] @default(["ALL"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 1. جدول النماذج الأساسية (القوالب / Templates)
// ==========================================
model FormTemplate {
  id          String  @id @default(uuid())
  code        String  @unique // الكود المرجعي للنموذج (مثال: FRM-HR-001)
  name        String // اسم النموذج (مثال: إخلاء طرف)
  description String? @db.Text
  version     String  @default("1.0")
  category    String // hr, financial, operations, general

  // إعدادات المظهر والطباعة
  colorMode    String  @default("color")
  numberFormat String  @default("english")
  timezone     String  @default("Asia/Riyadh")
  fontFamily   String  @default("Tajawal")
  fontSize     Int     @default(12)
  isPublic     Boolean @default(false)
  isActive     Boolean @default(true)

  // إعدادات الصفحة (Json للحفاظ على المرونة)
  pageSettings Json // يحتوي على: orientation, size, margins, header_height

  // الصور والخلفيات
  headerImage String?
  footerImage String?
  bgImage     String?

  borderSettings Json? // 👈 إضافة حقل الإطار
  watermark      Json? // 👈 إضافة حقل العلامة المائية

  // العلاقات (Relations)
  blocks FormBlock[] // الحقول المكونة للنموذج
  usages FormUsage[] // سجلات استخدام هذا النموذج

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 2. جدول حقول النموذج (البلوكات / Blocks)
// ==========================================
model FormBlock {
  id         String       @id @default(uuid())
  templateId String
  template   FormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  type  String // نوع الحقل (text, date, signature, employee_info, table...)
  label String // التسمية

  position Json // الإحداثيات والأبعاد (x, y, width, height)
  style    Json // المحاذاة والألوان

  // إعدادات التعبئة
  isEditable   Boolean @default(true) // هل يسمح للمستخدم بتعديله عند الاستخدام؟
  isRequired   Boolean @default(false) // هل هو إجباري؟
  dataSource   String  @default("manual") // مصدر البيانات (manual, auto_system, auto_employee)
  defaultValue String? @db.Text // النص الافتراضي أو رابط الصورة

  // إعدادات إضافية للجداول أو القوائم المعقدة
  config Json?

  order Int @default(0) // ترتيب الحقل
}

// ==========================================
// 3. جدول سجلات الاستخدام (النماذج المعبأة / Usages)
// ==========================================
model FormUsage {
  id         String       @id @default(uuid())
  templateId String
  template   FormTemplate @relation(fields: [templateId], references: [id])

  // السريال القانوني الفريد (سيتم توليده ديناميكياً)
  trackingSerial String @unique

  userId       String // معرف الموظف الذي قام بإنشاء/تعبئة النموذج
  targetUserId String? // إذا كان النموذج يخص موظف معين (مثل شهادة راتب لموظف آخر)

  status String @default("draft") // مسودة (draft)، مكتمل (completed)، مؤرشف (archived)

  // رابط ملف الـ PDF النهائي (بعد الاعتماد/الطباعة، يحفظ كملف ثابت لا يتغير)
  generatedPdfUrl String?

  // العلاقات
  values FormFieldValue[] // القيم التي تم إدخالها في هذا الاستخدام بالتحديد

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 4. جدول قيم الحقول (إجابات المستخدم / Field Values)
// ==========================================
model FormFieldValue {
  id      String    @id @default(uuid())
  usageId String
  usage   FormUsage @relation(fields: [usageId], references: [id], onDelete: Cascade)

  blockId String // يشير إلى الحقل في جدول FormBlock

  textValue String? @db.Text // للقيم النصية المباشرة
  jsonValue Json? // للجداول، أو البصمات، أو التواقيع المحفوظة كـ Base64
}

model SystemFolder {
  id       String  @id @default(uuid())
  name     String
  parentId String? // إذا كان null، فهو داخل مجلد النظام الثابت (مثل: sys-hr)

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false) // للحذف المنطقي (سلة المحذوفات)

  files SystemFile[]
}

model SystemFile {
  id           String @id @default(uuid())
  name         String
  originalName String
  extension    String
  size         Int
  url          String

  // 💡 الحقول الجديدة المطلوبة للنزاهة والإصدارات
  fileHash String? // بصمة الملف (MD5)
  version  Int     @default(1) // رقم الإصدار

  folderId String?
  folder   SystemFolder? @relation(fields: [folderId], references: [id])

  uploadedBy String?
  createdAt  DateTime  @default(now())
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?
  deletedBy  String?
}

model EmailAccount {
  id          String         @id @default(uuid())
  accountName String
  email       String         @unique
  imapServer  String         @default("imap.hostinger.com") // خادم هوستنقر للاستقبال
  imapPort    Int            @default(993)
  smtpServer  String         @default("smtp.hostinger.com") // خادم هوستنقر للإرسال
  smtpPort    Int            @default(465)
  username    String
  password    String // يُفضل تشفيرها في المشاريع الحقيقية
  useSSL      Boolean        @default(true)
  isActive    Boolean        @default(true)
  messages    EmailMessage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model EmailMessage {
  id              String       @id @default(uuid())
  messageId       String       @unique // المعرف الآتي من مزود البريد
  accountId       String
  account         EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  from            String
  to              String
  subject         String
  body            String       @db.Text
  date            DateTime
  isRead          Boolean      @default(false)
  isStarred       Boolean      @default(false)
  isArchived      Boolean      @default(false)
  isDeleted       Boolean      @default(false)
  isSent          Boolean      @default(false)
  hasAttachments  Boolean      @default(false)
  messageCategory String? // لتخزين تصنيف الذكاء الاصطناعي
  createdAt       DateTime     @default(now())
}

model Notification {
  id                String   @id @default(uuid())
  code              String   @unique
  category          String // عاجل، مالي، توثيق، نظام، معاملات
  subCategory       String? // فواتير متأخرة، تسويات جاهزة، إلخ
  relatedEntityCode String? // المرجع مثل INV-5678
  title             String
  description       String   @db.Text
  severity          String   @default("low") // high, medium, low
  timestamp         DateTime @default(now())
  createdByRule     String?
  isRead            Boolean  @default(false)
  assignedTo        String?
  amount            Float?
  daysOverdue       Int?
  attachmentMissing Boolean  @default(false)
  linkedScreen      Json? // لتخزين مسار الشاشة { screenCode, iconId, tabId }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TailscaleConfig {
  id        String   @id @default(uuid())
  tailnet   String? // اسم الشبكة (مثال: mydomain.github.beta.tailscale.net)
  apiKey    String? // مفتاح Tailscale (API Key)
  authKey   String? // مفتاح الـ Auth (لربط الأجهزة الجديدة تلقائياً) 👈 الحقل الجديد
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransactionSource {
  id        String   @id @default(uuid())
  name      String   @unique // الاسم يجب أن يكون غير مكرر
  isActive  Boolean  @default(true) // لإمكانية إخفاء المصدر دون حذفه نهائياً
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// نموذج تصنيفات الروابط
model LinkCategory {
  id        String      @id @default(uuid())
  name      String      @unique
  links     QuickLink[]
  createdAt DateTime    @default(now())
}

// نموذج الروابط السريعة
model QuickLink {
  id          String  @id @default(uuid())
  title       String
  url         String
  description String?

  // العلاقات
  categoryId String
  category   LinkCategory @relation(fields: [categoryId], references: [id])

  // الوصول والأمان
  accessLevel       String  @default("الكل") // الإدارة العليا، الموظفين، أخرى
  requiresLogin     Boolean @default(false)
  loginData         String? // يمكن حفظه كنص مشفر لاحقاً
  assignedEmployees String? // نص يحمل أسماء الموظفين مفصولين بفاصلة

  // الصلاحيات (التواريخ)
  validUntil  DateTime?
  loginExpiry DateTime?

  // بيانات إضافية
  customFields Json? // مصفوفة من {key, value}
  notes        String?
  usageCount   Int     @default(0)

  isPinned   Boolean @default(false)
  pinOrder   Int     @default(0) // 👈 حقل ترتيب التثبيت
  importance String  @default("عادي")

  // التتبع
  createdBy String   @default("مدير النظام")
  updatedBy String   @default("مدير النظام")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
