// server/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================================================
// 1. سياسات الدوام والإجازات (Time & Leave Policies)
// ==================================================

// 💡 الإجازات الرسمية للشركة (مثل: العيد، اليوم الوطني)
model PublicHoliday {
  id        String   @id @default(uuid())
  name      String // مثال: "إجازة عيد الفطر"
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  isPaid    Boolean  @default(true) // هل هي مدفوعة الأجر؟
  createdAt DateTime @default(now())
}

// 💡 أيام العمل الأسبوعية الافتراضية للشركة (لمنع احتساب الجمعة غياب)
model CompanyWorkingDays {
  id        String  @id @default("global_working_days")
  sunday    Boolean @default(true)
  monday    Boolean @default(true)
  tuesday   Boolean @default(true)
  wednesday Boolean @default(true)
  thursday  Boolean @default(true)
  friday    Boolean @default(false) // 👈 إجازة افتراضية
  saturday  Boolean @default(false) // 👈 إجازة افتراضية
}

// ------ نموذج الموظفين (شاشة 817) ------
model Employee {
  id           String @id @default(cuid())
  employeeCode String @unique @default(cuid())

  // 💡 [تعديل] يمكن إبقاء name للاستخدام السريع، ولكن تم إضافة نظام الاسم الرباعي
  name   String
  nameEn String?

  // 🚀 --- الإضافات الجديدة: نظام الاسم الرباعي ---
  firstNameAr  String?
  secondNameAr String?
  thirdNameAr  String?
  fourthNameAr String?
  firstNameEn  String?
  secondNameEn String?
  thirdNameEn  String?
  fourthNameEn String?

  // 🚀 --- الإضافات الجديدة: الصورة الشخصية والتحكم في العرض ---
  profilePicture         String?
  isPhotoVisible         Boolean @default(true)
  isAgeVisible           Boolean @default(true)
  isInternalTitleVisible Boolean @default(true)

  // 🚀 --- الإضافات الجديدة: البيانات الشخصية ---
  birthDate   DateTime? @db.Date
  nationality String?

  nationalId String @unique
  email      String @unique
  phone      String @unique

  // البيانات الوظيفية
  position        String // المسمى الداخلي
  qiwaPosition    String? // المسمى الرسمي حسب قوى
  department      String
  hireDate        DateTime // تاريخ الالتحاق (العقد)
  actualStartDate DateTime? @db.Date // 🚀 جديد: تاريخ المباشرة الفعلي

  baseSalary Float?
  jobLevel   Int?
  type       String @default("full-time")
  status     String @default("active")

  gosiNumber        String?
  iqamaNumber       String?
  performanceRating Float?
  frozenUntil       DateTime?
  frozenReason      String?
  password          String
  refreshToken      String?
  permissionsCount  Int? // عدد الصلاحيات المخصصة

  // 🚀 --- الإضافات الجديدة: تفاصيل العنوان الوطني ---
  shortAddress     String? // العنوان المختصر (مثال: RRRD2929)
  streetNameAr     String? // اسم الشارع
  streetNameEn     String?
  districtAr       String? // الحي
  districtEn       String?
  buildingNumber   String? // رقم المبنى
  unitNumber       String? // رقم الوحدة
  floorNumber      String? // رقم الدور
  postalCode       String? // الرمز البريدي
  additionalNumber String? // الرقم الإضافي
  cityAr           String? // المدينة
  cityEn           String?

  fingerprintId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- العلاقات الفرعية للموظف (كما هي بدون تغيير) ---
  attachments       Attachment[]            @relation("EmployeeAttachments")
  attendanceRecords EmployeeAttendance[]
  leaveRequests     EmployeeLeaveRequest[]
  skills            EmployeeSkill[]
  certifications    EmployeeCertification[]
  evaluations       EmployeeEvaluation[]
  promotions        EmployeePromotion[]

  // --- علاقات العمل والمهام ---
  roles              JobRole[]    @relation("EmployeeToJobRole")
  specialPermissions Permission[] @relation("EmployeeToSpecialPermission")
  managedProjects    Project[]
  assignedTasks      Task[]       @relation("EmployeeToTask")

  // --- المراسلات ---
  sentMessages  Message[]      @relation("SenderToMessage")
  conversations Conversation[] @relation("EmployeeToConversation")

  // --- النظام المالي والإداري ---
  uploadedAttachments Attachment[]
  paymentsReceived    Payment[]     @relation("EmployeeToPayment")
  activitiesPerformed ActivityLog[] @relation("EmployeeToActivityLog")

  shiftType String @default("FIXED")

  // للدوام الثابت (FIXED)
  shiftStartTime String? @default("08:00")
  shiftEndTime   String? @default("17:00")

  requiredDailyHours Float? @default(8.0)

  customWorkingDays Json?

  // --- إدارة الوثائق ---
  ownedDocuments         Document[]               @relation("OwnedDocuments")
  docPermissions         DocumentPermission[]     @relation("GrantedPermissions")
  documentActivities     DocumentActivity[]
  documentAccess         DocumentPermission[] // الصلاحيات الممنوحة للموظف
  createdClassifications DocumentClassification[] @relation("CreatedClassifications")

  // --- المعاملات ---
  transactionAssignments TransactionEmployee[]
  quotationTemplates     QuotationTemplate[]

  archivedProjects   ArchivedProject[]       @relation("EmployeeArchivedProjects")
  approvedProjects   ArchivedProject[]       @relation("ProjectApprover")
  SystemNotification SystemNotification[]
  AttendanceLog      AttendanceLog[]
  documentationLogs  DocumentationAuditLog[]
  payrolls           PayrollRecord[]

  jobOffer JobOffer? @relation("AcceptedJobOffer")

  // العروض الوظيفية التي قام هذا الموظف (موظف الموارد البشرية) بإنشائها
  createdJobOffers JobOffer[] @relation("CreatedJobOffers")

  documents            EmployeeDocument[]        @relation("EmployeeOwnedDocs")
  uploadedDocs         EmployeeDocument[]        @relation("EmployeeUploadedDocs")
  leaves               EmployeeLeave[]           @relation("EmployeeLeaves")
  contracts            EmployeeContract[]
  createdQuotations    Quotation[]               @relation("QuoteCreator")
  approvedQuotations   Quotation[]               @relation("QuoteApprover")
  firstPartyQuotations Quotation[]               @relation("QuoteFirstParty")
  quotationLogs        QuotationLog[]            @relation("QuotationLogsUser")
  uploadedArchives     PropertyDocumentArchive[] @relation("DocUploader")
  archiveLogs          ArchiveAuditLog[]
  cashVaultLogs        CashVaultAuditLog[]
}

// ==================================================
// 3. الإجازات الخاصة بالموظف (Employee Leaves)
// ==================================================
model EmployeeLeave {
  id         String   @id @default(uuid())
  employeeId String
  type       String // SICK, ANNUAL, UNPAID, EMERGENCY
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  reason     String?
  status     String   @default("APPROVED") // PENDING, APPROVED, REJECTED

  employee  Employee @relation("EmployeeLeaves", fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ==================================================
// 4. مركز مستندات الموظف المعزز بالذكاء الاصطناعي (AI Document Center)
// ==================================================
model EmployeeDocument {
  id         String  @id @default(cuid())
  fileName   String // اسم الملف الأصلي وقت الرفع
  customName String? // 🚀 الاسم المعرب (مثال: هوية وطنية)
  filePath   String // @unique تم إزالة الـ unique للسماح بتجديد نفس الملف إذا لزم الأمر
  fileType   String
  fileSize   Int
  notes      String? @db.Text
  category   String  @default("OTHER") // "CONTRACT", "ID_PASSPORT", "CERTIFICATE", "OTHER"

  // 🚀 حقول التواريخ والحالة الجديدة
  issueDate   DateTime? @db.Date
  expiryDate  DateTime? @db.Date
  isPermanent Boolean   @default(false)
  status      String    @default("ACTIVE") // ACTIVE: ساري, ARCHIVED: مؤرشف/مجدد

  // 🚀 حقول التجديد (لربط المستند الجديد بالقديم)
  parentDocId String?
  parentDoc   EmployeeDocument?  @relation("DocumentRenewals", fields: [parentDocId], references: [id])
  renewals    EmployeeDocument[] @relation("DocumentRenewals")

  createdAt DateTime @default(now())

  // الموظف صاحب المستند (الذي يُرفع المستند في ملفه)
  employeeId String
  employee   Employee @relation("EmployeeOwnedDocs", fields: [employeeId], references: [id], onDelete: Cascade)

  // الموظف/المدير الذي قام بعملية الرفع
  uploadedById String
  uploadedBy   Employee @relation("EmployeeUploadedDocs", fields: [uploadedById], references: [id])
}

// نموذج لسجل الحضور
model EmployeeAttendance {
  id       String    @id @default(cuid())
  date     DateTime  @db.Date
  status   String // (Present, Absent, On Leave)
  checkIn  DateTime? @db.Time
  checkOut DateTime? @db.Time
  notes    String?

  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String

  @@index([employeeId, date])
}

// نموذج لطلبات الإجازات
model EmployeeLeaveRequest {
  id        String   @id @default(cuid())
  type      String // (سنوية, مرضية, ...)
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  status    String   @default("Pending") // (Pending, Approved, Rejected)
  reason    String?

  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String

  @@index([employeeId])
}

// نموذج لمهارات الموظف
model EmployeeSkill {
  id       String @id @default(cuid())
  category String // (فنية, إدارية, لغات)
  skill    String // (AutoCAD, React, إدارة مشاريع)
  level    String // (مبتدئ, متوسط, خبير)

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  @@index([employeeId])
}

// نموذج لشهادات الموظف
model EmployeeCertification {
  id         String    @id @default(cuid())
  name       String // (PMP, شهادة AWS)
  authority  String // (PMI, Amazon)
  issueDate  DateTime  @db.Date
  expiryDate DateTime? @db.Date

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  @@index([employeeId])
}

// نموذج لتقييمات الموظف
model EmployeeEvaluation {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  evaluator String // (اسم المُقيّم أو الإدارة)
  rating    Float // (التقييم من 5)
  comments  String?

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  @@index([employeeId, date])
}

// نموذج لترقيات الموظف
model EmployeePromotion {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  oldPosition String
  newPosition String
  oldLevel    Int
  newLevel    Int
  notes       String?

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  @@index([employeeId, date])
}

// ==========================================
// 1. نموذج عقود الموظفين الرسمية (قوى، أجير، عن بعد)
// ==========================================
model EmployeeContract {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  contractType String // (عقد عمل، أجير، عمل عن بعد، اتفاقية تدريب)
  source       String // (منصة قوى، منصة أجير، داخلي)

  startDate   DateTime? @db.Date
  endDate     DateTime? @db.Date
  isActive    Boolean   @default(true)
  isRenewable Boolean   @default(true)
  autoRenew   Boolean   @default(false)

  firstPartyName  String?
  firstPartyRep   String?
  secondPartyName String?

  fileUrl         String  @db.Text
  aiExtractedData Json? // بيانات الذكاء الاصطناعي الخام
  notes           String? @db.Text

  uploadedById String?
  uploadedAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==========================================
// 2. تحديث نموذج العروض الوظيفية الشامل
// ==========================================
model JobOffer {
  id          String  @id @default(uuid())
  offerNumber String? @unique @default(uuid()) // أضفنا ?

  // 1. بيانات العرض الأساسية
  offerType          String    @default("NEW") // جديد، معدل، بديل، داخلي
  language           String    @default("AR")
  detailLevel        String    @default("DETAILED")
  templateId         String?
  branch             String?
  status             String    @default("DRAFT") // مسودة، تحت المراجعة، مرسل، مقبول، الخ
  requiresSuperApp   Boolean   @default(true)
  requiresGmApp      Boolean   @default(false)
  requiresFinApp     Boolean   @default(false)
  isConvertibleToEmp Boolean   @default(true)
  creationReason     String?   @db.Text
  internalNotes      String?   @db.Text
  validityDays       Int       @default(14)
  issueDate          DateTime  @default(now())
  expiryDate         DateTime?

  // 2. بيانات المرشح
  candidateNameAr String  @default("غير محدد")
  candidateNameEn String?
  identityType    String  @default("NATIONAL_ID")
  idNumber        String?
  nationality     String?
  candidatePhone  String
  candidateEmail  String
  candidateCity   String?
  candidateStatus String  @default("NEW_CANDIDATE")
  candidateSource String? // لينكدإن، إحالة، الخ
  validationFlags Json? // { idChecked: true, degreeChecked: false }

  // 3. المرفقات وتحليل الـ CV
  cvFileUrl        String?
  aiCvAnalysis     Json? // نقاط القوة، النقص، التوصيات
  otherAttachments Json? // مصفوفة مسارات المرفقات الأخرى

  // 4. بيانات الوظيفة
  jobTitleAr         String    @default("غير محدد")
  jobTitleEn         String?
  department         String?
  directManager      String?
  workLocation       String? // مقر، هجين، عن بعد
  shiftType          String? // كامل، جزئي، تدريب
  expectedStartDate  DateTime? @db.Date
  finalStartDate     DateTime? @db.Date
  probationDays      Int       @default(90)
  workingDaysPerWeek Int       @default(5)
  workingHoursPerDay Int       @default(8)
  requiredTools      Json? // { laptop: true, car: false, drivingLicense: true }

  // 5. الوصف الوظيفي والمهام
  jobDescription String? @db.Text
  jobTasks       Json? // مصفوفة المهام ومؤشرات الأداء

  // 6. العرض المالي
  basicSalary        Float
  housingAllowance   Float   @default(0)
  transportAllowance Float   @default(0)
  otherAllowances    Json? // { telecom: 200, nature: 500 }
  totalSalary        Float   @default(0)
  currency           String  @default("SAR")
  medicalInsurance   String? // فئة A, B, C
  tickets            String? // تذكرة سنوية
  financialNotes     String? @db.Text

  // 7. الشروط والنظام
  conditions String? @db.Text

  // 8. المستندات المطلوبة قبل المباشرة
  requiredDocs Json? // مصفوفة المستندات { name: "الهوية", required: true }

  // 9. الإرسال والقبول
  sendingDetails    Json? // { method: "EMAIL", date: "...", sentBy: "..." }
  acceptanceDetails Json? // { method: "MANUAL", date: "...", acceptedBy: "...", fileUrl: "..." }
  isFinalAccepted   Boolean @default(false)
  isConvertedToEmp  Boolean @default(false)

  // 10. الاعتمادات
  supervisorId     String?
  supervisorStatus String  @default("PENDING")
  supervisorNotes  String? @db.Text
  gmStatus         String?

  // 11. إعدادات الإخراج
  previewSettings Json? // { showCover: true, showQR: true, showTasks: "SHORT" }

  // التتبع والإصدارات
  version       Int     @default(1)
  parentOfferId String? // إذا كان عرض معدل من عرض سابق

  createdById String
  createdBy   Employee @relation("CreatedJobOffers", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // الربط بالموظف عند القبول
  employeeId     String?   @unique
  employeeAsUser Employee? @relation("AcceptedJobOffer", fields: [employeeId], references: [id])
}

enum PayrollSource {
  SYSTEM
  MUDAD
}

enum ApprovalStatus {
  PENDING // مسودة (عند الموارد البشرية)
  UNDER_REVIEW // بانتظار اعتماد المشرف
  APPROVED // معتمد
  RETURNED // مُرجع للتعديل
  REJECTED // مرفوض نهائياً
  PAID // مدفوع (من مدد)
}

model PayrollRecord {
  id             String         @id @default(uuid())
  employeeId     String
  month          String // e.g., "2026-05"
  baseSalary     Float          @default(0)
  housingAllow   Float          @default(0)
  transportAllow Float          @default(0)
  deductions     Float          @default(0)
  netSalary      Float          @default(0)
  source         PayrollSource  @default(SYSTEM) // <--- الحقل الجديد
  status         ApprovalStatus @default(PENDING)
  supervisorNote String?        @db.Text // ملاحظات المشرف عند الاعتماد/الرفض/الإرجاع

  employee  Employee @relation(fields: [employeeId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, month])
}

// ------ نموذج الأدوار الوظيفية (شاشة 903) ------
model JobRole {
  id               String   @id @default(cuid())
  code             String   @unique
  nameAr           String
  nameEn           String?
  description      String?
  responsibilities String[]
  level            String?
  department       String?
  status           String   @default("active")
  canAssignTasks   Boolean  @default(true)
  allowMultiple    Boolean  @default(true)
  allowMultiRole   Boolean  @default(true)
  order            Int?

  createdDate  DateTime @default(now())
  lastModified DateTime @updatedAt
  modifiedBy   String?

  parentRole   JobRole?  @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  parentRoleId String?
  childRoles   JobRole[] @relation("RoleHierarchy")

  employees   Employee[]   @relation("EmployeeToJobRole")
  permissions Permission[] @relation("JobRoleToPermission")
}

// ------ نموذج الصلاحيات (شاشة 902) ------
model Permission {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  level       String
  screenId    String?
  screenName  String?
  tabId       String?
  tabName     String?
  actionType  String?
  status      String  @default("active")

  parentId String?
  parent   Permission?  @relation("PermissionHierarchy", fields: [parentId], references: [id])
  children Permission[] @relation("PermissionHierarchy")

  frozenType   String?
  frozenDate   DateTime?
  frozenUntil  DateTime?
  frozenBy     String?
  frozenReason String?

  createdDate  DateTime @default(now())
  lastModified DateTime @updatedAt
  modifiedBy   String?

  roles     JobRole[]         @relation("JobRoleToPermission")
  employees Employee[]        @relation("EmployeeToSpecialPermission")
  groups    PermissionGroup[] @relation("GroupToPermission")
}

// ------ نموذج مجموعات الصلاحيات ------
model PermissionGroup {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  type String @default("sub_module") // لتحديد ما إذا كان "module" أو "sub_module"

  // 1. العلاقات الذاتية لبناء الشجرة (Self-Relation)
  parentId String? // معرف الجروب الأب (إن وجد)
  parent   PermissionGroup?  @relation("GroupHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children PermissionGroup[] @relation("GroupHierarchy")

  permissions Permission[] @relation("GroupToPermission")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

// ===============================================
// 2. نموذج العملاء (Client Module) - محدث ليدعم WMS
// ===============================================

// ------ نموذج العميل (شاشة 300) ------
model Client {
  id         String @id @default(cuid())
  clientCode String @unique

  // --- بيانات الاتصال الأساسية ---
  mobile   String
  email    String? @unique
  idNumber String  @unique // الهوية الوطنية / السجل / رقم الوقف

  // --- بيانات JSON للمرونة ---
  name           Json // { ar: "...", en: "...", details: {...} }
  contact        Json
  address        Json?
  identification Json // (تحتوي على العمر، مكان الميلاد، التاريخ الهجري والميلادي)
  representative Json? // (بيانات الوكيل/الناظر/المفوض)
  heirs          Json? // 👈 1. الإضافة الجديدة: مصفوفة بيانات الورثة 

  // --- حقول WMS الصريحة (للسرعة والفلترة) ---
  officialNameAr String? @map("official_name_ar")
  riskTier       String  @default("LOW")
  profilePicture String? // 👈 2. الإضافة الجديدة: مسار صورة العميل / شعار الوقف أو الشركة

  // --- التفاصيل ---
  type                 String // (فرد، شركة، جهة حكومية، ورثة، وقف، مكتب هندسي)
  category             String?
  nationality          String?
  occupation           String?
  company              String?
  taxNumber            String?
  rating               Int?    @default(3)
  secretRating         Int?    @default(50)
  grade                String? // (أ, ب, ج)
  gradeScore           Int?
  completionPercentage Float?
  isActive             Boolean @default(true)
  notes                String?
  createdBy            String?

  districtId   String?
  districtNode RiyadhDistrict? @relation(fields: [districtId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- العلاقات ---
  ownerships            OwnershipFile[]
  transactions          Transaction[]
  contracts             Contract[]
  attachments           Attachment[]
  activityLogs          ActivityLog[]
  documents             Document[]
  // داخل model Client
  privateTransactions   PrivateTransaction[]      @relation("ClientPrivateTransactions")
  TransactionFolder     TransactionFolder[]
  transactionOwnerships TransactionOwner[]
  OfficeTask            OfficeTask[]
  archivedProjects      ArchivedProject[]
  technicalReports      TechnicalReport[]
  quotations            Quotation[]               @relation("ClientQuotations")
  archivedDocuments     PropertyDocumentArchive[]
}

model ClientClassification {
  id          String  @id @default(cuid())
  name        String  @unique
  color       String
  description String?
  isActive    Boolean @default(true)
}

// ===============================================
// 3. نموذج الملكيات (Ownership / Deeds Module)
// ===============================================

model OwnershipFile {
  id   String @id @default(cuid())
  code String @unique // كود مرجعي للنظام OWN-2026-xxx

  // --- تفاصيل الصك (Deed Details) ---
  deedNumber       String?
  deedDate         DateTime? @db.Date
  issuingAuthority String? // الجهة المصدرة (كتابة العدل الأولى بالرياض مثلاً)
  status           String    @default("Active") // Active, Sold, Mortgage

  // --- البيانات المكانية (Spatial Data) ---
  city        String?
  district    String?
  planNumber  String? // رقم المخطط
  blockNumber String? // رقم البلوك (تمت إضافته)
  plotNumber  String? // رقم القطعة
  area        Float? // المساحة بالمتر المربع

  districtId   String?
  districtNode RiyadhDistrict? @relation(fields: [districtId], references: [id])

  // --- إحداثيات (لخرائط جوجل أو GIS) ---
  centerLat Float?
  centerLng Float?

  contracts Contract[]

  notes String?

  documents   Json? @default("[]") // الوثائق
  plots       Json? @default("[]") // القطع
  owners      Json? @default("[]") // الملاك والحصص
  boundaries  Json? @default("[]") // الحدود والأطوال
  aiData      Json? // بيانات الذكاء الاصطناعي المستخرجة
  attachments Json? @default("[]") // المرفقات

  // --- العلاقات ---
  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  transactions Transaction[] // المعاملات المرتبطة بهذا الصك

  aiLogs AIAnalysisLog[] // سجل عمليات التحليل لهذا الصك

  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  OfficeTask        OfficeTask[]
  technicalReports  TechnicalReport[]
  quotations        Quotation[]               @relation("OwnershipQuotations")
  archivedDocuments PropertyDocumentArchive[]

  @@index([deedNumber])
  @@index([district])
  @@index([clientId])
  @@index([districtId])
}

// ===============================================
// *. نموذج جديد: سجل تحليل الذكاء الاصطناعي
// ===============================================

model AIAnalysisLog {
  id String @id @default(cuid())

  fileName String // اسم الملف المرفوع
  filePath String // مسار الملف
  fileSize Int

  status          String // Success, Failed
  confidenceScore Float? // نسبة الدقة (0-100)

  extractedData Json // البيانات الخام المستخرجة (Raw JSON)

  // هل تم اعتماد هذه البيانات وإنشاء صك بها؟
  isApproved Boolean @default(false)

  // ربط اختياري بالصك الذي تم إنشاؤه
  ownershipId String?
  ownership   OwnershipFile? @relation(fields: [ownershipId], references: [id])

  performedBy String? // معرف الموظف الذي قام بالعملية
  createdAt   DateTime @default(now())
}

// ===============================================
// 4. نموذج المعاملات والمشاريع (Core Business Logic)
// ===============================================

// ------ نموذج المشروع ------
model Project {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  description String?
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  manager   Employee? @relation(fields: [managerId], references: [id])
  managerId String?

  transactions Transaction[]
}

// ------ نموذج المعاملة (قلب النظام) ------
model Transaction {
  id              String @id @default(cuid())
  transactionCode String @unique
  title           String

  // --- النوع والقالب ---
  transactionType   TransactionType? @relation(fields: [transactionTypeId], references: [id])
  transactionTypeId String?

  // --- البيانات الأساسية ---
  status                String  @default("Draft")
  statusColor           String? @default("#6b7280")
  priority              String? @default("متوسط")
  description           String?
  location              String?
  deedNumber            String? // يمكن استبداله بالربط مع OwnershipFile
  projectClassification String?

  // --- بيانات التتبع والتقدم ---
  category   String?
  complexity String?
  duration   Int?
  progress   Float?  @default(0)

  // --- البيانات المالية ---
  totalFees       Float? @default(0)
  paidAmount      Float? @default(0)
  remainingAmount Float? @default(0)
  fees            Json?

  // --- التفاصيل الفنية (JSON) ---
  floors               Json? @default("[]")
  setbacks             Json? @default("[]")
  components           Json? @default("[]")
  componentsOldLicense Json? @default("[]")
  componentsProposed   Json? @default("[]")
  componentsExisting   Json? @default("[]")
  boundaries           Json? @default("[]")
  landArea             Json? @default("{}")

  authorities     String[]
  stages          Json?
  warnings        String[]
  notes           Json?    @default("{}")
  approvals       Json?    @default("{}")
  requestPurposes Json?

  // --- العلاقات ---
  client   Client @relation(fields: [clientId], references: [id])
  clientId String

  // علاقة جديدة مع الحي (التقسيم الإداري)
  districtId   String?
  districtNode RiyadhDistrict? @relation(fields: [districtId], references: [id])

  // علاقة جديدة مع الملكية (شاشة 310)
  ownership   OwnershipFile? @relation(fields: [ownershipId], references: [id])
  ownershipId String?

  project   Project? @relation(fields: [projectId], references: [id])
  projectId Int?

  contract   Contract? @relation(fields: [contractId], references: [id])
  contractId String?

  // --- المرفقات والمهام والموظفين ---
  attachments          Attachment[]
  payments             Payment[]
  tasks                Task[]
  documents            Document[]
  appointments         Appointment[]
  transactionEmployees TransactionEmployee[]
  followUpTasks        FollowUpTask[]

  // --- تواريخ ---
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedDate DateTime?
}

// ------ نوع المعاملة (Configuration) ------
model TransactionType {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String  @unique
  description String?
  isActive    Boolean @default(true)

  // تفاصيل الإعدادات
  category      String?
  categoryAr    String?
  duration      Int?    @default(0)
  estimatedCost Float?  @default(0)
  complexity    String?

  defaultCosts Json?
  // القيم الافتراضية
  tasks        Json?
  documents    String[]
  authorities  String[]
  fees         Json?
  stages       Json?
  warnings     String[]
  notes        String[]

  transactions Transaction[]
  quotations   Quotation[]
}

// ------ سجل الموظفين العاملين على المعاملة ------
model TransactionEmployee {
  id String @id @default(cuid())

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String

  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String

  role String // الدور في المعاملة (مهندس مصمم، مراجع، etc)

  createdAt DateTime @default(now())

  @@unique([transactionId, employeeId])
  @@index([transactionId])
  @@index([employeeId])
}

// ===============================================
// 5. النماذج الديناميكية (Dynamic Forms)
// ===============================================

model RequestPurpose {
  id          String  @id @default(cuid())
  type        String // 'brief' أو 'detailed'
  name        String
  nameEn      String
  description String?
  icon        String?
  color       String?
  isActive    Boolean @default(true)

  dynamicForm DynamicFormDefinition?

  @@unique([type, name])
}

model DynamicFormDefinition {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  purpose   RequestPurpose @relation(fields: [purposeId], references: [id], onDelete: Cascade)
  purposeId String         @unique

  fields DynamicFormField[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DynamicFormField {
  id        String @id @default(cuid())
  label     String
  fieldKey  String
  fieldType String
  order     Int    @default(0)

  optionsJson    Json?
  validationJson Json?
  placeholder    String?

  form   DynamicFormDefinition @relation(fields: [formId], references: [id], onDelete: Cascade)
  formId String

  @@unique([formId, fieldKey])
  @@index([formId])
}

// ===============================================
// 6. المهام والمواعيد (Task & Appointment Management)
// ===============================================

model Task {
  id          String    @id @default(cuid())
  taskNumber  String?   @unique
  title       String
  description String?
  status      String    @default("Pending")
  dueDate     DateTime?

  priority         String?   @default("medium")
  progress         Int?      @default(0)
  category         String?
  assignedById     String?
  receivedDate     DateTime?
  completedDate    DateTime?
  attachmentsCount Int?      @default(0)
  commentsCount    Int?      @default(0)
  fees             Json?

  createdAt DateTime @default(now())

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String

  assignedTo   Employee? @relation("EmployeeToTask", fields: [assignedToId], references: [id])
  assignedToId String?

  @@index([assignedToId])
  @@index([transactionId])
}

model Appointment {
  id       String   @id @default(cuid())
  title    String
  date     DateTime
  type     String
  status   String   @default("scheduled")
  notes    String?
  location String?

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionId])
}

// ===============================================
// نموذج قوالب العقود (Contract Templates)
// ===============================================
model ContractTemplate {
  id          String  @id @default(cuid())
  title       String // اسم القالب (مثال: عقد فرد — خدمات هندسية)
  description String? // وصف القالب
  clientType  String // نوع العميل المستهدف (فرد، شركة، جهة حكومية)
  serviceType String // نوع الخدمة (رخصة بناء، إشراف، إلخ)

  hasRep    Boolean @default(false) // هل يدعم وجود ممثل/وكيل؟
  isProxy   Boolean @default(false) // هل يدعم نيابة عن مكتب آخر؟
  isDefault Boolean @default(false) // هل هذا القالب هو الافتراضي؟

  sections  Int @default(1) // عدد أقسام العقد
  usesCount Int @default(0) // عدد مرات استخدام هذا القالب

  clauses Json? @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts Contract[]
}

// ===============================================
// 7. المالية والعقود (Finance & Contracts)
// ===============================================

model Contract {
  id           String   @id @default(cuid())
  contractCode String   @unique
  title        String
  startDate    DateTime
  endDate      DateTime
  totalValue   Float
  status       String   @default("Active")

  client   Client @relation(fields: [clientId], references: [id])
  clientId String

  // 👈 الإضافات الجديدة لحفظ تفاصيل العقد
  ownershipId String?
  ownership   OwnershipFile? @relation(fields: [ownershipId], references: [id])

  templateId String?
  template   ContractTemplate? @relation(fields: [templateId], references: [id])

  clauses Json? @default("[]") // حفظ نسخة من بنود العقد وقت إنشائه

  transactions Transaction[]
  quotation    Quotation?    @relation(fields: [quotationId], references: [id])
  quotationId  String?       @unique
  attachments  Attachment[]
}

// --- Enums الخاصة بعروض الأسعار ---
enum TemplateType {
  SUMMARY
  DETAILED
}

enum QuotationStatus {
  DRAFT
  PENDING_APPROVAL
  NEEDS_MODIFICATION
  APPROVED
  SENT
  ACCEPTED
  PARTIALLY_PAID
  REJECTED
  TRASHED
  EXPIRED
  CANCELLED // 👈 تم إضافة (ملغى)
  REFUND_IN_PROGRESS // 👈 تم إضافة (استرجاع جارٍ)
  REFUNDED // 👈 تم إضافة (مسترد بالكامل)
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum ClientTitle {
  MR
  MRS
  SIR_COMPANY
  SIR_ENTITY
  SIR_WAQF
  PRINCE
  PRINCESS
  ROYAL_PRINCE
  ROYAL_PRINCESS
  CUSTOM
}

enum HandlingMethod {
  DIRECT
  AUTHORIZED
  AGENT
}

// ==================================================
// 1. سجل تتبع عروض الأسعار (Audit Log)
// ==================================================
model QuotationLog {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  action     String // "CREATE", "SUBMIT", "APPROVE", etc.
  fromStatus QuotationStatus?
  toStatus   QuotationStatus

  // 🔗 الترابط مع الموظف الذي قام بالإجراء
  userId   String
  user     Employee @relation("QuotationLogsUser", fields: [userId], references: [id])
  userName String?
  notes    String?  @db.Text

  createdAt DateTime @default(now())
}

// ==================================================
// 2. النموذج الرئيسي لعرض السعر (Quotation)
// ==================================================
model Quotation {
  id      String  @id @default(cuid())
  number  String  @unique // QT-26-02-0012
  subject String? // حقل الموضوع
  address String? // حقل العنوان

  // 🔗 1. علاقات العملاء والمكاتب
  clientId String?
  client   Client? @relation("ClientQuotations", fields: [clientId], references: [id])

  officeId String? // إذا كان العرض موجهاً لمكتب وسيط بدلاً من عميل مباشر
  office   IntermediaryOffice? @relation("OfficeQuotations", fields: [officeId], references: [id])

  // 🔗 2. علاقات الأملاك والمعاملات
  ownershipId String?
  ownership   OwnershipFile? @relation("OwnershipQuotations", fields: [ownershipId], references: [id])

  transactionId String?
  transaction   PrivateTransaction? @relation("TransactionQuotations", fields: [transactionId], references: [id], onDelete: Cascade)

  meetingMinuteId String?
  meetingMinute   MeetingMinute? @relation("MeetingMinuteQuotations", fields: [meetingMinuteId], references: [id])

  // 🔗 3. علاقات الموظفين (الموارد البشرية)
  createdById String?
  creator     Employee? @relation("QuoteCreator", fields: [createdById], references: [id])

  approvedById String?
  approvedBy   Employee? @relation("QuoteApprover", fields: [approvedById], references: [id])

  firstPartyEmployeeId String?
  firstPartyEmployee   Employee? @relation("QuoteFirstParty", fields: [firstPartyEmployeeId], references: [id])

  // البيانات الأساسية
  issueDate    DateTime @default(now())
  validityDays Int      @default(30)
  expiryDate   DateTime
  isRenewable  Boolean  @default(false)

  // التشفير والأمان
  stampType         StampType @default(NONE)
  qrVerificationUrl String?   @db.Text
  barcodeData       String?
  securityHash      String?   @db.Text

  // 🔗 4. إدارة الإصدارات (العلاقة الذاتية لعروض السعر التكميلية أو المعدلة)
  revisionNumber    Int         @default(1)
  quotationCategory String      @default("ORIGINAL")
  parentQuotationId String?
  parentQuotation   Quotation?  @relation("QuotationRevisions", fields: [parentQuotationId], references: [id])
  childQuotations   Quotation[] @relation("QuotationRevisions")

  // نموذج العرض
  templateType     TemplateType @default(SUMMARY)
  templateId       String?
  showClientCode   Boolean      @default(true)
  showPropertyCode Boolean      @default(true)

  // بيانات الخدمة
  transactionTypeId String?
  transactionType   TransactionType? @relation(fields: [transactionTypeId], references: [id])
  serviceNumber     String?
  serviceYear       String?
  licenseNumber     String?
  licenseYear       String?

  // حقول الاعتمادات والأختام
  isStamped Boolean   @default(false)
  stampedAt DateTime?
  stampedBy String?

  isSigned      Boolean   @default(false)
  signedAt      DateTime?
  signatureHash String?

  // البنود والتسعير
  items            QuotationItem[]
  subtotal         Float           @default(0)
  taxRate          Float           @default(0.15)
  officeTaxBearing Int             @default(0)
  taxAmount        Float           @default(0)
  total            Float           @default(0)
  collectedAmount  Float           @default(0)
  currency         String          @default("SAR")

  // 🔗 5. الدفعات والمرفقات وسجل التتبع
  payments    QuotationPayment[]
  attachments Attachment[]       @relation("QuotationAttachments")
  logs        QuotationLog[] // السجل التاريخي للإجراءات

  acceptedMethods      Json?
  selectedBankAccounts Json? @default("[]")

  missingDocs     String? @db.Text
  showMissingDocs Boolean @default(false)

  // الشروط
  terms          String? @db.Text
  conclusion     String? @db.Text
  notes          String? @db.Text
  // ----------------------------------------------------
  // التعديل 1: تحويل الـ Enums إلى نصوص لتقبل القيم المخصصة
  // ----------------------------------------------------
  clientTitle    String? @default("MR") // تم التعديل إلى String
  handlingMethod String? @default("DIRECT") // تم التعديل إلى String

  // ----------------------------------------------------
  // التعديل 2: حقول إخفاء/إظهار مفقودة
  // ----------------------------------------------------
  showSummaryTable Boolean @default(true) // حقل إظهار جدول الخلاصة العلوي

  // ----------------------------------------------------
  // التعديل 3: حقول لحفظ الأسماء التي تُعدل يدوياً في المعاينة
  // ----------------------------------------------------
  secondPartyName String? // حفظ اسم العميل إذا تم تعديله يدوياً
  secondPartyRep  String? // حفظ اسم ممثل العميل إذا تم تعديله يدوياً
  firstPartyRep   String? // حفظ اسم ممثل المكتب إذا تم تعديله يدوياً

  // حقول التمثيل النظامي الإضافية
  authDocIssueDate      DateTime?
  showAuthDocIssueDate  Boolean?  @default(false)
  authDocExpiryDate     DateTime?
  showAuthDocExpiryDate Boolean?  @default(false)
  customUsufructType    String?

  // حقول الطرف الأول (المكتب)
  firstPartyRepCapacity   String?
  showFirstPartyEmpId     Boolean? @default(true)
  firstPartySignatureType String?  @default("MANUAL")

  // الحالة
  status QuotationStatus @default(DRAFT)

  // 🔗 6. العلاقة مع العقد
  contract Contract? // العلاقة موجودة مسبقاً من جهة العقد

  clientType          String?
  signatureMethod     String?
  repName             String?
  repIdNumber         String?
  repPhone            String?
  repCapacity         String?
  authDocType         String?
  authDocNumber       String?
  authDocDate         DateTime?
  authDocIssuer       String?
  isAuthDocAttached   Boolean   @default(false)
  pdfUrl              String?   @db.Text
  transactionTypeName String? // عمود جديد لحفظ اسم المعاملة المكتوب يدوياً
  documentTitle       String?

  bgType     String? @default("official1")
  fontFamily String? @default("Tajawal")

  showTimeline      Boolean   @default(true)
  totalDuration     Int       @default(20)
  durationUnit      String    @default("WORKING_DAY") // WORKING_DAY, CALENDAR_DAY, WEEK, MONTH
  startConditions   Json?     @default("[\"DOCUMENTS_RECEIVED\"]") // مصفوفة بالشروط المختارة
  customStartDate   DateTime?
  showEndDate       Boolean   @default(false)
  showTimelineNotes Boolean   @default(true)
  timelineNotes     String?   @db.Text // النص الافتراضي للملاحظات السفلية

  qrCodeData String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  order       Int
  title       String
  description String?
  category    String?

  quantity     Float        @default(1)
  unit         String       @default("خدمة")
  unitPrice    Float
  discount     Float        @default(0)
  discountType DiscountType @default(PERCENTAGE)

  executionDuration Int? // مدة تنفيذ هذه الخدمة المحددة
  durationUnit      String? // وحدة المدة إن اختلفت
  timelineNotes     String? // ملاحظات تنفيذية خاصة بالبند (تظهر في الجدول)
  showInTimeline    Boolean @default(true) // هل تظهر في جدول العرض أم داخلية

  subtotal Float

  taxRate   Float @default(0.15) // نسبة الضريبة (0.15 أو 0)
  taxAmount Float @default(0) // قيمة الضريبة لهذا البند

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuotationPayment {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  installmentNumber Int
  percentage        Float
  amount            Float
  dueCondition      String

  createdAt DateTime @default(now())
}

model QuotationTemplate {
  id          String       @id @default(cuid())
  code        String       @unique // TPL-001
  title       String
  description String?      @db.Text
  type        TemplateType @default(SUMMARY)

  // هل هو النموذج الافتراضي
  isDefault Boolean @default(false)
  status    String  @default("active") // "active", "disabled"

  // حقل التجميد الجديد
  isFrozen Boolean @default(false)

  // JSON لتخزين خيارات الأقسام (cover, header, items...)
  sectionsConfig Json @default("{}")
  // JSON لتخزين خيارات العرض الإضافية (showClientCode...)
  displayOptions Json @default("{}")

  defaultTerms String? @db.Text

  // عداد الاستخدام
  usesCount Int @default(0)

  // علاقة المستخدم الذي أنشأ النموذج
  employeeId String?
  creator    Employee? @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// بند مفرد في المكتبة
model QuotationLibraryItem {
  id          String  @id @default(cuid())
  code        String  @unique // ITM-001
  title       String
  description String? @db.Text
  category    String // "خدمات هندسية", "خدمات قانونية"
  subCategory String? // "رخص وأمانة"
  unit        String  @default("خدمة")
  price       Float   @default(0)

  isEditable  Boolean @default(true)
  isActive    Boolean @default(true)
  warningText String? @db.Text // ملاحظات قانونية/استثناءات
  usesCount   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// مجموعة بنود في المكتبة
model QuotationBundle {
  id          String  @id @default(cuid())
  code        String  @unique // BDL-001
  title       String
  description String? @db.Text
  icon        String? @default("📦") // رمز تعبيري (Emoji)
  color       String? @default("blue") // اللون في الواجهة

  itemsIds String[] // مصفوفة تحتوي على أكواد البنود [ITM-001, ITM-002]

  isActive  Boolean @default(true)
  usesCount Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id        String   @id @default(cuid())
  amount    Float
  date      DateTime @default(now())
  method    String // (Cash, Check, Transfer)
  reference String?
  notes     String?

  category      String? @default("أتعاب مكتب")
  isFollowUpFee Boolean @default(false)
  receiptImage  String?

  receivedBy   Employee @relation("EmployeeToPayment", fields: [receivedById], references: [id])
  receivedById String

  allocations Json? @default("[]")

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionId])
  @@index([receivedById])
}

// ===============================================
// 8. إدارة الوثائق والأرشفة (DMS)
// ===============================================

model Document {
  id         String  @id @default(cuid())
  fileNumber String  @unique
  name       String
  type       String // 'file' أو 'folder'
  extension  String?
  size       Int?
  filePath   String? @unique

  createdAt  DateTime @default(now())
  modifiedAt DateTime @updatedAt

  owner   Employee @relation("OwnedDocuments", fields: [ownerId], references: [id])
  ownerId String

  classification   DocumentClassification? @relation(fields: [classificationId], references: [id])
  classificationId String?

  tags      String[]
  version   String   @default("1.0")
  isShared  Boolean  @default(false)
  downloads Int      @default(0)
  views     Int      @default(0)

  // هيكلية المجلدات
  path     String
  parent   Document?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?
  children Document[] @relation("FolderHierarchy")

  // الربط بالكيانات الأخرى
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String?

  client   Client? @relation(fields: [clientId], references: [id])
  clientId String?

  permissions DocumentPermission[]
  activities  DocumentActivity[]

  @@index([ownerId])
  @@index([parentId])
  @@index([transactionId])
  @@index([clientId])
  @@index([classificationId])
}

// ===============================================
// *. إعدادات أنواع المستندات (Document Types Config)
// ===============================================

model DocumentType {
  id     String  @id @default(cuid())
  code   String  @unique // DOC-001
  name   String
  nameEn String?

  classification    String // "مالي", "فني", "إداري", "قانوني"
  allowedExtensions String[] // ["PDF", "JPG", "DWG"]
  maxSizeMB         Int      @default(5)

  requiresSignature Boolean @default(false)
  confidentiality   String  @default("General") // "General", "Confidential", "TopSecret"
  allowMultiple     Boolean @default(false) // هل يسمح برفع أكثر من ملف لهذا النوع في المعاملة الواحدة؟

  status String @default("Active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentPermission {
  id               String @id @default(cuid())
  permissionNumber String @unique @default(cuid())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String

  user   Employee @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  accessLevel String // 'view', 'edit', 'delete', 'admin'
  expiryDate  DateTime?

  grantedBy   Employee @relation("GrantedPermissions", fields: [grantedById], references: [id])
  grantedById String
  grantedAt   DateTime @default(now())

  @@unique([documentId, userId])
  @@index([userId])
}

model DocumentActivity {
  id             String @id @default(cuid())
  activityNumber String @unique @default(cuid())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String

  fileName String
  action   String // 'upload', 'download', 'edit', 'delete', ...

  user   Employee @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  timestamp DateTime @default(now())
  ipAddress String?
  details   String?

  @@index([documentId])
  @@index([userId])
}

model DocumentClassification {
  id          String  @id @default(cuid())
  name        String  @unique
  color       String  @default("#6b7280")
  description String?

  createdBy   Employee @relation("CreatedClassifications", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())

  documents Document[]

  @@index([createdById])
}

model Attachment {
  id        String   @id @default(cuid())
  fileName  String
  filePath  String   @unique
  fileType  String
  fileSize  Int
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  uploadedBy   Employee @relation(fields: [uploadedById], references: [id])
  uploadedById String

  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String?

  contract   Contract? @relation(fields: [contractId], references: [id])
  contractId String?

  client   Client? @relation(fields: [clientId], references: [id])
  clientId String?

  sectorId String?
  sector   RiyadhSector? @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  districtId String?
  district   RiyadhDistrict? @relation(fields: [districtId], references: [id], onDelete: Cascade)

  employee    Employee?  @relation("EmployeeAttachments", fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId  String?
  quotation   Quotation? @relation("QuotationAttachments", fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId String?
}

// ===============================================
// 9. وحدات إضافية (التعقيب، شوارع الرياض، الإعدادات)
// ===============================================

// وحدة التعقيب (Follow-Up)
model FollowUpAgent {
  id                 String  @id @default(cuid())
  type               String // 'individual' or 'entity'
  name               String
  nationalId         String?
  commercialRegister String?

  phone   String
  email   String?
  address String?

  specialization     String[]
  governmentEntities String[]

  joinDate DateTime @default(now())
  status   String   @default("active")
  rating   Float    @default(5.0)
  notes    String?

  tasks FollowUpTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FollowUpTask {
  id String @id @default(cuid())

  agent   FollowUpAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId String

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String

  governmentEntity String
  description      String

  startDate      DateTime  @default(now())
  targetDate     DateTime?
  completionDate DateTime?

  status        String @default("pending")
  successStatus String @default("pending")
  attempts      Int    @default(0)

  notes     String?
  feedbacks String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([transactionId])
}

// وحدة شوارع وتقسيم الرياض
model RiyadhSector {
  id             String           @id @default(cuid())
  code           String           @unique // 👈 جديد: مثل SEC-C
  name           String           @unique
  districts      RiyadhDistrict[] // 👈 جديد: القطاع يحتوي على أحياء
  streets        RiyadhStreet[]
  createdAt      DateTime         @default(now())
  officialLink   String?
  mapImage       String?
  satelliteImage String?
  notes          Json?            @default("[]") // لتخزين الملاحظات
  regulations    Json?            @default("[]") // لتخزين الاشتراطات
  auditLogs      Json?            @default("[]") // لتخزين سجل التعديلات
  attachments    Attachment[] // ربط المرفقات
}

// 🚀 الجدول الرئيسي للقطع (Master Data for Plots)
model RiyadhPlanPlot {
  id         String @id @default(cuid())
  plotNumber String // رقم القطعة (مثلاً: 15 أو القطعة الشمالية)
  plotCode   String @unique // 👈 كود البحث المميز (مثال: PLT-8374-12)

  planId String
  plan   RiyadhPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  // العلاقات (كل قطعة يمكن أن ترتبط بعدة مشاريع عبر الجدول الوسيط)
  projectPlots ProjectPlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🛡️ حماية: لا يمكن تكرار نفس رقم القطعة داخل نفس المخطط
  @@unique([plotNumber, planId])
}

// 🚀 الجدول الوسيط (بين المشروع والقطعة)
model ProjectPlot {
  id String @id @default(cuid())

  projectId String
  project   ArchivedProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 👈 تم التعديل: نربط السجل بمعرف القطعة بدلاً من كتابة اسمها
  plotId String
  plot   RiyadhPlanPlot @relation(fields: [plotId], references: [id], onDelete: Cascade)

  createdAt    DateTime    @default(now())
  RiyadhPlan   RiyadhPlan? @relation(fields: [riyadhPlanId], references: [id])
  riyadhPlanId String?

  // 🛡️ حماية: لا يمكن ربط نفس القطعة بنفس المشروع مرتين
  @@unique([projectId, plotId])
}

model RiyadhPlan {
  id         String  @id @default(cuid())
  planNumber String  @unique // رقم المخطط الرسمي
  oldNumber  String? // الترقيم القديم

  // جعلنا الكود الداخلي اختيارياً لتجنب أخطاء الإضافة من الواجهة الجديدة
  internalCode String? @unique @default(cuid())

  status      String  @default("معتمد")
  isWithout   Boolean @default(false) // هل هو "بدون" مخطط؟
  properties  Int     @default(0) // عدد الملكيات المربوطة
  plots       Int     @default(0) // عدد القطع (القديم)
  attachments Int     @default(0) // عدد المرفقات (القديم)

  // 🚀 --- الحقول الجديدة المضافة لدعم الواجهة الشاملة ---
  hijriYear        String? // سنة الاعتماد
  areaKm           String? // المساحة بالكيلومتر
  areaM            String? // المساحة بالمتر
  mainUsages       String? // الاستخدام الرئيسي
  subUsages        String? // الاستخدامات الفرعية
  totalPlots       Int     @default(0) // إجمالي القطع (من الواجهة)
  neighborhoods    String? // الأحياء التابع لها كنص
  officialMapUrl   String? // رابط خريطة الأمانة
  googleMapUrl     String? // رابط خريطة جوجل
  officialMapImage String? @db.Text // صورة الخريطة الرسمية (Base64)
  googleMapImage   String? @db.Text // صورة خريطة جوجل (Base64)
  notes            String? @db.Text // ملاحظات عامة

  // --- العلاقات القديمة ---
  districts          RiyadhDistrict[]
  specialRegulations Json?            @default("[]")

  // 🚀 --- العلاقات الجديدة ---
  streets      RiyadhPlanStreet[]
  files        RiyadhPlanFile[]
  projects     ArchivedProject[]
  projectPlots ProjectPlot[]

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  RiyadhPlanPlot RiyadhPlanPlot[]
}

// 🚀 نموذج فرعي: شوارع المخطط
model RiyadhPlanStreet {
  id     String     @id @default(cuid())
  planId String
  plan   RiyadhPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  name          String // اسم الشارع
  width         String? // عرض الشارع
  hasSpecialReg Boolean @default(false) // تنظيم خاص؟
  regDesc       String? // وصف التنظيم الخاص

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 🚀 نموذج فرعي: ملفات ومرفقات المخطط
model RiyadhPlanFile {
  id     String     @id @default(cuid())
  planId String
  plan   RiyadhPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  url  String  @db.Text // رابط أو مسار الملف (مؤقتاً Base64 أو URL السيرفر)
  name String // اسم الملف
  desc String? // وصف الملف
  type String? // نوع الملف (PDF, PNG, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RiyadhDistrict {
  id   String @id @default(cuid())
  code String @unique // 👈 جديد: مثل NBH-C-001
  name String @unique

  sector   RiyadhSector @relation(fields: [sectorId], references: [id]) // 👈 جديد: الحي ينتمي لقطاع
  sectorId String

  streets             RiyadhStreet[]
  plans               RiyadhPlan[]
  ownerships          OwnershipFile[]
  clients             Client[] // أضف هذا السطر
  transactions        Transaction[] // أضف هذا السطر
  createdAt           DateTime             @default(now())
  officialLink        String?
  mapImage            String?
  satelliteImage      String?
  notes               Json?                @default("[]") // لتخزين الملاحظات
  regulations         Json?                @default("[]") // لتخزين الاشتراطات
  auditLogs           Json?                @default("[]") // لتخزين سجل التعديلات
  attachments         Attachment[] // ربط المرفقات
  privateTransactions PrivateTransaction[] @relation("DistrictPrivateTransactions")
  archivedProjects    ArchivedProject[]
}

model RiyadhStreet {
  id         String @id @default(cuid())
  streetCode String @unique
  name       String

  sector   RiyadhSector @relation(fields: [sectorId], references: [id])
  sectorId String

  district   RiyadhDistrict? @relation(fields: [districtId], references: [id])
  districtId String?

  type   String
  width  Float
  length Float
  lanes  Int
  status String

  lighting  Boolean @default(true)
  sidewalks Boolean @default(true)

  centerLat Float
  centerLng Float

  hasSpecialRegulation Boolean @default(false)
  regulationDetails    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sectorId])
  @@index([districtId])
}

// سجل الأنشطة العام
model ActivityLog {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  action      String
  description String
  category    String

  performedBy   Employee @relation("EmployeeToActivityLog", fields: [performedById], references: [id])
  performedById String

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  @@index([clientId])
  @@index([performedById])
}

// نظام المحادثات
model Conversation {
  id        String   @id @default(cuid())
  name      String?
  createdAt DateTime @default(now())

  participants Employee[] @relation("EmployeeToConversation")
  messages     Message[]
}

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String

  sender   Employee @relation("SenderToMessage", fields: [senderId], references: [id])
  senderId String
}

// ===============================================
// 10. النظام الداخلي الموازي (Private / Shadow System)
// ===============================================

model PrivateTransaction {
  id              String @id @default(cuid())
  transactionCode String @unique // مثال: PTX-2026-001
  title           String

  // --- البيانات الأساسية ---
  status      String  @default("جديدة")
  description String?
  category    String? // نوع المعاملة (إصدار، تعديل...)
  complexity  String? // نوع الرفع (برافع، بدون...)
  source      String? // المكتب المنفذ الخارجي الحر
  createdBy   String? @default("مدير النظام")

  // 💡 [احترافي] فصل بيانات الملاك لدعم تعدد الملاك بشكل صريح
  clientId   String
  client     Client  @relation("ClientPrivateTransactions", fields: [clientId], references: [id])
  clientType String? // نوع العميل (فرد، شركة، ورثة...)
  ownerNames String? @db.Text // أسماء الملاك المتعددين (أحمد و محمد)
  ownerIds   String? // هويات الملاك المتعددين

  // 💡 [احترافي] فصل بيانات الموقع والمساحة لسهولة الفلترة والبحث
  districtId   String?
  districtNode RiyadhDistrict? @relation("DistrictPrivateTransactions", fields: [districtId], references: [id])
  districtName String? // اسم الحي (نص حر في حال لم يكن مسجلاً)
  sector       String?
  planNumber   String? // رقم المخطط
  plots        String[] // أرقام القطع كـ Array
  landArea     Float? // مساحة الأرض (Float لتقبل الكسور)
  oldDeed      String? // رقم الصك القديم

  isOnAxis        String? // هل يقع على محور (مثال: "نعم" أو "لا")
  streetName      String? // اسم الشارع
  officialMapLink String? @db.Text // رابط الخريطة المعتمدة (استخدمنا Text لأن الروابط قد تكون طويلة)
  // 👆 ====================================================

  // 💡 [احترافي] فصل أرقام المنصات
  serviceNo String?
  requestNo String?
  licenseNo String?

  // --- البيانات المالية والضريبية ---
  totalFees       Float?  @default(0)
  paidAmount      Float?  @default(0)
  remainingAmount Float?  @default(0)
  firstPayment    Float?  @default(0) // الدفعة الأولى المحصلة
  feeType         String? @default("نهائي") // مبدئي / نهائي

  // 💡 [احترافي] فصل بيانات الضريبة لتسهيل التقارير المحاسبية الختامية
  taxType   String? @default("بدون احتساب ضريبة")
  netAmount Float?  @default(0) // المبلغ الصافي
  taxAmount Float?  @default(0) // قيمة الضريبة المضافة

  // 💡 [احترافي] بيانات المصدر وتوزيع الأرباح
  sourceType    String? @default("مباشر")
  sourceName    String?
  sourcePercent Float?  @default(0)

  // 💡 مصدر المعاملة (مرتبط بجدول الأشخاص فقط: موظف، وسيط، معقب)
  sourcePersonId String?
  sourcePerson   Person? @relation("TxSourcePerson", fields: [sourcePersonId], references: [id])

  // --- التفاصيل الإضافية ---
  authorities String[]
  attachments String[]
  notes       Json?    @default("{}") // مخصص فقط لسجل الأحداث (Logs) والملاحظات العشوائية

  // --- العلاقات العكسية للتسويات ---
  payments      PrivatePayment[]
  settlements   PrivateSettlement[]
  disbursements Disbursement[]
  treasuryLogs  TreasuryTransaction[]

  // 💡 [احترافي] بيانات الطلب والرخصة (Request & License Data)
  designerOfficeId   String? // معرف المكتب المصمم
  supervisorOfficeId String? // معرف المكتب المشرف
  hasAgreement       Boolean   @default(false)
  requestDate        DateTime? // 👈 جديد: تاريخ الطلب 

  // 💡 بيانات الخدمة (مفصول الرقم عن التاريخ والسنة)
  serviceDate                DateTime? // 👈 جديد: تاريخ الخدمة
  electronicLicenseNumber    String? // رقم الرخصة الإلكترونية
  electronicLicenseHijriYear String? // سنة الرخصة (هجري)
  electronicLicenseDate      DateTime? // تاريخ الرخصة (ميلادي)

  oldLicenseNumber    String? // رقم الرخصة القديمة (لتصحيح الوضع)
  oldLicenseHijriYear String? // سنة الرخصة القديمة (هجري)
  oldLicenseDate      DateTime? // تاريخ الرخصة القديمة (ميلادي)
  requestNumber       String? // رقم الطلب (نظام بلدي)
  requestYear         String? // سنة الطلب (نظام بلدي)
  serviceNumber       String? // رقم الخدمة (نظام بلدي)
  serviceYear         String? // سنة الخدمة (نظام بلدي)
  responsibleEmployee String? // الموظف المسؤول عن الرفع

  surveyRequestNumber String?
  surveyRequestYear   String?
  surveyServiceNumber String?
  surveyServiceYear   String?
  surveyReportNumber  String?
  surveyReportDate    DateTime?

  generalNotes          String?
  generalNotesUpdatedBy String?
  generalNotesUpdatedAt DateTime?

  // 💡 حقول التعاقد الإلكتروني/التفويض (Electronic Contract / Authorization)
  contractNumber       String?
  contractApprovalDate DateTime?
  contractApprovedBy   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- العلاقات مع سجل الأشخاص (الأدوار) ---
  brokerId String?
  broker   Person? @relation("TxBroker", fields: [brokerId], references: [id])

  agentId String?
  agent   Person? @relation("TxAgent", fields: [agentId], references: [id])

  officeId String?
  office   IntermediaryOffice? @relation(fields: [officeId], references: [id])

  stakeholderId String?
  stakeholder   Person? @relation("TxStakeholder", fields: [stakeholderId], references: [id])

  receiverId String?
  receiver   Person? @relation("TxReceiver", fields: [receiverId], references: [id])

  engOfficeBrokerId String?
  engOfficeBroker   Person? @relation("TxEngBroker", fields: [engOfficeBrokerId], references: [id])

  tasks       TransactionTask[]
  brokersList TransactionBroker[]

  coopOfficeId String?
  CoopOffice   CoopOffice? @relation(fields: [coopOfficeId], references: [id])

  folders TransactionFolder[]
  files   TransactionFile[]

  // 💡 [احترافي] بيانات التتبع لمدير الملفات
  modifiedBy String? @default("غير محدد") // اسم الموظف الذي قام بآخر تعديل
  isUrgent   Boolean @default(false) // علامة الاستعجال

  // 💡 [احترافي] المعاملات المرتبطة (Linked Transactions) - علاقة ذاتية
  linkedParentId String?
  linkedParent   PrivateTransaction?  @relation("LinkedTransactions", fields: [linkedParentId], references: [id])
  linkedChildren PrivateTransaction[] @relation("LinkedTransactions")

  ownersList       TransactionOwner[]
  OfficeTask       OfficeTask[]
  MeetingMinute    MeetingMinute[]
  technicalReports TechnicalReport[]
  quotations       Quotation[]        @relation("TransactionQuotations")

  @@index([clientId])
  @@index([districtId])
}

// 💡 👈 الجدول الوسيط الجديد لربط المعاملة بأكثر من عميل (مالك)
model TransactionOwner {
  id String @id @default(cuid())

  transactionId String
  transaction   PrivateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  clientId String // إجباري: كل مالك يجب أن يكون عميلاً في النظام
  client   Client @relation(fields: [clientId], references: [id])

  idNumber        String?
  sharePercentage Float?  @default(100) // نسبة التملك (اختياري)
  isPrimary       Boolean @default(false) // هل هو العميل الرئيسي للمعاملة؟

  createdAt DateTime @default(now())

  @@unique([transactionId, clientId]) // منع تكرار نفس العميل في نفس المعاملة
  @@index([clientId])
}

// ===============================================
// مدفوعات النظام الداخلي
// ===============================================
model PrivatePayment {
  id        String   @id @default(cuid())
  amount    Float
  date      DateTime @db.Date
  method    String
  periodRef String?

  // 👈 الربط مع سجل الأشخاص (من دفع؟)
  collectedFromType String // من أشخاص النظام، شخص آخر
  collectedFromId   String?
  collectedFrom     Person? @relation("PaymentCollector", fields: [collectedFromId], references: [id])
  collectedFromName String? // يستخدم فقط إذا كان شخصاً خارجياً غير مسجل

  // 👈 الربط مع سجل الأشخاص (الموظف المستلم)
  receiverId String?
  receiver   Person? @relation("PaymentReceiver", fields: [receiverId], references: [id])

  // 👈 الربط مع البنك
  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])

  // 💡 2. هل تم توريد المبلغ النقدي للخزنة؟
  isDepositedToSafe Boolean @default(false)

  notes        String? @db.Text
  receiptImage String?
  collectedBy  String? // اسم أو بيانات الموظف الذي قام بالتحصيل

  // الربط مع المعاملة
  transactionId String?
  transaction   PrivateTransaction? @relation(fields: [transactionId], references: [id])

  createdAt DateTime @default(now())

  @@index([collectedFromId])
  @@index([receiverId])
  @@index([bankAccountId])
}

// ===============================================
// تسويات النظام الداخلي
// ===============================================
model PrivateSettlement {
  id         String @id @default(cuid())
  targetType String

  // 👈 الربط مع المستفيد (شريك، وسيط، معقب)
  targetId   String?
  target     Person? @relation("SettlementTarget", fields: [targetId], references: [id])
  targetName String? // شخص خارجي

  amount Float
  status String @default("PENDING")

  deliveryMethod String?
  deliveryDate   DateTime? @db.Date

  // 👈 الربط مع من قام بتسليم المبلغ
  deliveredById String?
  deliveredBy   Person? @relation("SettlementDeliverer", fields: [deliveredById], references: [id])

  // 👈 الربط مع المعاملة (إذا كانت التسوية تخص معاملة محددة)
  transactionId String?
  transaction   PrivateTransaction? @relation(fields: [transactionId], references: [id])

  source         String?
  periodRef      String?
  notes          String? @db.Text
  attachmentPath String?

  isOpeningBalance Boolean @default(false)
  openingTotal     Float?  @default(0)
  openingDelivered Float?  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetId])
  @@index([deliveredById])
  @@index([transactionId])
}

// ===============================================
// المكاتب المتعاونة
// ===============================================
model CoopOffice {
  id            String  @id @default(cuid())
  name          String
  contactName   String?
  phone         String?
  agreementType String  @default("حسب عدد المعاملات")
  monthlyAmount Float?  @default(0)

  // 👈 الربط مع سجل الأشخاص (المسؤول من طرفكم)
  responsibleId String?
  responsible   Person? @relation("OfficeResponsible", fields: [responsibleId], references: [id])

  isLinkedToSystem Boolean @default(false)
  notes            String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isMainBranch       Boolean              @default(false)
  fees               CoopOfficeFee[]
  PrivateTransaction PrivateTransaction[]
}

model CoopOfficeFee {
  id              String @id @default(cuid())
  transactionCode String @unique
  internalName    String

  officeId String
  office   CoopOffice @relation(fields: [officeId], references: [id])

  isSurveyOnly Boolean @default(false)
  isPrepToo    Boolean @default(false)

  officeFees Float
  paidAmount Float     @default(0)
  dueDate    DateTime?

  status String  @default("غير مدفوع")
  notes  String? @db.Text

  // 💡 الحقول الجديدة التي تمت إضافتها من التحديث الأخير
  transactionId    String? // للربط بالمعاملة الأم
  requestType      String? // نوع الطلب (إصدار، تجديد...)
  providedServices String? @db.Text // الخدمات المقدمة (نص حر)
  uploadStatus     String? // حالة الرفع على النظام
  licenseNumber    String? // رقم الرخصة
  licenseYear      String? // سنة الرخصة
  serviceNumber    String? // رقم الخدمة
  serviceYear      String? // سنة الخدمة
  entityName       String? // اسم الجهة

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===============================================
// مصروفات المكتب
// ===============================================
model OfficeExpense {
  id     String @id @default(cuid())
  item   String
  amount Float

  // 👈 الربط مع الأشخاص
  payerId   String?
  payer     Person? @relation("ExpensePayer", fields: [payerId], references: [id])
  payerName String? // في حال كان كيان خارجي (الشركة مثلاً)

  payeeId   String?
  payee     Person? @relation("ExpensePayee", fields: [payeeId], references: [id])
  payeeName String? // جهة خارجية (شركة الكهرباء)

  method        String
  source        String
  expenseDate   DateTime
  notes         String?  @db.Text
  attachmentUrl String?

  isClearable      Boolean @default(false)
  linkToSettlement Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===============================================
// إدارة الخزنة (نظام إرث)
// ===============================================

enum VaultStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum TransactionDirection {
  INBOUND
  OUTBOUND
  INTERNAL_TRANSFER
}

enum TransactionCategory {
  FEES
  RESERVE
  BANK_SUPPORT
  PENDING
  CUSTODY
}

enum SettleStatus {
  NOT_STARTED
  OPEN
  AWAITING_SETTLEMENT
  SETTLED
  PARTIALLY_SETTLED
  CANCELLED
  REFUNDED
  NEEDS_REVIEW
}

model CashVault {
  id                    String                 @id @default(uuid())
  vaultCode             String                 @unique
  vaultName             String
  responsibleEmployeeId String
  openingBalance        Decimal                @db.Decimal(18, 4)
  openingBalanceDate    DateTime
  currentBalance        Decimal                @default(0) @db.Decimal(18, 4)
  feesBalance           Decimal                @default(0) @db.Decimal(18, 4)
  reserveBalance        Decimal                @default(0) @db.Decimal(18, 4)
  bankSupportBalance    Decimal                @default(0) @db.Decimal(18, 4)
  pendingBalance        Decimal                @default(0) @db.Decimal(18, 4)
  targetReserveAmount   Decimal?               @db.Decimal(18, 4)
  minimumAlertAmount    Decimal?               @db.Decimal(18, 4)
  status                VaultStatus            @default(ACTIVE)
  notes                 String?                @db.Text
  createdBy             String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  transactions          CashVaultTransaction[]
}

model CashVaultTransaction {
  id              String               @id @default(uuid())
  transactionNo   String               @unique
  vaultId         String
  vault           CashVault            @relation(fields: [vaultId], references: [id])
  transactionType String
  direction       TransactionDirection
  amount          Decimal              @db.Decimal(18, 4)
  category        TransactionCategory
  transactionDate DateTime
  balanceBefore   Decimal              @db.Decimal(18, 4)
  balanceAfter    Decimal              @db.Decimal(18, 4)
  description     String               @db.Text
  reason          String?              @db.Text
  createdBy       String
  deliveredBy     String?
  receivedBy      String?
  recipientName   String?
  recipientType   String?

  // الربط الداخلي والخارجي
  linkedTransactionId      String?
  linkedExternalDealId     String?
  linkedCustomerId         String?
  linkedContractId         String?
  linkedInvoiceId          String?
  linkedQuotationId        String?
  linkedQuotationPaymentId String?
  settlementId             String?

  attachmentIds String[]
  status        String    @default("APPROVED")
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  externalDeal ExternalDeal?   @relation(fields: [linkedExternalDealId], references: [id])
  settlement   CashSettlement? @relation(fields: [settlementId], references: [id])
}

model ExternalDeal {
  id                      String                   @id @default(uuid())
  dealNo                  String                   @unique
  dealName                String
  ownerOrClientName       String
  description             String?                  @db.Text
  responsiblePerson       String
  originalAgreementAmount Decimal                  @db.Decimal(18, 4)
  actualCollectedAmount   Decimal                  @default(0) @db.Decimal(18, 4)
  extraAmountsTotal       Decimal                  @default(0) @db.Decimal(18, 4)
  obligationsTotal        Decimal                  @default(0) @db.Decimal(18, 4)
  netProfit               Decimal                  @default(0) @db.Decimal(18, 4)
  distributionMethod      String
  settlementStatus        SettleStatus             @default(NOT_STARTED)
  dealStatus              String                   @default("OPEN")
  cancellationReason      String?
  refundStatus            String?
  attachmentIds           String[]
  notes                   String?                  @db.Text
  createdBy               String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  obligations             ExternalDealObligation[]
  vaultTransactions       CashVaultTransaction[]
}

model ExternalDealObligation {
  id                String       @id @default(uuid())
  externalDealId    String
  externalDeal      ExternalDeal @relation(fields: [externalDealId], references: [id], onDelete: Cascade)
  partyName         String
  partyType         String
  amount            Decimal      @db.Decimal(18, 4)
  reason            String
  isPaid            Boolean      @default(false)
  paidTransactionId String?
  notes             String?      @db.Text
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model CashSettlement {
  id                     String                       @id @default(uuid())
  settlementNo           String                       @unique
  settlementType         String
  vaultId                String
  periodFrom             DateTime?
  periodTo               DateTime?
  grossCollected         Decimal                      @db.Decimal(18, 4)
  extraAmounts           Decimal                      @db.Decimal(18, 4)
  totalObligations       Decimal                      @db.Decimal(18, 4)
  totalExpenses          Decimal                      @db.Decimal(18, 4)
  netProfitBeforeReserve Decimal                      @db.Decimal(18, 4)
  reserveAmount          Decimal                      @db.Decimal(18, 4)
  bankSupportAmount      Decimal                      @db.Decimal(18, 4)
  netDistributable       Decimal                      @db.Decimal(18, 4)
  status                 String                       @default("PENDING")
  createdBy              String
  approvedBy             String?
  createdAt              DateTime                     @default(now())
  approvedAt             DateTime?
  notes                  String?                      @db.Text
  distributions          CashSettlementDistribution[]
  vaultTransactions      CashVaultTransaction[]
}

model CashSettlementDistribution {
  id                String         @id @default(uuid())
  settlementId      String
  settlement        CashSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  beneficiaryName   String
  beneficiaryType   String
  employeeId        String?
  percentage        Decimal?       @db.Decimal(5, 2)
  amount            Decimal        @db.Decimal(18, 4)
  reason            String
  paymentMethod     String
  paidTransactionId String?
  notes             String?        @db.Text
  createdAt         DateTime       @default(now())
}

model CashVaultAuditLog {
  id         String @id @default(uuid())
  entityType String
  entityId   String
  action     String

  // 👈 إضافة العلاقة المباشرة مع جدول الموظفين
  userId String
  user   Employee @relation(fields: [userId], references: [id])

  oldValueJson String?  @db.Text
  newValueJson String?  @db.Text
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
}

// ===============================================
// حركات الخزنة
// ===============================================
model TreasuryTransaction {
  id        String   @id @default(cuid())
  type      String
  amount    Float
  date      DateTime
  statement String?

  // 👈 الربط مع المعاملات (إذا كانت الحركة مرتبطة بمعاملة)
  transactionId String?
  transaction   PrivateTransaction? @relation(fields: [transactionId], references: [id])

  // 👈 الربط مع الأشخاص (المستفيد / المودع)
  personId      String?
  person        Person? @relation("TreasuryPerson", fields: [personId], references: [id])
  referenceText String? // نص مرجعي إضافي

  notes         String? @db.Text
  attachmentUrl String?
  metadata      Json?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TreasurySettings {
  id      Int     @id @default(1)
  enabled Boolean @default(true)
  type    String  @default("نسبة مئوية")
  value   Float   @default(27.3)
  method  String  @default("على كل معاملة")

  updatedAt DateTime @updatedAt
}

// ===============================================
// الحسابات البنكية
// ===============================================
model BankAccount {
  id            String  @id @default(cuid())
  bankName      String // اسم البنك
  bankLogo      String? @db.Text // 👈 رابط أو مسار صورة شعار البنك
  accountNameAr String? // 👈 اسم العميل/الشركة بالعربي
  accountNameEn String? // 👈 اسم العميل/الشركة بالإنجليزي
  accountNumber String  @unique
  iban          String?
  currency      String  @default("SAR") // 👈 العملة (ر.س، USD، إلخ)
  qrCodeData    String? @db.Text

  // الربط مع الأشخاص
  openedById String?
  openedBy   Person? @relation("AccountOpener", fields: [openedById], references: [id])

  controlledById String?
  controlledBy   Person? @relation("AccountController", fields: [controlledById], references: [id])

  openDate          DateTime?
  authorizedPersons String?

  initialBalance      Float     @default(0)
  initialBalanceDate  DateTime?
  initialBalanceNotes String?

  systemBalance   Float @default(0)
  externalBalance Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions    BankTransaction[]
  privatePayments PrivatePayment[]
}

model BankTransaction {
  id        String      @id @default(cuid())
  accountId String
  account   BankAccount @relation(fields: [accountId], references: [id])

  type   String
  amount Float

  // 👈 الربط مع الشريك عند الشحن
  partnerId String?
  partner   Person? @relation("BankTxPartner", fields: [partnerId], references: [id])

  date  DateTime
  notes String?

  createdAt DateTime @default(now())
}

// ===============================================
// أوامر الصرف (Disbursements)
// ===============================================
model Disbursement {
  id            String @id @default(cuid())
  requestNumber String @unique
  type          String

  // 👈 الربط مع المستفيد
  beneficiaryId   String?
  beneficiary     Person? @relation("DisbursementBeneficiary", fields: [beneficiaryId], references: [id])
  beneficiaryName String? // في حال المستفيد خارجي غير مسجل

  amount            Float
  date              DateTime
  reason            String
  notes             String?  @db.Text
  requestAttachment String?

  // 👈 الربط بالمعاملة
  isRelatedToTx Boolean             @default(false)
  transactionId String?
  transaction   PrivateTransaction? @relation(fields: [transactionId], references: [id])

  department String?
  importance String?

  repaymentType      String?
  expectedReturnDate DateTime?
  repaymentMethod    String?

  status          String @default("معلق")
  repaymentStatus String @default("غير مطلوب")
  remainingAmount Float?

  executionMethod     String?
  executionReference  String?
  executionNotes      String?   @db.Text
  executionAttachment String?
  executedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===============================================
// سجل الأشخاص (المركز الأساسي)
// ===============================================
model Person {
  id            String  @id @default(cuid())
  personCode    String  @unique
  name          String
  role          String
  phone         String?
  agreementType String?
  notes         String? @db.Text
  attachments   Json?

  email             String?
  preferredCurrency String? @default("SAR")
  isActive          Boolean @default(true)
  // 🚀 --- الحقول الجديدة للموظف عن بعد والربط المستقبلي ---
  firstNameAr       String?
  secondNameAr      String?
  thirdNameAr       String?
  fourthNameAr      String?

  firstNameEn  String?
  secondNameEn String?
  thirdNameEn  String?
  fourthNameEn String?

  country  String?
  whatsapp String?
  telegram String?

  transferMethod  String? // طريقة التحويل (ويسترن، بنك، انستا)
  transferDetails Json? // تفاصيل التحويل (رقم الحساب، الايبان الخ)

  isLocalOnly Boolean @default(true) // 💡 true = هذا الشخص تم إنشاؤه في النظام الفرعي ولا يرحل للرئيسي

  idNumber      String? // رقم الهوية أو الإقامة
  monthlySalary Float? // الراتب الشهري
  jobTitle      String? // المسمى الوظيفي

  // 👈 جميع العلاقات العكسية (لتسهيل استخراج كشف حساب/ملف للشخص)
  paymentsCollected PrivatePayment[] @relation("PaymentCollector")
  paymentsReceived  PrivatePayment[] @relation("PaymentReceiver")

  settlementsTarget   PrivateSettlement[] @relation("SettlementTarget")
  settlementsDelivred PrivateSettlement[] @relation("SettlementDeliverer")

  expensesPaid     OfficeExpense[]     @relation("ExpensePayer")
  expensesReceived OfficeExpense[]     @relation("ExpensePayee")
  assignedBrokers  TransactionBroker[] @relation("PersonBrokers")

  treasuryLogs TreasuryTransaction[] @relation("TreasuryPerson")

  disbursements Disbursement[] @relation("DisbursementBeneficiary")

  bankAccountsOpened BankAccount[]     @relation("AccountOpener")
  bankAccountsCtrl   BankAccount[]     @relation("AccountController")
  bankTransactions   BankTransaction[] @relation("BankTxPartner")

  officesResponsible CoopOffice[] @relation("OfficeResponsible")

  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  brokeredTransactions    PrivateTransaction[] @relation("TxBroker")
  agentTransactions       PrivateTransaction[] @relation("TxAgent")
  stakeholderTransactions PrivateTransaction[] @relation("TxStakeholder")
  receivedTransactions    PrivateTransaction[] @relation("TxReceiver")
  engBrokeredTransactions PrivateTransaction[] @relation("TxEngBroker")
  assignedTasks           TransactionTask[]    @relation("WorkerTasks")
  // 💡 إضافة العلاقة العكسية لمصدر المعاملة
  sourcedTransactions     PrivateTransaction[] @relation("TxSourcePerson")
}

model TransactionTask {
  id            String  @id @default(cuid())
  transactionId String
  workerId      String
  taskName      String?
  cost          Float?  @default(0)

  // 💡 1. الحقول الجديدة للمهام المتقدمة
  description   String?   @db.Text
  deadline      DateTime?
  isUrgent      Boolean   @default(false)
  isCompleted   Boolean   @default(false)
  submitComment String?   @db.Text
  submitFileUrl String?
  submittedAt   DateTime?
  assignedBy    String?   @default("مدير النظام")

  // 💡 2. الحقول القديمة (استرجعناها هنا حتى لا يتم حذف بياناتك المالية السابقة)
  isFinal         Boolean?  @default(false)
  isPaid          Boolean   @default(false)
  paidAmount      Float     @default(0)
  paymentCurrency String?   @default("SAR")
  paymentDate     DateTime? @db.Date

  createdAt DateTime @default(now())

  // العلاقات (Relations)
  transaction PrivateTransaction @relation(fields: [transactionId], references: [id])
  worker      Person             @relation("WorkerTasks", fields: [workerId], references: [id])
}

// 💡 3. أضف هذا النموذج الجديد (لأسعار الصرف)
model ExchangeRate {
  id          String   @id @default(cuid())
  currency    String   @unique // USD, EGP
  rate        Float // e.g., 0.266 for USD, 13.15 for EGP
  transferFee Float    @default(0) // رسوم التحويل الثابتة
  updatedAt   DateTime @updatedAt
}

// ===============================================
// جدول ربط الوسطاء بالمعاملات (لدعم وسطاء متعددين)
// ===============================================
model TransactionBroker {
  id            String   @id @default(cuid())
  transactionId String
  brokerId      String
  fees          Float    @default(0)
  createdAt     DateTime @default(now())

  transaction PrivateTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  broker      Person             @relation("PersonBrokers", fields: [brokerId], references: [id])
}

// ===============================================
// إعدادات النظام الشاملة (System Settings)
// ===============================================
model SystemSettings {
  id Int @id @default(1)

  // إعدادات عامة
  companyName String? @default("مكتب ديتيلز للاستشارات الهندسية")
  taxNumber   String? @default("310000000000003")
  currency    String? @default("SAR")
  timezone    String? @default("Asia/Riyadh (UTC+3)")

  // إعدادات التأخير
  warningDays Int? @default(5)
  overdueDays Int? @default(10)

  // إعدادات التقدير الضريبي
  taxEstimateEnabled Boolean? @default(true)
  taxPercentage      Float?   @default(15)
  taxApplyTo         String?  @default("كل المبالغ البنكية")
  taxExclude         Json?    @default("[\"النقد\", \"الخزنة\", \"التحصيل غير المسلم للشركة\"]")
  taxNotes           String?  @db.Text

  // إعدادات حصة المكتب
  officeShareType       String?  @default("percentage")
  officeShareValue      Float?   @default(10)
  officeShareCategories Json?    @default("[{\"id\":1,\"label\":\"أقل من 50,000\",\"minProfit\":0,\"maxProfit\":50000,\"fixedAmount\":2000},{\"id\":2,\"label\":\"50,000 — 150,000\",\"minProfit\":50000,\"maxProfit\":150000,\"fixedAmount\":5000},{\"id\":3,\"label\":\"150,000 — 500,000\",\"minProfit\":150000,\"maxProfit\":500000,\"fixedAmount\":12000},{\"id\":4,\"label\":\"أكثر من 500,000\",\"minProfit\":500000,\"maxProfit\":999999999,\"fixedAmount\":25000}]")
  officeShareManual     Boolean? @default(false)
  officeShareManualVal  Float?   @default(0)

  // الحسابات الخاصة
  specialAccounts Json? @default("[{\"id\":1,\"systemName\":\"حسابات العبودي\",\"reportName\":\"العبودي\"},{\"id\":2,\"systemName\":\"حسابات إبراهيم الراجحي\",\"reportName\":\"إبراهيم الراجحي\"},{\"id\":3,\"systemName\":\"حسابات أحمد طلعت\",\"reportName\":\"أحمد طلعت\"},{\"id\":4,\"systemName\":\"حسابات محمد فؤاد\",\"reportName\":\"محمد فؤاد\"}]")

  geminiApiKey  String? @db.Text
  aiConcurrency Int?    @default(3)

  updatedAt DateTime @updatedAt
}

// ===============================================
// إعدادات مظهر القائمة الجانبية (Sidebar Settings)
// ===============================================
model SidebarSettings {
  id Int @id @default(1)

  // الألوان
  bgColor     String @default("#293241")
  textColor   String @default("#cbd5e1")
  activeColor String @default("#2563eb")
  hoverColor  String @default("#1e293b")

  // الأبعاد والسلوك
  width       Int     @default(280)
  isCollapsed Boolean @default(false)

  // اللوجو والترتيب
  logoUrl       String? @default("/logo.jpeg")
  categoryOrder Json?   @default("[]") // لتخزين ترتيب الأقسام [ "CAT_FINANCE", "CAT_DASHBOARD", ... ]
  customLabels  Json?   @default("{}") // لتخزين الأسماء المعدلة { "CAT_FINANCE": "المالية", "01": "لوحة المدير" }
  itemOrder     Json?   @default("{}")

  updatedAt DateTime @updatedAt

  @@map("sidebar_settings")
}

model OutsourceSalary {
  id              String   @id @default(uuid())
  employeeId      String
  employeeName    String
  period          String
  startDate       String
  endDate         String
  daysCount       Int
  dailyRate       Float
  grossAmount     Float
  deductions      Float
  netAmount       Float
  roundedAmount   Float
  status          String // "paid", "partial", "unpaid"
  paidAmount      Float    @default(0)
  remainingAmount Float
  paymentType     String
  createdAt       DateTime @default(now())

  payments OutsourcePayment[]
}

model OutsourcePayment {
  id             String          @id @default(uuid())
  salaryRecordId String
  salary         OutsourceSalary @relation(fields: [salaryRecordId], references: [id])
  amount         Float
  paymentMethod  String
  paymentDate    String
  paymentTime    String
  currency       String
  notes          String?
  receiptUrl     String?
  isPartial      Boolean
  createdAt      DateTime        @default(now())
}

// ===============================================
// 💡 نظام التسجيل السريع (Quick Entries)
// ===============================================

model QuickEntry {
  id            String   @id @default(cuid())
  entryCode     String   @unique
  date          DateTime @db.Date
  time          String
  type          String
  description   String   @db.Text
  amount        Float?
  relatedPerson String?
  priority      String   @default("normal")
  attachments   String[]

  status String @default("pending")

  processedDetails Json?
  processedAt      DateTime?

  // 💡 التعديل هنا: استخدام نصوص بدلاً من علاقات لمنع أي مشاكل
  recordedBy  String  @default("موظف النظام")
  processedBy String?

  comments QuickEntryComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuickEntryComment {
  id   String @id @default(cuid())
  text String @db.Text

  entryId String
  entry   QuickEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  // 💡 التعديل هنا
  author String @default("مستخدم")

  createdAt DateTime @default(now())
}

// ===============================================
// 💡 إدارة المكاتب الوسيطة (Intermediary Offices)
// ===============================================

model IntermediaryOffice {
  id                 String   @id @default(cuid())
  code               String   @unique
  nameAr             String
  nameEn             String?
  commercialRegister String
  engineeringLicense String?
  vatNumber          String?
  vatStatus          String   @default("غير مسجل") // مسجل، غير مسجل
  nationalAddress    String?
  city               String
  region             String?
  email              String?
  phone              String?
  whatsapp           String?
  website            String?
  specializations    String[]
  internalNotes      String?  @db.Text

  status           String  @default("نشط") // نشط، موقوف، مجمد
  suspensionReason String? @db.Text
  relationshipType String  @default("وسيط") // وسيط، شريك، مكتب تابع

  contactPerson String?
  contactMobile String?

  receivableBalance   Float   @default(0)
  lastTransactionCode String? @default("-")
  lastTransactionDate String? @default("-")

  contacts          OfficeContact[]
  officialAssets    OfficeAsset[]
  intermediaryLinks IntermediaryLink[]

  // علاقة مع المعاملات (يجب أن يكون لديك حقل officeId في جدول PrivateTransaction)
  // transactions    PrivateTransaction[] 

  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  PrivateTransaction   PrivateTransaction[]
  archivedAsDesigner   ArchivedProject[]    @relation("ArchivedDesigner")
  archivedAsSupervisor ArchivedProject[]    @relation("ArchivedSupervisor")
  quotations           Quotation[]          @relation("OfficeQuotations")
}

model OfficeContact {
  id                 String  @id @default(cuid())
  name               String
  position           String?
  mobile             String
  email              String?
  notes              String? @db.Text
  isAuthorizedSigner Boolean @default(false)

  officeId String
  office   IntermediaryOffice @relation(fields: [officeId], references: [id], onDelete: Cascade)
}

model OfficeAsset {
  id           String  @id @default(cuid())
  type         String // logo, stamp, signature, etc.
  label        String
  fileName     String?
  fileType     String?
  content      String? @db.Text
  version      Int     @default(1)
  isActive     Boolean @default(true)
  approvedBy   String?
  approvedDate String?
  settings     Json?

  uploadedBy   String?
  uploadedAt   String?
  uploadedTime String?
  usageCount   Int     @default(0)

  officeId String
  office   IntermediaryOffice @relation(fields: [officeId], references: [id], onDelete: Cascade)
}

model IntermediaryLink {
  id               String  @id @default(cuid())
  intermediaryName String
  role             String
  commissionType   String  @default("percentage")
  commissionValue  Float   @default(0)
  isDefault        Boolean @default(false)

  officeId String
  office   IntermediaryOffice @relation(fields: [officeId], references: [id], onDelete: Cascade)
}

// ===============================================
// سجل الرخص المركزي (Permits Registry)
// ===============================================
model Permit {
  id           String  @id @default(cuid())
  permitNumber String
  year         Int? // 👈 جعلناه اختيارياً
  hijriYear    String? // 👈 تمت الإضافة (مهم جداً لمنع التكرار)
  type         String? // 👈 جعلناه اختيارياً
  form         String? // 👈 جعلناه اختيارياً
  ownerName    String
  idNumber     String?

  issueDate  String?
  expiryDate String?

  district          String?
  sector            String?
  plotNumber        String?
  planNumber        String?
  usage             String?
  landArea          Float?
  engineeringOffice String?
  source            String? // 👈 جعلناه اختيارياً
  qrStatus          String  @default("غير متوفر")
  aiStatus          String  @default("غير مطبق")
  copies            Int     @default(1)
  notes             String  @default("")
  attachmentUrl     String?
  mainUsage         String?
  subUsage          String?
  detailedReport    String? @db.Text

  linkedTransactionId String?
  linkedOwnershipId   String?
  linkedClientId      String?
  linkedOfficeId      String?
  extraAttachments    String? @db.Text

  componentsData String? @db.Text
  boundariesData String? @db.Text

  archiveDate DateTime @default(now()) @db.Date
  updatedAt   DateTime @updatedAt

  aiJobId       String? // لمعرفة أي مهمة AI قامت باستخراج هذه الرخصة
  isMerged      Boolean  @default(false) // هل هذه رخصة تم دمجها مع أخرى؟
  mergedIntoId  String? // ID الرخصة الأساسية التي تم دمج هذه الرخصة معها
  mergedInto    Permit?  @relation("MergedPermits", fields: [mergedIntoId], references: [id])
  duplicateFrom Permit[] @relation("MergedPermits")
}

// ============================================================================
// 💡 11. نظام إدارة الوثائق والأرشفة المؤسسي (Enterprise DMS)
// ============================================================================

model TransactionFolder {
  id    String  @id @default(cuid())
  name  String
  color String? @default("#FDB022")
  icon  String? @default("📁")

  // 💡 [احترافي] إعدادات المجلد
  isSystemFolder Boolean @default(false) // لا يمكن حذفه أو تغيير اسمه
  isLocked       Boolean @default(false) // مقفل بكلمة مرور أو صلاحيات
  isDeleted      Boolean @default(false) // الحذف الآمن (Soft Delete)

  // 💡 [احترافي] التتبع
  createdBy String    @default("النظام")
  updatedBy String?
  deletedBy String?
  deletedAt DateTime?

  // العلاقات الهرمية
  parentId String?
  parent   TransactionFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children TransactionFolder[] @relation("FolderHierarchy")

  files TransactionFile[]

  // 💡 [احترافي] الربط المرن (يمكن ربط المجلد بأكثر من كيان)
  transactionId String?
  transaction   PrivateTransaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionId])
  @@index([parentId])
}

model TransactionFile {
  id           String @id @default(cuid())
  name         String // الاسم المعروض للمستخدم
  originalName String // الاسم الحقيقي وقت الرفع
  mimeType     String
  extension    String
  size         Int
  url          String

  // 💡 [احترافي] النزاهة والإصدارات
  fileHash       String? // بصمة الملف (MD5/SHA256) لمنع التكرار
  version        Int     @default(1) // رقم الإصدار
  isConfidential Boolean @default(false) // ملف سري (يتطلب صلاحية عليا)

  // 💡 [احترافي] الحذف الآمن
  isDeleted Boolean @default(false)

  // 💡 [احترافي] التتبع
  uploadedBy String // الموظف الذي رفع الملف
  updatedBy  String? // الموظف الذي غير اسمه
  deletedBy  String? // الموظف الذي حذفه
  deletedAt  DateTime?

  // 💡 [احترافي] البيانات الوصفية المرنة (Meta-data)
  tags            String[] // [فواتير, 2026, ضرائب]
  aiExtractedData Json? // بيانات استخرجها الذكاء الاصطناعي من الملف

  // العلاقات
  folderId String?
  folder   TransactionFolder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  transactionId String?
  transaction   PrivateTransaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  // 💡 سجل الحركات الخاص بهذا الملف تحديداً
  activityLogs FileActivityLog[]
  // 💡 الإصدارات القديمة من هذا الملف
  versions     FileVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionId])
  @@index([folderId])
}

// ============================================================================
// 💡 نظام الإصدارات (File Versioning) - للإحتفاظ بتاريخ الملفات المعدلة
// ============================================================================
model FileVersion {
  id     String          @id @default(cuid())
  fileId String
  file   TransactionFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  versionNumber Int
  url           String
  size          Int
  uploadedBy    String
  changeNotes   String? // سبب التعديل

  createdAt DateTime @default(now())

  @@index([fileId])
}

// ============================================================================
// 💡 سجل التدقيق للملفات (Audit Trail & Activity Logs) - تتبع كل همسة!
// ============================================================================
model FileActivityLog {
  id String @id @default(cuid())

  fileId String?
  file   TransactionFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)

  folderId String? // في حال كان الحدث على مجلد

  // نوع الحدث: UPLOAD, DOWNLOAD, VIEW, RENAME, DELETE, RESTORE, SHARE
  action String

  // من قام بالحدث؟
  performedBy String // معرف أو اسم الموظف

  // من أين؟
  ipAddress String? // رقم الـ IP للموظف (أمان)
  userAgent String? // المتصفح والجهاز المستخدم

  // ماذا تغير؟ (مثال: { "oldName": "x.pdf", "newName": "y.pdf" })
  details Json?

  createdAt DateTime @default(now())

  @@index([fileId])
  @@index([action])
  @@index([performedBy])
}

// ============================================================================
// 💡 إعدادات تصنيفات المجلدات
// ============================================================================
model FolderCategory {
  id         String   @id @default(cuid())
  name       String // اسم التصنيف (مثل: مرفقات، صكوك)
  code       String? // كود مكون من 3 أرقام (اختياري)
  icon       String // الرمز (Emoji)
  color      String // كود اللون (Hex)
  order      Int      @default(0) // ترتيب العرض
  subFolders String[] // قائمة بأسماء المجلدات الفرعية التلقائية

  // صلاحيات افتراضية لمن يمكنه رؤية هذا التصنيف
  allowedRoles String[] @default(["ALL"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 1. جدول النماذج الأساسية (القوالب / Templates)
// ==========================================
model FormTemplate {
  id          String  @id @default(uuid())
  code        String  @unique // الكود المرجعي للنموذج (مثال: FRM-HR-001)
  name        String // اسم النموذج (مثال: إخلاء طرف)
  description String? @db.Text
  version     String  @default("1.0")
  category    String // hr, financial, operations, general

  // إعدادات المظهر والطباعة
  colorMode    String  @default("color")
  numberFormat String  @default("english")
  timezone     String  @default("Asia/Riyadh")
  fontFamily   String  @default("Tajawal")
  fontSize     Int     @default(12)
  isPublic     Boolean @default(false)
  isActive     Boolean @default(true)

  // إعدادات الصفحة (Json للحفاظ على المرونة)
  pageSettings Json // يحتوي على: orientation, size, margins, header_height

  // الصور والخلفيات
  headerImage String?
  footerImage String?
  bgImage     String?

  borderSettings Json? // 👈 إضافة حقل الإطار
  watermark      Json? // 👈 إضافة حقل العلامة المائية

  // العلاقات (Relations)
  blocks FormBlock[] // الحقول المكونة للنموذج
  usages FormUsage[] // سجلات استخدام هذا النموذج

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 2. جدول حقول النموذج (البلوكات / Blocks)
// ==========================================
model FormBlock {
  id         String       @id @default(uuid())
  templateId String
  template   FormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  type  String // نوع الحقل (text, date, signature, employee_info, table...)
  label String // التسمية

  position Json // الإحداثيات والأبعاد (x, y, width, height)
  style    Json // المحاذاة والألوان

  // إعدادات التعبئة
  isEditable   Boolean @default(true) // هل يسمح للمستخدم بتعديله عند الاستخدام؟
  isRequired   Boolean @default(false) // هل هو إجباري؟
  dataSource   String  @default("manual") // مصدر البيانات (manual, auto_system, auto_employee)
  defaultValue String? @db.Text // النص الافتراضي أو رابط الصورة

  // إعدادات إضافية للجداول أو القوائم المعقدة
  config Json?

  order Int @default(0) // ترتيب الحقل
}

// ==========================================
// 3. جدول سجلات الاستخدام (النماذج المعبأة / Usages)
// ==========================================
model FormUsage {
  id         String       @id @default(uuid())
  templateId String
  template   FormTemplate @relation(fields: [templateId], references: [id])

  // السريال القانوني الفريد (سيتم توليده ديناميكياً)
  trackingSerial String @unique

  userId       String // معرف الموظف الذي قام بإنشاء/تعبئة النموذج
  targetUserId String? // إذا كان النموذج يخص موظف معين (مثل شهادة راتب لموظف آخر)

  status String @default("draft") // مسودة (draft)، مكتمل (completed)، مؤرشف (archived)

  // رابط ملف الـ PDF النهائي (بعد الاعتماد/الطباعة، يحفظ كملف ثابت لا يتغير)
  generatedPdfUrl String?

  // العلاقات
  values FormFieldValue[] // القيم التي تم إدخالها في هذا الاستخدام بالتحديد

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 4. جدول قيم الحقول (إجابات المستخدم / Field Values)
// ==========================================
model FormFieldValue {
  id      String    @id @default(uuid())
  usageId String
  usage   FormUsage @relation(fields: [usageId], references: [id], onDelete: Cascade)

  blockId String // يشير إلى الحقل في جدول FormBlock

  textValue String? @db.Text // للقيم النصية المباشرة
  jsonValue Json? // للجداول، أو البصمات، أو التواقيع المحفوظة كـ Base64
}

model SystemFolder {
  id       String  @id @default(uuid())
  name     String
  parentId String? // إذا كان null، فهو داخل مجلد النظام الثابت (مثل: sys-hr)

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false) // للحذف المنطقي (سلة المحذوفات)

  files SystemFile[]
}

model SystemFile {
  id           String @id @default(uuid())
  name         String
  originalName String
  extension    String
  size         Int
  url          String

  // 💡 الحقول الجديدة المطلوبة للنزاهة والإصدارات
  fileHash String? // بصمة الملف (MD5)
  version  Int     @default(1) // رقم الإصدار

  folderId String?
  folder   SystemFolder? @relation(fields: [folderId], references: [id])

  uploadedBy String?
  createdAt  DateTime  @default(now())
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?
  deletedBy  String?
}

model EmailAccount {
  id          String         @id @default(uuid())
  accountName String
  email       String         @unique
  imapServer  String         @default("imap.hostinger.com") // خادم هوستنقر للاستقبال
  imapPort    Int            @default(993)
  smtpServer  String         @default("smtp.hostinger.com") // خادم هوستنقر للإرسال
  smtpPort    Int            @default(465)
  username    String
  password    String // يُفضل تشفيرها في المشاريع الحقيقية
  useSSL      Boolean        @default(true)
  isActive    Boolean        @default(true)
  messages    EmailMessage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model EmailMessage {
  id        String       @id @default(uuid())
  messageId String       @unique // المعرف الآتي من مزود البريد
  accountId String
  account   EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  from      String
  to        String?
  cc        String? // 👈 يجب إضافته
  bcc       String? // 👈 يجب إضافته
  subject   String?
  body      String?      @db.Text
  html      String?      @db.Text
  date      DateTime     @default(now())

  isRead     Boolean @default(false)
  isStarred  Boolean @default(false)
  isArchived Boolean @default(false)
  isDeleted  Boolean @default(false)
  isSent     Boolean @default(false)
  isDraft    Boolean @default(false)

  hasAttachments  Boolean  @default(false)
  messageCategory String? // لتخزين تصنيف الذكاء الاصطناعي
  createdAt       DateTime @default(now())
  isAnalyzed      Boolean  @default(false)
  // البيانات المستخرجة
  reqNumber       String? // رقم الطلب
  reqYear         String? // سنة الطلب
  serviceNumber   String? // رقم الخدمة
  serviceYear     String? // سنة الخدمة
  ownerName       String? // اسم المالك
  serviceType     String? // نوع الخدمة
  replyText       String? // الإفادة / محتوى الرد
  entityName      String? // اسم الجهة
  viewTime        String? // وقت الإطلاع (حقل إضافي)
  sectorName      String? // القطاع (حقل إضافي)

  // 💡 حقول التوقيع والفوتر للمسودات
  signature   String? @db.Text
  footerText  String? @db.Text
  footerColor String?
  footerSize  String?

  // الربط التلقائي بمعاملة (للاستخدام لاحقاً)
  linkedTxId      String?
  matchConfidence Int? // نسبة التطابق

  @@index([date(sort: Desc)])
  @@index([isDraft, isSent, isArchived, isDeleted])
  @@index([messageId])
  @@index([from])
}

model Notification {
  id                String   @id @default(uuid())
  code              String   @unique
  category          String // عاجل، مالي، توثيق، نظام، معاملات
  subCategory       String? // فواتير متأخرة، تسويات جاهزة، إلخ
  relatedEntityCode String? // المرجع مثل INV-5678
  title             String
  description       String   @db.Text
  severity          String   @default("low") // high, medium, low
  timestamp         DateTime @default(now())
  createdByRule     String?
  isRead            Boolean  @default(false)
  assignedTo        String?
  amount            Float?
  daysOverdue       Int?
  attachmentMissing Boolean  @default(false)
  linkedScreen      Json? // لتخزين مسار الشاشة { screenCode, iconId, tabId }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TailscaleConfig {
  id        String   @id @default(uuid())
  tailnet   String? // اسم الشبكة (مثال: mydomain.github.beta.tailscale.net)
  apiKey    String? // مفتاح Tailscale (API Key)
  authKey   String? // مفتاح الـ Auth (لربط الأجهزة الجديدة تلقائياً) 👈 الحقل الجديد
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransactionSource {
  id        String   @id @default(uuid())
  name      String   @unique // الاسم يجب أن يكون غير مكرر
  isActive  Boolean  @default(true) // لإمكانية إخفاء المصدر دون حذفه نهائياً
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// نموذج تصنيفات الروابط
model LinkCategory {
  id        String      @id @default(uuid())
  name      String      @unique
  links     QuickLink[]
  createdAt DateTime    @default(now())
}

// نموذج الروابط السريعة
model QuickLink {
  id          String  @id @default(uuid())
  title       String
  url         String
  description String?

  // العلاقات
  categoryId String
  category   LinkCategory @relation(fields: [categoryId], references: [id])

  // الوصول والأمان
  accessLevel       String  @default("الكل") // الإدارة العليا، الموظفين، أخرى
  requiresLogin     Boolean @default(false)
  loginData         String? // يمكن حفظه كنص مشفر لاحقاً
  assignedEmployees String? // نص يحمل أسماء الموظفين مفصولين بفاصلة

  // الصلاحيات (التواريخ)
  validUntil  DateTime?
  loginExpiry DateTime?

  // بيانات إضافية
  customFields Json? // مصفوفة من {key, value}
  notes        String?
  usageCount   Int     @default(0)

  isPinned   Boolean @default(false)
  pinOrder   Int     @default(0) // 👈 حقل ترتيب التثبيت
  importance String  @default("عادي")

  // التتبع
  createdBy String   @default("مدير النظام")
  updatedBy String   @default("مدير النظام")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReferenceDocument {
  id       String  @id @default(cuid())
  title    String
  source   String
  category String
  type     String
  fileUrl  String?

  // 1. المعاملات المستهدفة
  txType         String?
  txMainCategory String?
  txSubCategory  String?

  // محددات الانطباق
  transactionTypes String[]
  // 2. العقار والأرض
  buildingTypes    String[]
  landAreaFrom     Float?
  landAreaTo       Float?

  // 3. الموقع الجغرافي
  city      String?
  sector    String?
  districts String[]

  floorsFrom      Int?
  floorsTo        Int?
  streetWidthFrom Int?
  streetWidthTo   Int?

  issueDate  DateTime?
  expiryDate DateTime?

  status         String @default("نشط")
  analysisStatus String @default("غير محلل")

  // نصوص الإدارة والتحليل
  keyRules    String[]
  aiSummary   String?  @db.Text
  manualNotes String?  @db.Text

  // 🚀 الحقول الجديدة المستخرجة بواسطة الذكاء الاصطناعي
  windProtocol       String? @db.Text
  monitoringProtocol String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // علاقة مع سجل التحديثات (يحذف السجلات تلقائياً إذا حُذف المستند)
  logs ReferenceLog[]
}

model ReferenceLog {
  id          String            @id @default(cuid())
  referenceId String
  reference   ReferenceDocument @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  action    String
  userName  String
  userEmail String?

  createdAt DateTime @default(now())
}

// أضف هذا الموديل في ملف prisma/schema.prisma

model AdvancedContract {
  id     String   @id @default(uuid())
  code   String   @unique // رقم العقد المولد
  name   String
  type   String // تصميم، إشراف، إلخ
  status String   @default("Draft")
  date   DateTime @default(now())

  // بيانات الأطراف (تخزن كـ Json لتجنب تعقيد الجداول)
  partyA        String? // 👈 مفقود سابقاً
  partyB        String? // 👈 مفقود سابقاً
  partyADetails Json
  partyBDetails Json

  // تفاصيل المشروع
  projectDetails Json
  terms          String? @db.Text // 👈 مفقود سابقاً (نطاق العمل التفصيلي)
  activePresets  Json? // 👈 مفقود سابقاً (القوالب)

  // التفاصيل المالية
  financials      Json
  contractValue   Float
  paymentTerms    String @db.Text
  paymentSchedule Json // جدول الدفعات

  // المحتوى القانوني والالتزامات
  introduction      String  @db.Text
  obligationsList   Json // قائمة الالتزامات التفصيلية
  generalConditions String  @db.Text
  governingLaw      String  @db.Text
  witnesses         Json? // 👈 مفقود سابقاً (الشهود)
  aiRiskAssessment  String? @db.Text // تقييم المخاطر المولد بالذكاء الاصطناعي

  // الذكاء الاصطناعي والملخصات
  coverSummary         String? @db.Text // 👈 مفقود سابقاً
  aiSummary            String? @db.Text // 👈 مفقود سابقاً
  isOnePageSummary     Boolean @default(false) // 👈 مفقود سابقاً
  // إعدادات التصميم (الإطارات، الخطوط، الخلفيات)
  designSettings       Json?
  // إعدادات التصميم والتحقق (تم فصلهم ليتطابقوا مع الـ Frontend)
  frameSettings        Json? // 👈 بدلاً من وضعها داخل designSettings
  spacingSettings      Json?
  typographySettings   Json?
  verificationSettings Json? // 👈 مفقود سابقاً
